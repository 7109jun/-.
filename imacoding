.inspector-title{color:#4ecdc4;font-size:11px;font-weight:bold;margin-bottom:8px;text-transform:uppercase;letter-spacing:0.5px}
.inspector-row{display:flex;align-items:center;margin-bottom:6px;gap:6px}
.inspector-label{color:#888;font-size:11px;width:70px;flex-shrink:0}

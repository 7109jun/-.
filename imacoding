const SHAPE_RANGES = {
  triangle:  {r:[180,255],g:[0,120],b:[0,120]},
  rectangle: {r:[0,120],g:[180,255],b:[150,255]},
  circle:    {r:[80,180],g:[180,255],b:[180,255]},
  star:      {r:[200,255],g:[180,255],b:[0,120]},
  hexagon:   {r:[80,180],g:[180,255],b:[100,180]},
  pentagon:  {r:[140,220],g:[140,220],b:[200,255]}
};
const SHAPE_LIST = ['triangle','rectangle','circle','star','hexagon','pentagon'];

/* ---------- LOGGER ---------- */
class Logger {
  constructor(el) { this.el = el; }
  log(msg, type='info') {
    const d = document.createElement('div');
    d.className = `log-line log-${type}`;
    d.textContent = `[${new Date().toLocaleTimeString()}] ${msg}`;
    this.el.appendChild(d);
    this.el.scrollTop = this.el.scrollHeight;
  }
  clear() { this.el.innerHTML = ''; }
  status(msg) {
    document.getElementById('status-left').textContent = msg;
  }
}


              1. Write code in the editor<br>
              2. Click ⚙ Compile<br>
              3. Click ▶ Play<br>
              4. Use WASD to move<br><br>
              Try editing the default code and see what happens!<br>
              Change <code>mode: doom</code> to <code>mode: 2d</code> for a different experience.
            </p>
          </div>
        `,
        target: null,
        position: 'center'
      }
    ];
    
    this.setupEvents();
  }
  
  setupEvents() {
    document.getElementById('tut-next').onclick = () => this.next();
    document.getElementById('tut-prev').onclick = () => this.prev();
    document.getElementById('tut-skip').onclick = () => this.end();
    document.getElementById('btn-tutorial').onclick = () => this.start();
  }
  
  start() {
    this.currentStep = 0;
    this.active = true;
    this.overlay.classList.add('active');
    this.showStep();
  }
  
  end() {
    this.active = false;
    this.overlay.classList.remove('active');
    localStorage.setItem('pixelvm_tutorial_done', '1');
  }
  
  next() {
    if (this.currentStep < this.steps.length - 1) {
      this.currentStep++;
      this.showStep();
    } else {
      this.end();
    }
  }
  
  prev() {
    if (this.currentStep > 0) {
      this.currentStep--;
      this.showStep();
    }
  }
  
  showStep() {
    const step = this.steps[this.currentStep];
    
    // Update content
    this.titleEl.textContent = step.title;
    this.contentEl.innerHTML = step.content;
    
    // Update progress
    const progress = ((this.currentStep + 1) / this.steps.length) * 100;
    this.progressFill.style.width = progress + '%';
    this.progressText.textContent = `${this.currentStep + 1}/${this.steps.length}`;
    
    // Update buttons
    document.getElementById('tut-prev').style.visibility = this.currentStep === 0 ? 'hidden' : 'visible';
    document.getElementById('tut-next').textContent = this.currentStep === this.steps.length - 1 ? 'Finish ✓' : 'Next →';
    
    // Spotlight
    if (step.target) {
      const el = document.querySelector(step.target);
      if (el) {
        const rect = el.getBoundingClientRect();
        const pad = 6;
        this.spotlight.style.left = (rect.left - pad) + 'px';
        this.spotlight.style.top = (rect.top - pad) + 'px';
        this.spotlight.style.width = (rect.width + pad*2) + 'px';
        this.spotlight.style.height = (rect.height + pad*2) + 'px';
        this.spotlight.style.display = 'block';
        this.positionTooltip(rect, step.position);
      }
    } else {
      this.spotlight.style.display = 'none';
      this.tooltip.style.left = '50%';
      this.tooltip.style.top = '50%';
      this.tooltip.style.transform = 'translate(-50%, -50%)';
    }
  }
  
  positionTooltip(targetRect, position) {
    const tt = this.tooltip;
    tt.style.transform = 'none';
    
    const margin = 20;
    const ttWidth = 400;
    const ttHeight = tt.offsetHeight || 200;
    
    switch(position) {
      case 'right':
        tt.style.left = (targetRect.right + margin) + 'px';
        tt.style.top = targetRect.top + 'px';
        if (targetRect.right + margin + ttWidth > window.innerWidth) {
          tt.style.left = (targetRect.left - ttWidth - margin) + 'px';
        }
        break;
      case 'left':
        tt.style.left = (targetRect.left - ttWidth - margin) + 'px';
        tt.style.top = targetRect.top + 'px';
        if (targetRect.left - ttWidth - margin < 0) {
          tt.style.left = (targetRect.right + margin) + 'px';
        }
        break;
      case 'bottom':
        tt.style.left = targetRect.left + 'px';
        tt.style.top = (targetRect.bottom + margin) + 'px';
        if (targetRect.bottom + margin + ttHeight > window.innerHeight) {
          tt.style.top = (targetRect.top - ttHeight - margin) + 'px';
        }
        break;
      case 'top':
        tt.style.left = targetRect.left + 'px';
        tt.style.top = (targetRect.top - ttHeight - margin) + 'px';
        break;
      default:
        tt.style.left = '50%';
        tt.style.top = '50%';
        tt.style.transform = 'translate(-50%, -50%)';
    }
  }
}

/* ---------- CODE PARSER ---------- */
class CodeParser {
  parse(code) {
    const result = { mode:'2d', entities:[], map:null };
    const lines = code.split('\n');
    let i = 0;
    while (i < lines.length) {
      const line = lines[i].trim();
      if (!line || line.startsWith('//')) { i++; continue; }
      const modeMatch = line.match(/^mode:\s*(\w+)/);
      if (modeMatch) { result.mode = modeMatch[1]; i++; continue; }
      const entMatch = line.match(/^entity\s+(\w+)\s*\{/);
      if (entMatch) {
        const name = entMatch[1];
        const ent = { name, shape:'circle', color:'#ffffff', pos:[200,200], vel:[0,0], ai:'idle', hp:100, layer:0, scale:1 };
        i++;
        while (i < lines.length && !lines[i].includes('}')) {
          const prop = lines[i].trim();
          if (prop && !prop.startsWith('//')) {
            const m = prop.match(/^(\w+):\s*(.+)$/);
            if (m) this.parseProp(ent, m[1], m[2]);
          }
          i++;
        }
        result.entities.push(ent);
        i++; continue;
      }
      if (line === 'map {') {
        const rows = [];
        i++;
        while (i < lines.length && !lines[i].includes('}')) {
          const row = lines[i].trim();
          if (row && /^[01]+$/.test(row)) rows.push(row.split('').map(Number));
          i++;
        }
        result.map = rows;
        i++; continue;
      }
      i++;
    }
    return result;
  }
  parseProp(ent, key, val) {
    val = val.trim();
    switch(key) {
      case 'shape': ent.shape = val; break;
      case 'color': ent.color = val; break;
      case 'pos':
        const pm = val.match(/\(([^,]+),\s*([^)]+)\)/);
        if (pm) ent.pos = [parseFloat(pm[1]), parseFloat(pm[2])];
        break;
      case 'vel':
        const vm = val.match(/\(([^,]+),\s*([^)]+)\)/);
        if (vm) ent.vel = [parseFloat(vm[1]), parseFloat(vm[2])];
        break;
      case 'ai': ent.ai = val; break;
      case 'hp': ent.hp = parseFloat(val); break;
      case 'layer': ent.layer = parseInt(val); break;
      case 'scale': ent.scale = parseFloat(val); break;
    }
  }
}

/* ---------- IMAGE GENERATOR ---------- */
class ImageGenerator {
  constructor() {
    this.canvas = document.createElement('canvas');
    this.ctx = this.canvas.getContext('2d');
  }
  generate(ast) {
    const numEntities = ast.entities.length;
    const numColors = new Set(ast.entities.map(e => e.color)).size;
    const cols = Math.max(16, numEntities + numColors + 2);
    const mapRows = ast.map ? ast.map.length : 0;
    const rows = 2 + Math.max(mapRows, Math.ceil(numEntities / cols));
    this.canvas.width = Math.max(64, cols);
    this.canvas.height = Math.max(64, rows);
    this.ctx.fillStyle = '#000';
    this.ctx.fillRect(0, 0, this.canvas.width, this.canvas.height);
    const uniqueColors = [...new Set(ast.entities.map(e => e.color))];
    const colorMap = {};
    uniqueColors.forEach((c, i) => {
      const rgb = this.hexToRgb(c);
      const r = Math.min(100, rgb[0] / 2);
      const g = 180 + (i % 70);
      const b = 150 + (i % 100);
      colorMap[c] = { r, g, b };
      this.setPixel(i, 0, r, g, b);
    });
    ast.entities.forEach((ent, i) => {
      const col = i % (cols - 1);
      const row = 1 + Math.floor(i / (cols - 1));
      const shapeIdx = SHAPE_LIST.indexOf(ent.shape);
      const range = SHAPE_RANGES[ent.shape] || SHAPE_RANGES.circle;
      const colorIdx = uniqueColors.indexOf(ent.color);
      const r = range.r[0] + ((shapeIdx * 10) + (ent.pos[0] / 10)) % (range.r[1] - range.r[0]);
      const g = 180 + (colorIdx * 10) % 70;
      const b = range.b[0] + ((ent.layer * 20) + ent.pos[1] / 10) % (range.b[1] - range.b[0]);
      this.setPixel(col, row, r, g, b);
    });
    if (ast.map) {
      for (let y = 0; y < ast.map.length; y++) {
        for (let x = 0; x < ast.map[y].length; x++) {
          if (ast.map[y][x] === 1) {
            const r = 100 + (x * 5) % 80;
            const g = 200 + (y * 3) % 50;
            const b = 120 + ((x+y) * 7) % 60;
            this.setPixel(x, 2 + y, r, g, b);
          }
        }
      }
    }
    return this.canvas;
  }
  setPixel(x, y, r, g, b) {
    const img = this.ctx.getImageData(0, 0, this.canvas.width, this.canvas.height);
    const i = (y * this.canvas.width + x) * 4;
    img.data[i] = r; img.data[i+1] = g; img.data[i+2] = b; img.data[i+3] = 255;
    this.ctx.putImageData(img, 0, 0);
  }
  hexToRgb(hex) {
    const m = hex.match(/^#?([a-f\d]{2})([a-f\d]{2})([a-f\d]{2})$/i);
    return m ? [parseInt(m[1],16), parseInt(m[2],16), parseInt(m[3],16)] : [255,255,255];
  }
}

/* ---------- IMAGE DECODER ---------- */
class ImageDecoder {
  decode(canvas) {
    const ctx = canvas.getContext('2d', { willReadFrequently: true });
    const img = ctx.getImageData(0, 0, canvas.width, canvas.height);
    const entities = [];
    const colors = {};
    for (let x = 0; x < canvas.width; x++) {
      const i = (0 * canvas.width + x) * 4;
      const r = img.data[i], g = img.data[i+1], b = img.data[i+2];
      if (r === 0 && g === 0 && b === 0) continue;
      if (this.inRange(r, [0,120]) && this.inRange(g, [180,255]) && this.inRange(b, [150,255])) {
        const name = String.fromCharCode(65 + (g - 180) % 26);
        colors[name] = `rgb(${Math.min(255,r*2)},${g},${b})`;
      }
    }
    let entIdx = 0;
    for (let y = 1; y < canvas.height; y++) {
      for (let x = 0; x < canvas.width; x++) {
        const i = (y * canvas.width + x) * 4;
        const r = img.data[i], g = img.data[i+1], b = img.data[i+2];
        if (r === 0 && g === 0 && b === 0) continue;
        const shape = this.detectShape(r, g, b);
        if (shape) {
          const colorKey = String.fromCharCode(65 + (g - 180) % 26);
          const color = colors[colorKey] || '#ffffff';
          entities.push({
            name: `E${entIdx}`, shape, color,
            pos: [x * 30 + 50, y * 30 + 50],
            vel: [0, 0], ai: 'idle', hp: 100, layer: b % 10, scale: 1
          });
          entIdx++;
        }
      }
    }
    return { entities, mode: '2d', map: null };
  }
  detectShape(r, g, b) {
    for (const [shape, range] of Object.entries(SHAPE_RANGES)) {
      if (this.inRange(r, range.r) && this.inRange(g, range.g) && this.inRange(b, range.b)) return shape;
    }
    return null;
  }
  inRange(v, [min, max]) { return v >= min && v <= max; }
}

/* ---------- ENTITY ---------- */
class Entity {
  constructor(data) {
    Object.assign(this, {
      id: Math.random().toString(36).slice(2),
      name:'?', shape:'circle', color:'#fff',
      pos:[0,0], vel:[0,0], hp:100, ai:'idle', layer:0, scale:1,
      angle:0, alive:true
    }, data);
    this.x = this.pos[0]; this.y = this.pos[1];
    this.vx = this.vel[0]; this.vy = this.vel[1];
    this.width = 30 * this.scale;
    this.height = 30 * this.scale;
  }
}

/* ---------- PHYSICS ---------- */
class Physics {
  update(entities, dt) {
    for (const e of entities) {
      if (!e.alive) continue;
      e.x += e.vx * dt; e.y += e.vy * dt;
      if (e.x < 0) { e.x = 0; e.vx *= -0.5; }
      if (e.x > 640-e.width) { e.x = 640-e.width; e.vx *= -0.5; }
      if (e.y < 0) { e.y = 0; e.vy *= -0.5; }
      if (e.y > 400-e.height) { e.y = 400-e.height; e.vy *= -0.5; }
    }
    for (let i=0; i<entities.length; i++) {
      for (let j=i+1; j<entities.length; j++) {
        const a = entities[i], b = entities[j];
        if (!a.alive || !b.alive) continue;
        if (this.aabb(a,b)) this.resolve(a,b);
      }
    }
  }
  aabb(a,b) {
    return a.x < b.x+b.width && a.x+a.width > b.x && a.y < b.y+b.height && a.y+a.height > b.y;
  }
  resolve(a,b) {
    const dx = (a.x+a.width/2) - (b.x+b.width/2);
    const dy = (a.y+a.height/2) - (b.y+b.height/2);
    a.vx += dx * 0.05; a.vy += dy * 0.05;
    b.vx -= dx * 0.05; b.vy -= dy * 0.05;
  }
}

/* ---------- AI ---------- */
class AI {
  update(entities, dt, player) {
    for (const e of entities) {
      if (!e.alive || e === player) continue;
      switch(e.ai) {
        case 'wander':
          if (Math.random() < 0.02) {
            e.vx = (Math.random()-0.5) * 100;
            e.vy = (Math.random()-0.5) * 100;
          }
          break;
        case 'chase':
          if (player && player.alive) {
            const dx = player.x - e.x, dy = player.y - e.y;
            const d = Math.hypot(dx,dy);
            if (d > 1) { e.vx = (dx/d)*80; e.vy = (dy/d)*80; }
          }
          break;
        case 'flee':
          if (player && player.alive) {
            const dx = e.x - player.x, dy = e.y - player.y;
            const d = Math.hypot(dx,dy);
            if (d > 1 && d < 200) { e.vx = (dx/d)*120; e.vy = (dy/d)*120; }
          }
          break;
      }
    }
  }
}

/* ---------- INPUT ---------- */
class Input {
  constructor() {
    this.keys = {};
    window.addEventListener('keydown', e => this.keys[e.key.toLowerCase()] = true);
    window.addEventListener('keyup', e => this.keys[e.key.toLowerCase()] = false);
  }
  isDown(k) { return !!this.keys[k]; }
}

/* ---------- AUDIO ---------- */
class Audio {
  constructor() { this.ctx = null; }
  init() {
    if (!this.ctx) try { this.ctx = new (window.AudioContext||window.webkitAudioContext)(); } catch(e){}
  }
  beep(freq=440, dur=0.1, type='square', vol=0.1) {
    if (!this.ctx) return;
    const o = this.ctx.createOscillator();
    const g = this.ctx.createGain();
    o.type = type; o.frequency.value = freq;
    g.gain.setValueAtTime(vol, this.ctx.currentTime);
    g.gain.exponentialRampToValueAtTime(0.001, this.ctx.currentTime + dur);
    o.connect(g); g.connect(this.ctx.destination);
    o.start(); o.stop(this.ctx.currentTime + dur);
  }
}

/* ---------- RENDERER ---------- */
class Renderer {
  constructor(canvas) {
    this.canvas = canvas;
    this.ctx = canvas.getContext('2d');
  }
  clear() {
    this.ctx.fillStyle = '#000';
    this.ctx.fillRect(0,0,this.canvas.width,this.canvas.height);
  }
  render2D(entities) {
    this.clear();
    const sorted = [...entities].filter(e=>e.alive).sort((a,b)=>a.layer-b.layer);
    for (const e of sorted) this.drawEntity(e);
  }
  drawEntity(e) {
    const ctx = this.ctx;
    ctx.save();
    ctx.translate(e.x + e.width/2, e.y + e.height/2);
    ctx.rotate(e.angle);
    ctx.scale(e.scale, e.scale);
    ctx.fillStyle = e.color;
    ctx.strokeStyle = '#000';
    ctx.lineWidth = 2;
    const s = Math.min(e.width, e.height)/2;
    this.drawShape(ctx, e.shape, s);
    ctx.restore();
    ctx.fillStyle = '#fff';
    ctx.font = '10px monospace';
    ctx.textAlign = 'center';
    ctx.fillText(e.name, e.x + e.width/2, e.y - 4);
  }
  drawShape(ctx, shape, s) {
    ctx.beginPath();
    switch(shape) {
      case 'triangle':
        ctx.moveTo(0,-s); ctx.lineTo(s,s); ctx.lineTo(-s,s); break;
      case 'rectangle':
        ctx.rect(-s,-s,s*2,s*2); break;
      case 'circle':
        ctx.arc(0,0,s,0,Math.PI*2); break;
      case 'star':
        for (let i=0; i<10; i++) {
          const a = (Math.PI/5)*i - Math.PI/2;
          const r = i%2===0 ? s : s/2;
          const x = r*Math.cos(a), y = r*Math.sin(a);
          if (i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
        }
        break;
      case 'hexagon':
        for (let i=0; i<6; i++) {
          const a = (Math.PI/3)*i - Math.PI/2;
          const x = s*Math.cos(a), y = s*Math.sin(a);
          if (i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
        }
        break;
      case 'pentagon':
        for (let i=0; i<5; i++) {
          const a = (Math.PI*2/5)*i - Math.PI/2;
          const x = s*Math.cos(a), y = s*Math.sin(a);
          if (i===0) ctx.moveTo(x,y); else ctx.lineTo(x,y);
        }
        break;
    }
    ctx.closePath();
    ctx.fill();
    ctx.stroke();
  }
  renderRaycast(entities, player, map) {
    if (!map || !player) { this.render2D(entities); return; }
    const ctx = this.ctx;
    const W = this.canvas.width, H = this.canvas.height;
    const sky = ctx.createLinearGradient(0,0,0,H/2);
    sky.addColorStop(0,'#223'); sky.addColorStop(1,'#556');
    ctx.fillStyle = sky; ctx.fillRect(0,0,W,H/2);
    const floor = ctx.createLinearGradient(0,H/2,0,H);
    floor.addColorStop(0,'#443'); floor.addColorStop(1,'#221');
    ctx.fillStyle = floor; ctx.fillRect(0,H/2,W,H/2);
    const fov = Math.PI/3;
    const maxDist = 20;
    for (let i=0; i<W; i++) {
      const rayAngle = player.angle - fov/2 + (i/W)*fov;
      const {dist, side} = this.castRay(player.x/40, player.y/40, rayAngle, maxDist, map);
      const corrected = dist * Math.cos(rayAngle - player.angle);
      const wallH = Math.min(H, (H / corrected) * 0.8);
      const shade = Math.max(0, 1 - dist/maxDist);
      ctx.fillStyle = side === 0 ?
        `rgb(${180*shade|0},${80*shade|0},${80*shade|0})` :
        `rgb(${130*shade|0},${60*shade|0},${60*shade|0})`;
      ctx.fillRect(i, (H-wallH)/2, 1, wallH);
    }
    const sprites = entities.filter(e => e.alive && e !== player).map(e => {
      const dx = e.x/40 - player.x/40;
      const dy = e.y/40 - player.y/40;
      return { e, dist: Math.hypot(dx,dy), angle: Math.atan2(dy,dx) };
    }).sort((a,b) => b.dist - a.dist);
    for (const sp of sprites) {
      let rel = sp.angle - player.angle;
      while (rel > Math.PI) rel -= Math.PI*2;
      while (rel < -Math.PI) rel += Math.PI*2;
      if (Math.abs(rel) > fov/2 + 0.2) continue;
      const sx = (0.5 + rel/fov) * W;
      const size = Math.min(H, (H / sp.dist) * 0.8);
      const shade = Math.max(0.2, 1 - sp.dist/maxDist);
      ctx.save();
      ctx.globalAlpha = shade;
      ctx.fillStyle = sp.e.color;
      ctx.strokeStyle = '#000';
      ctx.lineWidth = 2;
      const s = size/2;
      ctx.translate(sx, H/2);
      this.drawShape(ctx, sp.e.shape, s);
      ctx.fill(); ctx.stroke();
      ctx.restore();
      ctx.fillStyle = '#fff';
      ctx.font = '12px monospace';
      ctx.textAlign = 'center';
      ctx.fillText(sp.e.name, sx, H/2 - s - 5);
    }
    ctx.fillStyle = 'rgba(0,0,0,0.6)';
    ctx.fillRect(0,H-40,W,40);
    ctx.fillStyle = '#4ecdc4';
    ctx.font = 'bold 14px monospace';
    ctx.textAlign = 'left';
    ctx.fillText(`HP: ${player.hp}  POS: (${player.x.toFixed(0)},${player.y.toFixed(0)})  ANG: ${(player.angle*180/Math.PI).toFixed(0)}°`, 10, H-15);
    ctx.strokeStyle = '#fff';
    ctx.lineWidth = 2;
    ctx.beginPath();
    ctx.moveTo(W/2-10, H/2); ctx.lineTo(W/2+10, H/2);
    ctx.moveTo(W/2, H/2-10); ctx.lineTo(W/2, H/2+10);
    ctx.stroke();
  }
  castRay(ox, oy, angle, maxDist, map) {
    const dx = Math.cos(angle), dy = Math.sin(angle);
    const step = 0.05;
    for (let d=0; d<maxDist; d+=step) {
      const x = ox + dx*d, y = oy + dy*d;
      const mx = Math.floor(x), my = Math.floor(y);
      if (mx<0||my<0||my>=map.length||mx>=map[0].length) return {dist:d,side:0};
      if (map[my][mx] === 1) {
        const fx = x - mx;
        return {dist:d, side: (fx < 0.05 || fx > 0.95) ? 0 : 1};
      }
    }
    return {dist:maxDist, side:0};
  }
}

/* ---------- GAME ENGINE ---------- */
class GameEngine {
  constructor(logger) {
    this.logger = logger;
    this.entities = [];
    this.player = null;
    this.map = null;
    this.mode = '2d';
    this.physics = new Physics();
    this.ai = new AI();
    this.input = new Input();
    this.audio = new Audio();
    this.running = false;
    this.lastTime = 0;
  }
  reset() { this.entities = []; this.player = null; this.map = null; }
  loadAST(ast) {
    this.reset();
    this.mode = ast.mode;
    this.map = ast.map;
    ast.entities.forEach((data, i) => {
      const e = new Entity(data);
      if (i === 0 || data.name === 'P') { this.player = e; e.ai = 'idle'; }
      this.entities.push(e);
    });
    if (!this.player && this.entities.length > 0) {
      this.player = this.entities[0];
      this.player.ai = 'idle';
    }
    if (this.mode === 'doom' && this.player) this.player.angle = 0;
  }
  start() {
    if (this.running) return;
    this.running = true;
    this.audio.init();
    this.lastTime = performance.now();
    requestAnimationFrame(t => this.loop(t));
    this.logger.log('Engine started', 'info');
  }
  stop() {
    this.running = false;
    this.logger.log('Engine stopped', 'info');
  }
  loop(now) {
    if (!this.running) return;
    const dt = Math.min(0.05, (now - this.lastTime) / 1000);
    this.lastTime = now;
    this.handleInput(dt);
    this.ai.update(this.entities, dt, this.player);
    this.physics.update(this.entities, dt);
    requestAnimationFrame(t => this.loop(t));
  }
  handleInput(dt) {
    if (!this.player) return;
    const speed = 150 * dt;
    const rotSpeed = 3 * dt;
    if (this.mode === 'doom') {
      if (this.input.isDown('w')) {
        this.player.x += Math.cos(this.player.angle) * speed;
        this.player.y += Math.sin(this.player.angle) * speed;
      }
      if (this.input.isDown('s')) {
        this.player.x -= Math.cos(this.player.angle) * speed;
        this.player.y -= Math.sin(this.player.angle) * speed;
      }
      if (this.input.isDown('a')) this.player.angle -= rotSpeed;
      if (this.input.isDown('d')) this.player.angle += rotSpeed;
      if (this.map) {
        const mx = Math.floor(this.player.x / 40);
        const my = Math.floor(this.player.y / 40);
        if (my>=0 && my<this.map.length && mx>=0 && mx<this.map[0].length && this.map[my][mx]===1) {
          this.player.x -= Math.cos(this.player.angle) * speed;
          this.player.y -= Math.sin(this.player.angle) * speed;
        }
      }
    } else {
      if (this.input.isDown('w')||this.input.isDown('arrowup')) this.player.vy = -speed;
      else if (this.input.isDown('s')||this.input.isDown('arrowdown')) this.player.vy = speed;
      else this.player.vy *= 0.8;
      if (this.input.isDown('a')||this.input.isDown('arrowleft')) this.player.vx = -speed;
      else if (this.input.isDown('d')||this.input.isDown('arrowright')) this.player.vx = speed;
      else this.player.vx *= 0.8;
    }
    if (this.input.isDown(' ')) this.audio.beep(880, 0.05);
  }
}

/* ---------- MAIN APP ---------- */
class Studio {
  constructor() {
    this.logger = new Logger(document.getElementById('console-panel'));
    this.parser = new CodeParser();
    this.imgGen = new ImageGenerator();
    this.imgDec = new ImageDecoder();
    this.engine = new GameEngine(this.logger);
    this.sceneRenderer = new Renderer(document.getElementById('scene-canvas'));
    this.gameRenderer = new Renderer(document.getElementById('game-canvas'));
    this.tutorial = new Tutorial();
    
    this.currentAST = null;
    this.compiledImage = null;
    this.selectedEntity = null;
    
    this.setupUI();
    this.logger.log('PixelVM Studio initialized', 'info');
    this.logger.log('Write code → Compile → Play', 'info');
    this.logger.status('Ready');
    
    // Auto-start tutorial on first visit
    setTimeout(() => {
      if (!localStorage.getItem('pixelvm_tutorial_done')) {
        this.tutorial.start();
      }
    }, 500);
  }
  
  setupUI() {
    document.getElementById('btn-compile').onclick = () => this.compile();
    document.getElementById('btn-play').onclick = () => this.play();
    document.getElementById('btn-pause').onclick = () => this.pause();
    document.getElementById('btn-stop').onclick = () => this.stop();
    document.getElementById('btn-load').onclick = () => this.loadPNG();
    document.getElementById('btn-save').onclick = () => this.savePNG();
    document.getElementById('btn-help').onclick = () => document.getElementById('help-modal').style.display = 'flex';
    document.getElementById('btn-add-entity').onclick = () => this.addEntityTemplate();
    document.getElementById('btn-template').onclick = () => this.loadTemplate();
    
    document.querySelectorAll('.view-tab').forEach(tab => {
      tab.onclick = () => {
        document.querySelectorAll('.view-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.view-pane').forEach(p => p.classList.remove('active'));
        tab.classList.add('active');
        document.getElementById(`${tab.dataset.view}-pane`).classList.add('active');
      };
    });
    
    document.querySelectorAll('.bottom-tab').forEach(tab => {
      tab.onclick = () => {
        document.querySelectorAll('.bottom-tab').forEach(t => t.classList.remove('active'));
        document.querySelectorAll('.bottom-pane').forEach(p => p.style.display = 'none');
        tab.classList.add('active');
        document.getElementById(`${tab.dataset.panel}-panel`).style.display = 'block';
      };
    });
    
    this.renderLoop();
  }
  
  compile() {
    try {
      this.logger.clear();
      this.logger.log('Compiling code...', 'compile');
      const code = document.getElementById('code-editor').value;
      const ast = this.parser.parse(code);
      this.logger.log(`Parsed: ${ast.entities.length} entities, mode=${ast.mode}`, 'compile');
      if (ast.map) this.logger.log(`Map: ${ast.map.length}x${ast.map[0].length}`, 'compile');
      const img = this.imgGen.generate(ast);
      this.compiledImage = img;
      const sceneCanvas = document.getElementById('scene-canvas');
      sceneCanvas.width = img.width;
      sceneCanvas.height = img.height;
      const sctx = sceneCanvas.getContext('2d');
      sctx.imageSmoothingEnabled = false;
      sctx.drawImage(img, 0, 0);
      const scale = Math.min(512 / img.width, 512 / img.height, 8);
      sceneCanvas.style.width = (img.width * scale) + 'px';
      sceneCanvas.style.height = (img.height * scale) + 'px';
      this.currentAST = ast;
      this.updateHierarchy();
      this.logger.log(`✓ Compiled to ${img.width}×${img.height} image`, 'exec');
      this.logger.status(`Compiled: ${img.width}×${img.height} PNG`);
    } catch (err) {
      this.logger.log(`✗ Compile error: ${err.message}`, 'error');
      this.logger.status('Compile failed');
    }
  }
  
  play() {
    if (!this.currentAST) {
      this.compile();
      if (!this.currentAST) return;
    }
    this.engine.loadAST(this.currentAST);
    this.engine.start();
    document.querySelectorAll('.view-tab').forEach(t => t.classList.remove('active'));
    document.querySelectorAll('.view-pane').forEach(p => p.classList.remove('active'));
    document.querySelector('[data-view="game"]').classList.add('active');
    document.getElementById('game-pane').classList.add('active');
    document.getElementById('btn-play').classList.add('active');
    this.logger.log('▶ Playing', 'info');
    this.logger.status('Running');
  }
  
  pause() {
    this.engine.running = !this.engine.running;
    if (this.engine.running) {
      this.engine.lastTime = performance.now();
      requestAnimationFrame(t => this.engine.loop(t));
      this.logger.log('▶ Resumed', 'info');
    } else {
      this.logger.log('⏸ Paused', 'info');
    }
  }
  
  stop() {
    this.engine.stop();
    this.gameRenderer.clear();
    document.getElementById('btn-play').classList.remove('active');
    this.logger.status('Stopped');
  }
  
  updateHierarchy() {
    const list = document.getElementById('hierarchy-list');
    list.innerHTML = '';
    if (!this.currentAST) return;
    this.currentAST.entities.forEach((ent, i) => {
      const item = document.createElement('div');
      item.className = 'tree-item';
      item.innerHTML = `<span class="tree-icon">◆</span> ${ent.name} <span style="color:#666;font-size:10px">(${ent.shape})</span>`;
      item.onclick = () => {
        document.querySelectorAll('.tree-item').forEach(t => t.classList.remove('selected'));
        item.classList.add('selected');
        this.selectEntity(ent);
      };
      list.appendChild(item);
    });
    if (this.currentAST.map) {
      const item = document.createElement('div');
      item.className = 'tree-item';
      item.innerHTML = `<span class="tree-icon">▦</span> Map <span style="color:#666;font-size:10px">(${this.currentAST.map.length}×${this.currentAST.map[0].length})</span>`;
      list.appendChild(item);
    }
  }
  
  selectEntity(ent) {
    this.selectedEntity = ent;
    const body = document.getElementById('inspector-body');
    body.innerHTML = `
      <div class="inspector-section">
        <div class="inspector-title">Transform</div>
        <div class="inspector-row">
          <span class="inspector-label">Name</span>
          <input class="inspector-input" value="${ent.name}" data-prop="name">
        </div>
        <div class="inspector-row">
          <span class="inspector-label">Position</span>
          <input class="inspector-input" value="${ent.pos[0]}, ${ent.pos[1]}" data-prop="pos">
        </div>
      </div>
      <div class="inspector-section">
        <div class="inspector-title">Visual</div>
        <div class="inspector-row">
          <span class="inspector-label">Shape</span>
          <select class="inspector-select" data-prop="shape">
            ${SHAPE_LIST.map(s => `<option ${s===ent.shape?'selected':''}>${s}</option>`).join('')}
          </select>
        </div>
        <div class="inspector-row">
          <span class="inspector-label">Color</span>
          <input type="color" class="color-preview" value="${ent.color}" data-prop="color">
          <input class="inspector-input" value="${ent.color}" data-prop="color-text">
        </div>
        <div class="inspector-row">
          <span class="inspector-label">Scale</span>
          <input class="inspector-input" type="number" step="0.1" value="${ent.scale}" data-prop="scale">
        </div>
      </div>
      <div class="inspector-section">
        <div class="inspector-title">Behavior</div>
        <div class="inspector-row">
          <span class="inspector-label">AI</span>
          <select class="inspector-select" data-prop="ai">
            ${['idle','wander','chase','flee'].map(a => `<option ${a===ent.ai?'selected':''}>${a}</option>`).join('')}
          </select>
        </div>
        <div class="inspector-row">
          <span class="inspector-label">HP</span>
          <input class="inspector-input" type="number" value="${ent.hp}" data-prop="hp">
        </div>
        <div class="inspector-row">
          <span class="inspector-label">Layer</span>
          <input class="inspector-input" type="number" value="${ent.layer}" data-prop="layer">
        </div>
      </div>
    `;
    body.querySelectorAll('[data-prop]').forEach(input => {
      input.onchange = () => this.updateEntityProp(input.dataset.prop, input.value);
    });
  }
  
  updateEntityProp(prop, value) {
    if (!this.selectedEntity) return;
    const ent = this.selectedEntity;
    switch(prop) {
      case 'name': ent.name = value; break;
      case 'pos':
        const m = value.match(/([^,]+),\s*([^)]+)/);
        if (m) ent.pos = [parseFloat(m[1]), parseFloat(m[2])];
        break;
      case 'shape': ent.shape = value; break;
      case 'color':
      case 'color-text':
        ent.color = value;
        break;
      case 'scale': ent.scale = parseFloat(value); break;
      case 'ai': ent.ai = value; break;
      case 'hp': ent.hp = parseFloat(value); break;
      case 'layer': ent.layer = parseInt(value); break;
    }
    this.syncCodeFromAST();
  }
  
  syncCodeFromAST() {
    if (!this.currentAST) return;
    let code = `mode: ${this.currentAST.mode}\n\n`;
    for (const ent of this.currentAST.entities) {
      code += `entity ${ent.name} {\n`;
      code += `  shape: ${ent.shape}\n`;
      code += `  color: ${ent.color}\n`;
      code += `  pos: (${ent.pos[0]}, ${ent.pos[1]})\n`;
      code += `  ai: ${ent.ai}\n`;
      code += `  hp: ${ent.hp}\n`;
      code += `  layer: ${ent.layer}\n`;
      code += `  scale: ${ent.scale}\n`;
      code += `}\n\n`;
    }
    if (this.currentAST.map) {
      code += `map {\n`;
      for (const row of this.currentAST.map) code += `  ${row.join('')}\n`;
      code += `}\n`;
    }
    document.getElementById('code-editor').value = code;
  }
  
  addEntityTemplate() {
    const ta = document.getElementById('code-editor');
    ta.value += `\nentity NewEntity {\n  shape: circle\n  color: #ffffff\n  pos: (200, 200)\n  ai: idle\n  hp: 100\n}\n`;
    this.logger.log('Added entity template', 'info');
  }
  
  loadTemplate() {
    const templates = [
      `// Simple 2D scene
mode: 2d

entity P {
  shape: triangle
  color: #4ecdc4
  pos: (320, 200)
  ai: idle
}

entity E1 {
  shape: star
  color: #ff6b6b
  pos: (100, 100)
  ai: wander
}

entity E2 {
  shape: hexagon
  color: #ffd93d
  pos: (500, 300)
  ai: chase
}`,
      `// DOOM-style FPS
mode: doom

entity P {
  shape: triangle
  color: #4ecdc4
  pos: (150, 150)
  ai: idle
  hp: 100
}

entity E1 {
  shape: star
  color: #ff6b6b
  pos: (300, 100)
  ai: chase
}

entity E2 {
  shape: hexagon
  color: #ffd93d
  pos: (400, 300)
  ai: chase
}

map {
  1111111111
  1000000001
  1010001001
  1000000001
  1001110001
  1000000001
  1010001001
  1000000001
  1000100001
  1111111111
}`
    ];
    document.getElementById('code-editor').value = templates[Math.floor(Math.random()*templates.length)];
    this.logger.log('Template loaded', 'info');
  }
  
  async loadPNG() {
    const input = document.createElement('input');
    input.type = 'file';
    input.accept = '.png';
    input.onchange = async (e) => {
      const file = e.target.files[0];
      if (!file) return;
      const img = new Image();
      img.onload = () => {
        const sceneCanvas = document.getElementById('scene-canvas');
        sceneCanvas.width = img.width;
        sceneCanvas.height = img.height;
        const sctx = sceneCanvas.getContext('2d');
        sctx.drawImage(img, 0, 0);
        const tmp = document.createElement('canvas');
        tmp.width = img.width; tmp.height = img.height;
        tmp.getContext('2d').drawImage(img, 0, 0);
        const decoded = this.imgDec.decode(tmp);
        this.currentAST = decoded;
        this.updateHierarchy();
        this.logger.log(`Loaded PNG: ${img.width}×${img.height}, ${decoded.entities.length} entities`, 'info');
        this.logger.status(`Loaded: ${file.name}`);
      };
      img.src = URL.createObjectURL(file);
    };
    input.click();
  }
  
  savePNG() {
    if (!this.compiledImage) {
      this.logger.log('No compiled image to save. Compile first!', 'warn');
      return;
    }
    const link = document.createElement('a');
    link.download = 'pixelvm-program.png';
    link.href = this.compiledImage.toDataURL();
    link.click();
    this.logger.log('PNG saved', 'info');
  }
  
  renderLoop() {
    const loop = () => {
      if (this.engine.running) {
        if (this.engine.mode === 'doom') {
          this.gameRenderer.renderRaycast(this.engine.entities, this.engine.player, this.engine.map);
        } else {
          this.gameRenderer.render2D(this.engine.entities);
        }
      }
      requestAnimationFrame(loop);
    };
    loop();
  }
}

window.addEventListener('DOMContentLoaded', () => {
  window.studio = new Studio();
});
</script>

.play-btn:hover{background:#4d4d4d;color:#fff}
.play-btn.active{background:#4ecdc4;color:#000}
.top-sep{width:1px;height:24px;background:#1a1a1a;margin:0 4px}
.scene-select{background:#2d2d2d;border:1px solid #1a1a1a;color:#ccc;padding:4px 8px;border-radius:3px;font-size:11px;cursor:pointer}
.top-label{color:#888;font-size:11px}
.top-right{margin-left:auto;display:flex;gap:6px;align-items:center}
.top-btn{background:#3c3c3c;border:1px solid #1a1a1a;color:#ccc;padding:4px 10px;border-radius:3px;cursor:pointer;font-size:11px}
.top-btn:hover{background:#4d4d4d}
.top-btn.primary{background:#4ecdc4;color:#000;border-color:#3ab5a3}
.top-btn.primary:hover{background:#5fded5}

/* MAIN 4-PANEL */
#main{display:flex;flex:1;overflow:hidden}

/* Left */
#left-col{width:280px;display:flex;flex-direction:column;background:#2d2d2d;border-right:1px solid #1a1a1a}
.panel{display:flex;flex-direction:column;flex:1;min-height:0}
.panel-header{background:#3c3c3c;padding:5px 10px;font-size:11px;font-weight:bold;color:#aaa;border-bottom:1px solid #1a1a1a;display:flex;justify-content:space-between;align-items:center;text-transform:uppercase;letter-spacing:0.5px}
.panel-header .btn-sm{background:transparent;border:none;color:#888;cursor:pointer;font-size:12px;padding:2px 4px}
.panel-header .btn-sm:hover{color:#fff}
.panel-body{flex:1;overflow:auto;background:#252525}

.tree-item{padding:4px 10px;cursor:pointer;display:flex;align-items:center;gap:6px;border-bottom:1px solid #1f1f1f;font-size:11px}
.tree-item:hover{background:#333}
.tree-item.selected{background:#4ecdc4;color:#000}
.tree-icon{font-size:12px}

#code-editor{flex:1;background:#1e1e1e;color:#d4d4d4;border:none;padding:10px;font-family:'Consolas',monospace;font-size:12px;line-height:1.5;resize:none;outline:none;tab-size:2;user-select:text}

/* Center */
#center-col{flex:1;display:flex;flex-direction:column;background:#1e1e1e;min-width:0}
#view-tabs{display:flex;background:#3c3c3c;border-bottom:1px solid #1a1a1a}
.view-tab{padding:6px 16px;cursor:pointer;color:#888;font-size:11px;border-right:1px solid #1a1a1a;text-transform:uppercase;letter-spacing:0.5px}
.view-tab:hover{color:#ccc;background:#444}
.view-tab.active{background:#252525;color:#4ecdc4;border-bottom:2px solid #4ecdc4}
#view-content{flex:1;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;background:#1a1a1a}
.view-pane{position:absolute;inset:0;display:none;align-items:center;justify-content:center}
.view-pane.active{display:flex}
#scene-canvas, #game-canvas{image-rendering:pixelated;background:#000;max-width:100%;max-height:100%;border:1px solid #333}
#scene-info{position:absolute;top:10px;left:10px;background:rgba(0,0,0,0.7);padding:6px 10px;border-radius:4px;font-size:10px;color:#4ecdc4;font-family:monospace}

/* Right */
#right-col{width:280px;display:flex;flex-direction:column;background:#2d2d2d;border-left:1px solid #1a1a1a}

.bottom-tab:hover{color:#ccc}
.bottom-tab.active{color:#4ecdc4;background:#252525}
#bottom-content{flex:1;overflow:auto;background:#1e1e1e;padding:6px 10px;font-family:'Consolas',monospace;font-size:11px}

  pointer-events:auto;
  z-index:2002;
  animation:tutorialFadeIn 0.3s ease;
}

@keyframes tutorialFadeIn {
  from { opacity:0; transform:translateY(10px); }
  to { opacity:1; transform:translateY(0); }
}

#tutorial-progress{
  display:flex;
  align-items:center;
  gap:8px;
  margin-bottom:10px;
}
#tutorial-progress-bar{
  flex:1;

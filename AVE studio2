// ==========================================
// 📝 Lexer
// ==========================================
class LexerError extends Error { constructor(m,l,c){super(m);this.line=l;this.col=c;} }

function tokenize(code, cfg) {
  const tokens=[]; let i=0, line=1, col=1;
  while(i<code.length) {
    const sl=line, sc=col;
    if(code[i]===' '||code[i]==='\t'){tokens.push({type:'t-ws',value:code[i],line:sl,col:sc});col++;i++;continue;}
    if(code[i]==='\n'){tokens.push({type:'t-ws',value:'\n',line:sl,col:sc});line++;col=1;i++;continue;}
    if(code[i]==='\r'){i++;continue;}

    if(cfg.comment && code.startsWith(cfg.comment,i)){
      let end=code.indexOf('\n',i); if(end===-1)end=code.length;
      tokens.push({type:'t-cmt',value:code.slice(i,end),line:sl,col:sc});
      col+=(end-i); i=end; continue;
    }

    if(code[i]===cfg.quote){
      let j=i+1, val=cfg.quote;
      while(j<code.length&&code[j]!==cfg.quote){
        if(code[j]==='\\'&&j+1<code.length){val+=code[j]+code[j+1];j+=2;}
        else{val+=code[j];j++;}
      }
      if(j>=code.length) throw new LexerError('닫히지 않은 문자열',sl,sc);
      val+=cfg.quote;
      tokens.push({type:'t-str',value:val,line:sl,col:sc});
      col+=(j-i+1); i=j+1; continue;
    }

    if(/[0-9]/.test(code[i])){
      let j=i;
      if(code[i]==='0'&&/[xb]/.test(code[i+1])){j+=2;while(j<code.length&&/[0-9a-fA-F]/.test(code[j]))j++;}
      else{while(j<code.length&&/[0-9.]/.test(code[j]))j++;
        if((code.slice(i,j).match(/\./g)||[]).length>1) throw new LexerError(`잘못된 숫자: '${code.slice(i,j)}'`,sl,sc);
      }
      tokens.push({type:'t-num',value:code.slice(i,j),line:sl,col:sc});
      col+=(j-i);i=j;continue;
    }

    let om=false;
    for(let op of cfg.operators){if(code.startsWith(op,i)){tokens.push({type:'t-op',value:op,line:sl,col:sc});col+=op.length;i+=op.length;om=true;break;}}
    if(om)continue;

    if('{ } ( ) [ ] , ;'.split(' ').includes(code[i])){tokens.push({type:'t-brk',value:code[i],line:sl,col:sc});col++;i++;continue;}

    if(/[a-zA-Z_가-힣]/.test(code[i])){
      let j=i;while(j<code.length&&/[a-zA-Z0-9_가-힣]/.test(code[j]))j++;
      const w=code.slice(i,j);
      let tp='t-id';
      if(cfg.keywords.includes(w))tp='t-kw';
      else if(cfg.types.includes(w))tp='t-type';
      tokens.push({type:tp,value:w,line:sl,col:sc});
      col+=(j-i);i=j;continue;
    }

    tokens.push({type:'t-unknown',value:code[i],line:sl,col:sc});col++;i++;
  }
  return tokens;
}

// ==========================================
// 🎨 하이라이팅 & 줄 번호 & 🆕 통계
// ==========================================
let lastStats = { lines:0, chars:0, tokens:0, words:0 };

function updateHighlight() {
  const code=$('codeEditor').value, cfg=getConfig();
  try {
    const tokens=tokenize(code,cfg);
    let html='';
    tokens.forEach(t=>{
      let v=t.value.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      html+= t.type==='t-ws' ? v : `<span class="${t.type}">${v}</span>`;
    });
    $('highlightLayer').innerHTML=html;
    
    // 🆕 통계 업데이트
    const meaningfulTokens = tokens.filter(t=>t.type!=='t-ws');
    lastStats = {
      lines: code.split('\n').length,
      chars: code.length,
      tokens: meaningfulTokens.length,
      words: code.trim() ? code.trim().split(/\s+/).length : 0
    };
    $('statSummary').textContent = `${lastStats.lines} L / ${lastStats.tokens} T`;
    $('statLines').textContent = lastStats.lines;
    $('statChars').textContent = lastStats.chars;
    $('statTokens').textContent = lastStats.tokens;
    $('statWords').textContent = lastStats.words;
    
    $('statusDot').className='status-dot ok';
    $('statusError').style.display='none';
  } catch(e) {
    $('statusDot').className='status-dot err';
    $('statusError').style.display='';
    $('statusError').textContent=`오류: L${e.line}:${e.col}`;
  }
  updateLineNumbers();
}

function updateLineNumbers() {
  const code=$('codeEditor').value;
  const count=code.split('\n').length;
  let html='';
  for(let i=1;i<=count;i++) html+=i+'\n';
  $('lineNumbers').textContent=html;
}

// 🆕 통계 툴팁 토글
function toggleStats() {
  $('statsTooltip').classList.toggle('show');
}

let hlTimer=null;
function onEditorInput(){
  clearTimeout(hlTimer);
  hlTimer=setTimeout(updateHighlight,80);
  updateCursorPos();
}

function syncScroll(){
  const e=$('codeEditor');
  $('highlightLayer').scrollTop=e.scrollTop;
  $('highlightLayer').scrollLeft=e.scrollLeft;
  $('lineNumbers').style.transform=`translateY(${-e.scrollTop}px)`;

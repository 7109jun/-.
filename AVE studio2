  reader.readAsText(file); input.value = '';
}

function openDownloadModal() { $('downloadModal').classList.add('show'); }
function closeDownloadModal() { $('downloadModal').classList.remove('show'); }
function selectExt(ext, el) {
  dlExt = ext;
  document.querySelectorAll('.download-option').forEach(e=>e.classList.remove('selected'));
  el.classList.add('selected');
}
async function doDownload() {
  const code = $('codeEditor').value;
  const fileName = 'main' + dlExt;
  if('showSaveFilePicker' in window) {
    try {
      const handle = await window.showSaveFilePicker({
        suggestedName: fileName,
        types: [{description:'AVE Source', accept:{'text/plain':[dlExt]}}]
      });
      const w = await handle.createWritable();
      await w.write(code); await w.close();
      sfx('ok'); closeDownloadModal();
    } catch(err) {
      if(err.name !== 'AbortError') fallbackDL(code, fileName);
    }
  } else fallbackDL(code, fileName);
}
function fallbackDL(code, fileName) {
  const blob = new Blob([code], {type:'text/plain;charset=utf-8'});
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = fileName;
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
  sfx('ok'); closeDownloadModal();
}

// ==========================================
// ✨ VS Code 확장 생성
// ==========================================
function openGenerateModal() {
  const cfg = getConfig();
  const keywordRegex = cfg.keywords.join('|');
  const operatorRegex = cfg.operators.map(op=>op.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')).join('|');
  const tmLanguage = {
    "$schema":"https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name":cfg.name, "scopeName":`source.${cfg.name.toLowerCase()}`,
    "patterns":[
      {"include":"#comments"},{"include":"#strings"},{"include":"#keywords"},{"include":"#operators"},{"include":"#numbers"}
    ],
    "repository":{
      "comments":{"patterns":[{"name":"comment.line.ave","match":`${cfg.comment.replace(/[.*+?^${}()|[\]\\]/g,'\\$&')}.*$`}]},
      "strings":{"name":"string.quoted.ave","match":`${cfg.quote}(\\\\.|[^${cfg.quote}\\\\])*${cfg.quote}`},
      "keywords":{"name":"keyword.control.ave","match":`\\b(${keywordRegex})\\b`},
      "operators":{"name":"keyword.operator.ave","match":`(${operatorRegex})`},
      "numbers":{"name":"constant.numeric.ave","match":"\\b(0[xX][0-9a-fA-F]+|0[bB][01]+|[0-9]+(\\.[0-9]+)?)\\b"}
    }
  };
  const pkg = {
    "name":`${cfg.name.toLowerCase()}-syntax`,
    "displayName":`${cfg.name} Language`,
    "version":cfg.version, "publisher":cfg.author,
    "engines":{"vscode":"^1.75.0"},
    "contributes":{
      "languages":[{"id":cfg.name.toLowerCase(),"aliases":[cfg.name],"extensions":[cfg.ext]}],
      "grammars":[{"language":cfg.name.toLowerCase(),"scopeName":`source.${cfg.name.toLowerCase()}`,"path":"./syntaxes/ave.tmLanguage.json"}]
    }
  };
  $('modalBody').innerHTML = `
    <div style="color:var(--green);margin-bottom:10px;">🎉 아래 파일을 저장하고 <code>npm install && vsce package</code> 실행</div>
    <div class="code-block">
      <button class="btn btn-small btn-primary copy-btn" onclick="copyCode(this)">복사</button>
      <h4 style="color:var(--blue);margin-bottom:8px;">1. package.json</h4>
      <pre>${JSON.stringify(pkg,null,2)}</pre>
    </div>
    <div class="code-block">
      <button class="btn btn-small btn-primary copy-btn" onclick="copyCode(this)">복사</button>
      <h4 style="color:var(--blue);margin-bottom:8px;">2. syntaxes/ave.tmLanguage.json</h4>
      <pre>${JSON.stringify(tmLanguage,null,2)}</pre>
    </div>
  `;
  $('generateModal').classList.add('show');
}
function closeGenModal() { $('generateModal').classList.remove('show'); }
function copyCode(btn) {
  const code = btn.nextElementSibling.nextElementSibling.textContent;
  navigator.clipboard.writeText(code).then(()=>{
    const orig = btn.textContent; btn.textContent = '복사됨!'; btn.style.background = 'var(--green)';
    setTimeout(()=>{btn.textContent = orig; btn.style.background = '';},1500);
  });
}


// ==========================================
// 🎹 에디터 키보드 기능
// ==========================================
const editor = $('codeEditor');
editor.addEventListener('input', onEditorInput);
editor.addEventListener('scroll', syncScroll);
editor.addEventListener('click', updateCursorPos);
editor.addEventListener('keyup', updateCursorPos);

// 🆕 전역 단축키
document.addEventListener('keydown', function(e) {
  // Ctrl+Enter: 실행
  if(e.ctrlKey && e.key==='Enter'){ e.preventDefault(); runCode(); return; }
  // Ctrl+/: 단축키 모달
  if(e.ctrlKey && e.key==='/'){ e.preventDefault(); showShortcuts(); return; }
  // Shift+Alt+F: 포맷
  if(e.shiftKey && e.altKey && (e.key==='F'||e.key==='f')){ e.preventDefault(); autoFormat(); return; }
  // Ctrl+S: 저장
  if(e.ctrlKey && e.key==='s'){ e.preventDefault(); saveProject(); return; }
});

editor.addEventListener('keydown', function(e) {
  const ta=this;
  // Tab: 들여쓰기
  if(e.key==='Tab'){
    e.preventDefault();
    const s=ta.selectionStart, end=ta.selectionEnd;
    ta.value=ta.value.substring(0,s)+'  '+ta.value.substring(end);
    ta.selectionStart=ta.selectionEnd=s+2;
    onEditorInput(); return;
  }
  // 자동 괄호
  const pairs={'{':'}','[':']','(':')'};
  if(pairs[e.key]){
    e.preventDefault();
    const s=ta.selectionStart, end=ta.selectionEnd;
    const sel=ta.value.substring(s,end);
    ta.value=ta.value.substring(0,s)+e.key+sel+pairs[e.key]+ta.value.substring(end);
    ta.selectionStart=s+1; ta.selectionEnd=s+1+sel.length;
    onEditorInput(); return;
  }
  // 자동 따옴표
  const cfg=getConfig();
  if(e.key===cfg.quote){
    const s=ta.selectionStart, end=ta.selectionEnd;
    if(s!==end){
      e.preventDefault();
      const sel=ta.value.substring(s,end);
      ta.value=ta.value.substring(0,s)+cfg.quote+sel+cfg.quote+ta.value.substring(end);
      ta.selectionStart=s+1; ta.selectionEnd=s+1+sel.length;
      onEditorInput();
    }
  }
  // Enter: 자동 들여쓰기
  if(e.key==='Enter'){
    const s=ta.selectionStart;
    const lineStart=ta.value.lastIndexOf('\n',s-1)+1;
    const line=ta.value.substring(lineStart,s);
    const indent=line.match(/^(\s*)/)[1];
    const lastChar=ta.value[s-1];
    if(lastChar==='{'){
      e.preventDefault();
      const insert='\n'+indent+'  \n'+indent;
      ta.value=ta.value.substring(0,s)+insert+ta.value.substring(s);
      ta.selectionStart=ta.selectionEnd=s+indent.length+3;
      onEditorInput();
    } else if(indent){
      e.preventDefault();
      const insert='\n'+indent;
      ta.value=ta.value.substring(0,s)+insert+ta.value.substring(s);
      ta.selectionStart=ta.selectionEnd=s+insert.length;
      onEditorInput();
    }
  }
});

// ==========================================
// 🔍 Parser
// ==========================================
class ParseError extends Error { constructor(m,l,c){super(m);this.line=l;this.col=c;} }
class Parser {
  constructor(tokens,cfg){
    this.t=tokens.filter(t=>t.type!=='t-ws');
    this.cfg=cfg; this.pos=0;
    this.kw={
      print:cfg.keywords[0],if:cfg.keywords[1],else:cfg.keywords[2],
      while:cfg.keywords[3],func:cfg.keywords[4],return:cfg.keywords[5],
      let:cfg.keywords[6],for:cfg.keywords[7],break:cfg.keywords[8],continue:cfg.keywords[9]
    };
  }
  peek(o=0){return this.t[this.pos+o];}
  eat(){return this.t[this.pos++];}
  expect(tp,v){
    const t=this.peek();
    if(!t||t.type!==tp||(v&&t.value!==v))
      throw new ParseError(`예상: ${tp} ${v||''}, 실제: ${t?t.value:'EOF'}`,t?t.line:'?',t?t.col:'?');
    return this.eat();
  }
  parseProgram(){let b=[];while(this.pos<this.t.length)b.push(this.parseStmt());return{type:'Program',body:b};}
  parseStmt(){
    const t=this.peek(); if(!t)return null;
    if(t.type==='t-kw'&&t.value===this.kw.let){this.eat();const n=this.expect('t-id').value;this.expect('t-op','=');return{type:'VarDecl',name:n,value:this.parseExpr(),line:t.line};}
    if(t.type==='t-kw'&&t.value===this.kw.print){this.eat();return{type:'Print',expr:this.parseExpr(),line:t.line};}
    if(t.type==='t-kw'&&t.value===this.kw.if){
      this.eat();const cond=this.parseExpr();this.expect('t-brk','{');const con=this.parseBlock();
      let alt=null;
      if(this.peek()?.type==='t-kw'&&this.peek().value===this.kw.else){
        this.eat();
        if(this.peek()?.type==='t-kw'&&this.peek().value===this.kw.if) alt=[this.parseStmt()];
        else{this.expect('t-brk','{');alt=this.parseBlock();}
      }
      return{type:'If',cond,consequent:con,alternate:alt,line:t.line};
    }
    if(t.type==='t-kw'&&t.value===this.kw.while){this.eat();const c=this.parseExpr();this.expect('t-brk','{');return{type:'While',cond:c,body:this.parseBlock(),line:t.line};}
    if(t.type==='t-kw'&&t.value===this.kw.for){
      this.eat();this.expect('t-brk','(');
      let init=null;
      if(this.peek().value!==';'){
        if(this.peek().type==='t-kw'&&this.peek().value===this.kw.let){this.eat();const n=this.expect('t-id').value;this.expect('t-op','=');init={type:'VarDecl',name:n,value:this.parseExpr()};}
        else init=this.parseExpr();
      }
      this.expect('t-brk',';');
      let cond=this.peek().value!==';'?this.parseExpr():null;
      this.expect('t-brk',';');
      let upd=this.peek().value!==')'?this.parseExpr():null;
      this.expect('t-brk',')');this.expect('t-brk','{');
      return{type:'For',init,cond,update:upd,body:this.parseBlock(),line:t.line};
    }
    if(t.type==='t-kw'&&t.value===this.kw.func){
      this.eat();const n=this.expect('t-id').value;this.expect('t-brk','(');
      const p=[];if(this.peek().value!==')'){p.push(this.expect('t-id').value);while(this.peek()?.value===','){this.eat();p.push(this.expect('t-id').value);}}
      this.expect('t-brk',')');this.expect('t-brk','{');
      return{type:'FuncDecl',name:n,params:p,body:this.parseBlock(),line:t.line};
    }
    if(t.type==='t-kw'&&t.value===this.kw.return){this.eat();let v=null;if(this.peek()&&this.peek().value!=='}'&&this.peek().value!==';')v=this.parseExpr();return{type:'Return',value:v,line:t.line};}
    if(t.type==='t-kw'&&t.value===this.kw.break){this.eat();return{type:'Break',line:t.line};}
    if(t.type==='t-kw'&&t.value===this.kw.continue){this.eat();return{type:'Continue',line:t.line};}
    return this.parseExprStmt();
  }
  parseBlock(){const s=[];while(this.peek()&&this.peek().value!=='}')s.push(this.parseStmt());this.expect('t-brk','}');return s;}
  parseExprStmt(){
    const e=this.parseExpr();
    if(e.type==='Identifier'&&this.peek()?.type==='t-op'&&this.peek().value==='='){this.eat();return{type:'Assign',name:e.name,value:this.parseExpr(),line:e.line};}
    if(e.type==='ArrAcc'&&this.peek()?.type==='t-op'&&this.peek().value==='='){this.eat();return{type:'ArrAssign',arr:e.arr,idx:e.idx,value:this.parseExpr(),line:e.line};}
    return{type:'ExprStmt',expr:e,line:e.line};
  }
  prec(op){return{'||':1,'&&':2,'==':3,'!=':3,'>':4,'<':4,'>=':4,'<=':4,'+':5,'-':5,'*':6,'/':6,'%':6}[op]||0;}
  parseExpr(){return this.parseBin(0);}
  parseBin(min){
    let l=this.parseUnary();
    while(this.peek()?.type==='t-op'&&this.prec(this.peek().value)>=min){
      const op=this.eat().value; l={type:'BinOp',op,left:l,right:this.parseBin(this.prec(op)+1),line:l.line};
    }
    return l;
  }
  parseUnary(){
    const t=this.peek();
    if(t?.type==='t-op'&&(t.value==='!'||t.value==='-')){this.eat();return{type:'Unary',op:t.value,arg:this.parseUnary(),line:t.line};}
    return this.parsePrimary();
  }
  parsePrimary(){
    const t=this.peek();
    if(!t)throw new ParseError('예상치 못한 EOF','?','?');
    if(t.type==='t-num'){this.eat();return{type:'Lit',vt:'Num',value:t.value,line:t.line};}
    if(t.type==='t-str'){
      this.eat();
      const raw=t.value.slice(1,-1);
      const q=this.cfg.quote;
      const p=raw.replace(/\\n/g,'\n').replace(/\\t/g,'\t').replace(/\\r/g,'\r').replace(/\\\\/g,'\\').replace(new RegExp('\\\\'+q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'),'g'),q);
      return{type:'Lit',vt:'Str',value:p,line:t.line};
    }
    if(t.type==='t-id'){
      this.eat();
      if(this.peek()?.value==='('){this.eat();const a=[];if(this.peek().value!==')'){a.push(this.parseExpr());while(this.peek()?.value===','){this.eat();a.push(this.parseExpr());}}this.expect('t-brk',')');return{type:'Call',callee:t.value,args:a,line:t.line};}
      if(this.peek()?.value==='['){this.eat();const idx=this.parseExpr();this.expect('t-brk',']');return{type:'ArrAcc',arr:t.value,idx,line:t.line};}
      return{type:'Identifier',name:t.value,line:t.line};
    }
    if(t.value==='('){this.eat();const e=this.parseExpr();this.expect('t-brk',')');return e;}
    if(t.value==='['){this.eat();const el=[];if(this.peek().value!==']'){el.push(this.parseExpr());while(this.peek()?.value===','){this.eat();el.push(this.parseExpr());}}this.expect('t-brk',']');return{type:'ArrLit',elements:el,line:t.line};}
    throw new ParseError(`예상치 못한 토큰: '${t.value}'`,t.line,t.col);
  }
}

// ==========================================
// 🏃 Interpreter
// ==========================================
class RetSig{constructor(v){this.value=v;}}
class BrkSig{}
class CntSig{}
class Env{
  constructor(p=null){this.v={};this.p=p;this.fn={};}
  def(n,val){this.v[n]=val;}
  get(n){if(n in this.v)return this.v[n];if(this.p)return this.p.get(n);throw new Error(`미정의 변수: ${n}`);}
  set(n,val){if(n in this.v){this.v[n]=val;return;}if(this.p){this.p.set(n,val);return;}throw new Error(`미정의 변수: ${n}`);}
  defFn(n,f){this.fn[n]=f;}
  getFn(n){if(n in this.fn)return this.fn[n];if(this.p)return this.p.getFn(n);throw new Error(`미정의 함수: ${n}`);}
}

class Interp {
  constructor(cfg,visit){this.cfg=cfg;this.env=new Env();this.visit=visit;this.iter=0;this.MAX=100000;}
  async run(ast){this.out=[];this.iter=0;for(const n of ast.body)await this.eval(n,this.env);return this.out;}
  chk(){if(++this.iter>this.MAX)throw new Error(`무한루프 감지 (${this.MAX}회)`);}
  async eval(n,e){
    if(!n)return;
    if(this.visit&&n._id)await this.visit(n._id);
    switch(n.type){
      case'VarDecl':e.def(n.name,await this.eval(n.value,e));break;
      case'Assign':e.set(n.name,await this.eval(n.value,e));break;
      case'ArrAssign':{const a=e.get(n.arr);if(!Array.isArray(a))throw new Error(n.arr+'는 배열 아님');a[await this.eval(n.idx,e)]=await this.eval(n.value,e);break;}
      case'Print':this.out.push(String(await this.eval(n.expr,e)));break;
      case'If':if(await this.eval(n.cond,e)){for(const c of n.consequent)await this.eval(c,e);}else if(n.alternate){for(const c of n.alternate)await this.eval(c,e);}break;
      case'While':while(await this.eval(n.cond,e)){this.chk();try{for(const c of n.body)await this.eval(c,e);}catch(x){if(x instanceof BrkSig)break;if(x instanceof CntSig)continue;throw x;}}break;
      case'For':{const fe=new Env(e);if(n.init)await this.eval(n.init,fe);while(!n.cond||await this.eval(n.cond,fe)){this.chk();try{for(const c of n.body)await this.eval(c,fe);}catch(x){if(x instanceof BrkSig)break;if(x instanceof CntSig){if(n.update)await this.eval(n.update,fe);continue;}throw x;}if(n.update)await this.eval(n.update,fe);}break;}
      case'FuncDecl':e.defFn(n.name,n);break;
      case'Return':throw new RetSig(n.value?await this.eval(n.value,e):undefined);
      case'Break':throw new BrkSig();
      case'Continue':throw new CntSig();
      case'ExprStmt':await this.eval(n.expr,e);break;
      case'BinOp':{const l=await this.eval(n.left,e),r=await this.eval(n.right,e),o=n.op;
        if(o==='+')return(typeof l==='string'||typeof r==='string')?String(l)+String(r):l+r;
        if(o==='-')return l-r;if(o==='*')return l*r;if(o==='/')return l/r;if(o==='%')return l%r;
        if(o==='==')return l==r;if(o==='!=')return l!=r;if(o==='>')return l>r;if(o==='<')return l<r;
        if(o==='>=')return l>=r;if(o==='<=')return l<=r;if(o==='&&')return l&&r;if(o==='||')return l||r;break;}
      case'Unary':{const a=await this.eval(n.arg,e);if(n.op==='!')return!a;if(n.op==='-')return-a;break;}
      case'Lit':return n.vt==='Num'?parseFloat(n.value):n.value;
      case'Identifier':return e.get(n.name);
      case'ArrLit':{const a=[];for(const el of n.elements)a.push(await this.eval(el,e));return a;}
      case'ArrAcc':{const a=e.get(n.arr);if(!Array.isArray(a))throw new Error(n.arr+'는 배열 아님');const i=await this.eval(n.idx,e);if(i<0||i>=a.length)throw new Error(`인덱스 초과: ${i}`);return a[i];}
      case'Call':{const fn=e.getFn(n.callee),ne=new Env(e);
        for(let i=0;i<fn.params.length;i++) ne.def(fn.params[i],i<n.args.length?await this.eval(n.args[i],e):undefined);
        try{for(const c of fn.body)await this.eval(c,ne);}catch(x){if(x instanceof RetSig)return x.value;throw x;}return undefined;}
    }
  }
}

// ==========================================
// 🌳 AST 렌더러
// ==========================================
let astC=0;
function renderAST(n,pfx='n'){
  if(!n||typeof n!=='object'||!n.type)return '';
  const id=pfx+'-'+(astC++);
  n._id=id;
  let c=`<span class="ast-type">${n.type}</span>`;
  if(n.name!==undefined)c+=` <span class="ast-key">name:</span> <span class="ast-val">"${n.name}"</span>`;
  if(n.vt)c+=` <span class="ast-key">val:</span> <span class="ast-val">${JSON.stringify(n.value)}</span>`;
  if(n.op)c+=` <span class="ast-key">op:</span> <span class="ast-val">"${n.op}"</span>`;
  if(n.callee)c+=` <span class="ast-key">fn:</span> <span class="ast-val">"${n.callee}"</span>`;
  if(n.line)c+=` <span class="log-line">L${n.line}</span>`;
  let h=`<div id="${id}" class="ast-node">${c}`;
  const rc=(child,s)=>(child&&typeof child==='object'&&child.type)?renderAST(child,id+s):'';
  if(Array.isArray(n.body))n.body.forEach((c,i)=>h+=rc(c,'-b'+i));
  if(Array.isArray(n.consequent)){h+=`<div class="ast-node"><span class="ast-key">consequent</span>`;n.consequent.forEach((c,i)=>h+=rc(c,'-cq'+i));h+=`</div>`;}
  if(Array.isArray(n.alternate)){h+=`<div class="ast-node"><span class="ast-key">alternate</span>`;n.alternate.forEach((c,i)=>h+=rc(c,'-al'+i));h+=`</div>`;}
  h+=rc(n.left,'-l')+rc(n.right,'-r')+rc(n.arg,'-a')+rc(n.expr,'-e')+rc(n.cond,'-cd')+rc(n.init,'-in')+rc(n.update,'-up')+rc(n.idx,'-ix')+rc(n.value,'-v');
  if(n.args){h+=`<div class="ast-node"><span class="ast-key">args</span>`;n.args.forEach((a,i)=>h+=rc(a,'-ag'+i));h+=`</div>`;}
  if(n.elements){h+=`<div class="ast-node"><span class="ast-key">elements</span>`;n.elements.forEach((a,i)=>h+=rc(a,'-el'+i));h+=`</div>`;}
  h+=`</div>`;return h;
}

async function hlNode(id){
  const el=$(id);
  if(el){el.classList.add('hl');sfx('tick');
    el.scrollIntoView({behavior:'smooth',block:'nearest'});
    const spd=parseInt($('speedSlider').value)||50;
    await new Promise(r=>setTimeout(r,spd));
    el.classList.remove('hl');
  }
}

// ==========================================
// ▶ 실행 + 🆕 히스토리
// ==========================================
async function runCode(){
  const out=$('outputBox'), ast=$('astOutput');
  out.innerHTML=''; ast.innerHTML='<span class="log-info">파싱 중...</span>';
  switchTab('output',document.querySelector('[data-tab="output"]'));
  const code=$('codeEditor').value, cfg=getConfig();
  const startTime = performance.now();
  try{
    sfx('start');
    astC=0;
    const tokens=tokenize(code,cfg);
    const parser=new Parser(tokens,cfg);
    const astObj=parser.parseProgram();
    ast.innerHTML=`<div class="ast-root">Program</div>`+renderAST(astObj);
    const interp=new Interp(cfg,async(id)=>await hlNode(id));
    const results=await interp.run(astObj);
    const elapsed = (performance.now()-startTime).toFixed(1);
    out.innerHTML=`<span class="log-success">🚀 실행 완료! (${interp.iter} iterations, ${elapsed}ms)</span>\n<span style="color:#666">-------------------</span>\n`;
    results.forEach(line=>{out.innerHTML+=`<div>${line}</div>`;});
    sfx('ok');
    
    // 🆕 히스토리에 추가
    addHistory({
      code: code.substring(0, 50) + (code.length > 50 ? '...' : ''),
      fullCode: code,
      status: 'ok',
      time: new Date().toLocaleTimeString(),
      result: results.join('\n').substring(0, 100)
    });
  } catch(e) {
    const li=e.line?` (L${e.line}:${e.col})`:'';
    ast.innerHTML=`<span class="log-error">❌ ${e.message}${li}</span>`;
    out.innerHTML=`<span class="log-error">❌ ${e.message}${li}</span>`;
    sfx('err');
    addHistory({
      code: code.substring(0, 50) + (code.length > 50 ? '...' : ''),
      fullCode: code,
      status: 'err',
      time: new Date().toLocaleTimeString(),
      result: e.message
    });
  }
}

// 🆕 히스토리 관리
function addHistory(entry) {
  runHistory.unshift(entry);
  if(runHistory.length > MAX_HISTORY) runHistory.pop();
  renderHistory();
}

function renderHistory() {
  const list = $('historyList');
  if(runHistory.length === 0) {
    list.innerHTML = '<div class="history-empty">아직 실행 기록이 없습니다</div>';
    return;
  }
  list.innerHTML = runHistory.map((h, i) => `
    <div class="history-item" onclick="restoreHistory(${i})" title="${h.result.replace(/"/g,'&quot;')}">
      <span><span class="h-status">${h.status==='ok'?'✅':'❌'}</span> ${h.code.replace(/</g,'&lt;')}</span>
      <span class="h-time">${h.time}</span>
    </div>
  `).join('');
}

function restoreHistory(idx) {
  const h = runHistory[idx];
  if(h && h.fullCode) {
    $('codeEditor').value = h.fullCode;
    onEditorInput();
    sfx('tick');
  }
}

function clearHistory() {
  runHistory = [];
  renderHistory();
}

function clearOutput() {
  $('outputBox').innerHTML = '<span class="log-info">[▶ 실행]을 눌러 결과를 확인하세요.</span>';
  $('astOutput').innerHTML = '<span class="log-info">[▶ 실행]을 눌러 AST를 확인하세요.</span>';
}


function updateCursorPos(){
  const e=$('codeEditor'), v=e.value, pos=e.selectionStart;
  const lines=v.substring(0,pos).split('\n');
  $('cursorLine').textContent=lines.length;
  $('cursorCol').textContent=lines[lines.length-1].length+1;

HTML + CSS + JS로 완전한 게임을 만들 수 있습니다.
~game
제목: 공 튕기기 게임
html:
<div class="game-box">
  <div class="ball"></div>
</div>
css:
.game-box { 
  width: 400px; 
  height: 300px; 
  background: #000; 
  position: relative; 
}
.ball { 
  width: 30px; 
  height: 30px; 
  background: red; 
  border-radius: 50%; 
  position: absolute; 
}
js:
const ball = this.querySelector('.ball');
let x = 0, y = 0, dx = 3, dy = 3;

function animate() {
  x += dx; y += dy;
  if (x > 370 || x < 0) dx = -dx;
  if (y > 270 || y < 0) dy = -dy;
  ball.style.left = x + 'px';
  ball.style.top = y + 'px';
  requestAnimationFrame(animate);
}
animate();
~


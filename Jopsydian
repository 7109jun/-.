css:
.game-area { 
  text-align: center; 
  padding: 50px; 
  background: #f0f0f0; 
}
#clickBtn { 
  font-size: 24px; 
  padding: 20px 40px; 
  cursor: pointer;
  background: #4a9eff;
  color: white;
  border: none;
  border-radius: 8px;
}
#score {
  font-size: 32px;
  font-weight: bold;
  color: #4a9eff;
}
js:
let score = 0;
const btn = this.querySelector('#clickBtn');
const scoreEl = this.querySelector('#score');

btn.addEventListener('click', () => {
  score++;
  scoreEl.textContent = score;
});

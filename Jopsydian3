.jocp-game-container{border:2px solid #333;border-radius:6px;overflow:hidden;background:#000;position:relative}
</style>
</head>
<body>
<div class="toolbar">
<button class="btn btn-save" onclick="downloadJOP()">저장</button>
<button class="btn btn-export" onclick="downloadJPC()">내보내기</button>
</div>
<div class="editor-container">
<textarea id="input" oninput="render()" spellcheck="false">!!!!!! 테스트


  <script>
    const JOCP = (function() {
      'use strict';
      
      let scriptStore = [];
      let metaData = {};

      const REGEX = {
        heading: /^(!{1,6})\s+(.+)$/,
        table: /^#\s/,
        listUnordered: /^(\*{1,6})\s+(.+)$/,
        listOrdered: /^(\d{1,3})\s+(.+)$/,
        checkboxTodo: /^\+\s+(.+)$/,
        checkboxDone: /^@\s+(.+)$/,
        hr: /^-{3,}\s*$/,
        copyBlock: /^~\s*$/,
        metaBlock: /^~meta\s*$/,
        templateQuiz: /^~quiz\s*$/,
        templateGallery: /^~gallery\s*$/,
        templateVideo: /^~video\s*$/,
        templateAudio: /^~audio\s*$/,
        templateGUI: /^~gui\s*$/,
        templateGame: /^~game\s*$/,
        inlineComment: /%%[^%]*%%/g,
        inlineImage: /!\{([^}]+)\}/g,
        inlineHyperlink: /=([^=]+)=\[([^\]]+)\]/g,
        inlineAnchor: /\[([^\]]+)\]\[([^\]]+)\]/g,
        inlineLink: /\[\[([^\]]+)\]\]/g,
        inlineQuote: /&([^&]+)&/g,
        inlineBoldUnder: /`([^`]+)`/g,
        inlineColor: /\?([^?]+)\?<(\d{1,3},\d{1,3},\d{1,3})>/g,
        inlineOpacity: /\^([^^]+)\^(\d{1,3})%/g,
        inlineBold: /\{([^}]+)\}/g,
        inlineItalic: /~([^~]+)~/g,
        inlineDel: /_([^_]+)_/g,
        youtube: /(?:youtube\.com\/(?:shorts\/|[^\/]+\/.+\/|(?:v|e(?:mbed)?)\/|.*[?&]v=)|youtu\.be\/)([a-zA-Z0-9_-]{11})/
      };

      function escapeHtml(text) {
        if (text == null) return '';
        const str = String(text);
        const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
        return str.replace(/[&<>"']/g, m => map[m]);
      }

      function escapeAttr(text) {
        return escapeHtml(text).replace(/\n/g, ' ').replace(/\r/g, '');
      }

      function slugify(text) {
        if (!text) return 'untitled';
        return String(text).replace(/\s+/g, '-').replace(/[^\w\-가-ㄱ-ㅎㅏ-ㅣ]/g, '').toLowerCase() || 'untitled';
      }

      function parseInline(text) {
        if (text == null) return '';
        const tokens = [];
        const store = (html) => {
          const token = `§J${tokens.length}§`;
          tokens.push(html);
          return token;
        };

        let result = String(text);
        result = result.replace(REGEX.inlineComment, '');
        result = result.replace(REGEX.inlineImage, (m, src) => store(`<img src="${escapeAttr(src)}" alt="image" style="max-width:100%;border-radius:4px;" />`));
        result = result.replace(REGEX.inlineHyperlink, (m, label, url) => store(`<a href="${escapeAttr(url)}" target="_blank">${escapeHtml(label)}</a>`));
        result = result.replace(REGEX.inlineAnchor, (m, target, label) => store(`<a href="#${slugify(target)}" class="jocp-anchor">${escapeHtml(label)}</a>`));
        result = result.replace(REGEX.inlineLink, (m, url) => store(`<a href="${escapeAttr(url)}" target="_blank">${escapeHtml(url)}</a>`));
        result = result.replace(REGEX.inlineQuote, (m, content) => store(`<blockquote>${escapeHtml(content)}</blockquote>`));
        result = result.replace(REGEX.inlineBoldUnder, (m, content) => store(`<ins><strong>${escapeHtml(content)}</strong></ins>`));
        result = result.replace(REGEX.inlineColor, (m, content, rgb) => store(`<span style="color:rgb(${rgb})">${escapeHtml(content)}</span>`));
        result = result.replace(REGEX.inlineOpacity, (m, content, percent) => store(`<span style="opacity:${Math.min(100, Math.max(0, parseInt(percent) || 0)) / 100}">${escapeHtml(content)}</span>`));
        result = result.replace(REGEX.inlineBold, (m, content) => store(`<strong>${escapeHtml(content)}</strong>`));
        result = result.replace(REGEX.inlineItalic, (m, content) => store(`<em>${escapeHtml(content)}</em>`));
        result = result.replace(REGEX.inlineDel, (m, content) => store(`<del>${escapeHtml(content)}</del>`));

        return result.replace(/§J(\d+)§/g, (m, idx) => tokens[parseInt(idx)] || '');
      }

      function parseMetaTemplate(lines, startIdx) {
        metaData = {};
        let i = startIdx + 1;
        while (i < lines.length && !REGEX.copyBlock.test(lines[i])) {
          const line = lines[i];
          const colonIdx = line.indexOf(':');
          if (colonIdx !== -1) {
            const key = line.substring(0, colonIdx).trim();
            const value = line.substring(colonIdx + 1).trim();
            if (key) metaData[key] = value;
          }
          i++;
        }
        return { nextIdx: i };
      }

      function renderMetaData() {
        if (Object.keys(metaData).length === 0) return '';
        const title = metaData['제목'] || metaData['title'] || '제목 없음';
        const author = metaData['저자'] || metaData['author'] || '';
        const date = metaData['날짜'] || metaData['date'] || '';
        const tags = metaData['태그'] || metaData['tags'] || '';
        const desc = metaData['설명'] || metaData['description'] || '';

        let html = `<div class="jocp-meta-box">`;
        html += `<div class="jocp-meta-title">${escapeHtml(title)}</div>`;
        html += `<div class="jocp-meta-info">`;
        if (author) html += `<div class="jocp-meta-item">✍️ ${escapeHtml(author)}</div>`;
        if (date) html += `<div class="jocp-meta-item">📅 ${escapeHtml(date)}</div>`;
        if (tags) html += `<div class="jocp-meta-item">️ ${escapeHtml(tags)}</div>`;
        html += `</div>`;
        if (desc) html += `<div class="jocp-meta-desc">${escapeHtml(desc)}</div>`;
        html += `<button class="jocp-meta-toggle" onclick="this.nextElementSibling.classList.toggle('hidden'); this.textContent = this.nextElementSibling.classList.contains('hidden') ? ' 메타데이터 보기' : '📋 메타데이터 숨기기';">📋 메타데이터 숨기기</button>`;
        html += `<div class="jocp-meta-details">`;
        const reservedKeys = ['제목', 'title', '저자', 'author', '날짜', 'date', '태그', 'tags', '설명', 'description'];
        for (const [key, value] of Object.entries(metaData)) {
          if (!reservedKeys.includes(key)) {
            html += `<div><strong>${escapeHtml(key)}:</strong> ${escapeHtml(value)}</div>`;
          }
        }
        html += `</div></div>`;
        return html;
      }

      function parseQuizTemplate(lines, startIdx) {
        let i = startIdx + 1;
        let question = '';
        const options = [];
        let correctIndex = -1;
        while (i < lines.length && !REGEX.copyBlock.test(lines[i])) {
          const line = lines[i].trim();
          if (line.startsWith('질문:')) question = line.substring(3).trim();
          else if (line.startsWith('- ')) {
            const optText = line.substring(2);
            if (optText.includes('(정답)')) {
              correctIndex = options.length;
              options.push(optText.replace('(정답)', '').trim());
            } else {
              options.push(optText);
            }
          }
          i++;
        }
        let html = `<div class="jocp-quiz"><div class="jocp-quiz-title">📝 ${parseInline(question)}</div>`;
        options.forEach((opt, idx) => {
          html += `<div class="jocp-quiz-option" onclick="JOCP.checkQuiz(this, ${idx}, ${correctIndex})">${parseInline(opt)}</div>`;
        });
        html += `</div>`;
        return { html, nextIdx: i };
      }

      function parseGalleryTemplate(lines, startIdx) {
        let i = startIdx + 1;
        let title = '갤러리';
        const images = [];
        while (i < lines.length && !REGEX.copyBlock.test(lines[i])) {
          const line = lines[i].trim();
          if (line.startsWith('제목:')) title = line.substring(3).trim();
          else if (line.startsWith('- ')) {
            const url = line.substring(2).trim();
            if (url) images.push(url);
          }
          i++;
        }
        let html = `<div class="jocp-gallery"><div class="jocp-gallery-title">️ ${parseInline(title)}</div><div class="jocp-gallery-grid">`;
        images.forEach(img => {
          html += `<img src="${escapeAttr(img)}" alt="gallery" loading="lazy" />`;
        });
        html += `</div></div>`;
        return { html, nextIdx: i };
      }

      function parseVideoTemplate(lines, startIdx) {
        let i = startIdx + 1;
        let source = '';
        let title = '동영상';
        while (i < lines.length && !REGEX.copyBlock.test(lines[i])) {
          const line = lines[i].trim();
          if (line.startsWith('소스:')) source = line.substring(3).trim();
          else if (line.startsWith('제목:')) title = line.substring(3).trim();
          i++;
        }
        let mediaHTML = '';
        const ytMatch = source.match(REGEX.youtube);
        if (ytMatch) {
          const videoId = ytMatch[1];
          mediaHTML = `<iframe src="https://www.youtube.com/embed/${videoId}?rel=0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen loading="lazy"></iframe>`;
        } else if (source) {
          mediaHTML = `<video controls src="${escapeAttr(source)}" preload="metadata"></video>`;
        }
        return { html: `<div class="jocp-media"><div class="jocp-media-title">🎬 ${parseInline(title)}</div>${mediaHTML}</div>`, nextIdx: i };
      }

      function parseAudioTemplate(lines, startIdx) {
        let i = startIdx + 1;
        let source = '';
        let title = '음악';
        while (i < lines.length && !REGEX.copyBlock.test(lines[i])) {
          const line = lines[i].trim();
          if (line.startsWith('소스:')) source = line.substring(3).trim();
          else if (line.startsWith('제목:')) title = line.substring(3).trim();
          i++;
        }
        const audioHTML = source ? `<audio controls src="${escapeAttr(source)}" preload="metadata"></audio>` : '';
        return { html: `<div class="jocp-media"><div class="jocp-media-title">🎵 ${parseInline(title)}</div>${audioHTML}</div>`, nextIdx: i };
      }

      function parseGUITemplate(lines, startIdx) {
        let i = startIdx + 1;
        let title = 'GUI';
        const buttons = [];
        while (i < lines.length && !REGEX.copyBlock.test(lines[i])) {
          const line = lines[i].trim();
          if (line.startsWith('제목:')) title = line.substring(3).trim();
          else if (line.startsWith('- ')) {
            const btnText = line.substring(2);
            const colonIdx = btnText.indexOf(':');
            if (colonIdx !== -1) {
              const label = btnText.substring(0, colonIdx).trim();
              const code = btnText.substring(colonIdx + 1).trim();
              if (label && code) buttons.push({ label, code });
            }
          }
          i++;
        }
        let html = `<div class="jocp-gui"><div class="jocp-gui-title">🎛️ ${parseInline(title)}</div>`;
        buttons.forEach((btn) => {
          const id = scriptStore.length;
          scriptStore.push(btn.code);
          html += `<button class="jocp-gui-btn" onclick="JOCP.executeScript(${id})">${parseInline(btn.label)}</button>`;
        });
        html += `</div>`;
        return { html, nextIdx: i };
      }

      function parseGameTemplate(lines, startIdx) {
        let i = startIdx + 1;
        let title = '게임';
        let htmlContent = '';
        let cssContent = '';
        let jsContent = '';
        let currentSection = '';
        while (i < lines.length && !REGEX.copyBlock.test(lines[i])) {
          const line = lines[i];
          if (line.startsWith('제목:')) {
            title = line.substring(3).trim();
            currentSection = '';
          } else if (/^html:\s*$/.test(line.trim())) currentSection = 'html';
          else if (/^css:\s*$/.test(line.trim())) currentSection = 'css';
          else if (/^js:\s*$/.test(line.trim())) currentSection = 'js';
          else if (currentSection === 'html') htmlContent += line + '\n';
          else if (currentSection === 'css') cssContent += line + '\n';
          else if (currentSection === 'js') jsContent += line + '\n';
          i++;
        }
        const gameId = 'game_' + Math.random().toString(36).substr(2, 9);
        const scriptId = scriptStore.length;
        scriptStore.push(jsContent);
        const parsedHtml = parseInline(htmlContent);
        const html = `<div class="jocp-game" id="${gameId}"><div class="jocp-game-title">🎮 ${parseInline(title)}</div><style>${cssContent}</style><div class="jocp-game-container">${parsedHtml}</div></div>`;
        setTimeout(() => {
          const el = document.getElementById(gameId);
          if (el) {
            const container = el.querySelector('.jocp-game-container');
            if (container) {
              try {
                new Function(scriptStore[scriptId]).call(container);
              } catch (e) {
                console.error('Game error:', e);
              }
            }
          }
        }, 100);
        return { html, nextIdx: i };
      }

      function parseBlock(lines) {
        let html = '';
        let i = 0;
        let metaRendered = false;
        while (i < lines.length) {
          const line = lines[i];
          if (REGEX.metaBlock.test(line) && !metaRendered) {
            const r = parseMetaTemplate(lines, i);
            html += renderMetaData();
            i = r.nextIdx;
            metaRendered = true;
            continue;
          }
          if (REGEX.templateQuiz.test(line)) { const r = parseQuizTemplate(lines, i); html += r.html; i = r.nextIdx; continue; }
          if (REGEX.templateGallery.test(line)) { const r = parseGalleryTemplate(lines, i); html += r.html; i = r.nextIdx; continue; }
          if (REGEX.templateVideo.test(line)) { const r = parseVideoTemplate(lines, i); html += r.html; i = r.nextIdx; continue; }
          if (REGEX.templateAudio.test(line)) { const r = parseAudioTemplate(lines, i); html += r.html; i = r.nextIdx; continue; }
          if (REGEX.templateGUI.test(line)) { const r = parseGUITemplate(lines, i); html += r.html; i = r.nextIdx; continue; }
          if (REGEX.templateGame.test(line)) { const r = parseGameTemplate(lines, i); html += r.html; i = r.nextIdx; continue; }
          if (REGEX.copyBlock.test(line)) {
            let content = '';
            i++;
            while (i < lines.length && !REGEX.copyBlock.test(lines[i])) {
              content += lines[i] + '\n';
              i++;
            }
            i++;
            html += `<div class="jocp-copy-block"><button class="copy-btn" onclick="JOCP.copyText(this)">복사</button><pre><code>${escapeHtml(content.trim())}</code></pre></div>`;
            continue;
          }
          if (REGEX.table.test(line)) {
            const rows = [];
            while (i < lines.length && REGEX.table.test(lines[i])) {
              const cells = lines[i].split('#').map(c => c.trim()).filter(c => c !== '');
              if (cells.length > 0) rows.push(cells);
              i++;
            }
            if (rows.length > 0) {
              html += '<table>';
              rows.forEach((row, idx) => {
                const tag = idx === 0 ? 'th' : 'td';
                html += '<tr>' + row.map(cell => `<${tag}>${parseInline(cell)}</${tag}>`).join('') + '</tr>';
              });
              html += '</table>';
            }
            continue;
          }
          if (REGEX.listUnordered.test(line)) {
            let listHtml = '<ul>';
            let prevLevel = 0;
            while (i < lines.length && REGEX.listUnordered.test(lines[i])) {
              const match = lines[i].match(REGEX.listUnordered);
              if (!match) break;
              const level = match[1].length;
              const content = match[2];
              if (level > prevLevel) for (let j = 0; j < level - prevLevel; j++) listHtml += '<ul>';
              else if (level < prevLevel) for (let j = 0; j < prevLevel - level; j++) listHtml += '</ul>';
              listHtml += `<li>${parseInline(content)}</li>`;
              prevLevel = level;
              i++;
            }
            for (let j = 0; j < prevLevel; j++) listHtml += '</ul>';
            html += listHtml;
            continue;
          }
          if (REGEX.listOrdered.test(line)) {
            html += '<ol>';
            while (i < lines.length && REGEX.listOrdered.test(lines[i])) {
              const match = lines[i].match(REGEX.listOrdered);
              if (!match) break;
              html += `<li>${parseInline(match[2])}</li>`;
              i++;
            }
            html += '</ol>';
            continue;
          }
          if (REGEX.heading.test(line)) {
            const match = line.match(REGEX.heading);
            if (match) {
              const level = 7 - match[1].length;
              const titleText = match[2];
              html += `<h${level} id="${slugify(titleText)}">${parseInline(titleText)}</h${level}>`;
            }
            i++;
            continue;
          }
          if (REGEX.hr.test(line)) { html += '<hr />'; i++; continue; }
          if (REGEX.checkboxTodo.test(line)) {
            const match = line.match(REGEX.checkboxTodo);
            if (match) html += `<label class="jocp-checkbox"><input type="checkbox"> ${parseInline(match[1])}</label>`;
            i++;
            continue;
          }
          if (REGEX.checkboxDone.test(line)) {
            const match = line.match(REGEX.checkboxDone);
            if (match) html += `<label class="jocp-checkbox completed"><input type="checkbox" checked disabled> ${parseInline(match[1])}</label>`;
            i++;
            continue;
          }
          if (line.trim() === '') { i++; continue; }
          html += `<p>${parseInline(line)}</p>`;
          i++;
        }
        return html;
      }

      return {
        get scriptStore() { return scriptStore; },
        get metaData() { return metaData; },
        parse: function(text) {
          scriptStore = [];
          metaData = {};
          if (text == null) return '';
          return parseBlock(String(text).split('\n'));
        },
        checkQuiz: function(el, idx, correct) {
          const parent = el.parentElement;
          if (!parent) return;
          const opts = parent.querySelectorAll('.jocp-quiz-option');
          opts.forEach((opt, i) => {
            opt.classList.remove('correct', 'wrong');
            if (i === correct) opt.classList.add('correct');
            else if (i === idx) opt.classList.add('wrong');
          });
        },
        executeScript: function(id) {
          const code = scriptStore[id];
          if (code) {
            try {
              new Function(code)();
            } catch (e) {
              console.error('Script error:', e);
              alert('스크립트 오류: ' + e.message);
            }
          }
        },
        copyText: function(btn) {
          const block = btn.closest('.jocp-copy-block');
          if (!block) return;
          const code = block.querySelector('code');
          if (!code) return;
          const text = code.innerText;
          if (navigator.clipboard) {
            navigator.clipboard.writeText(text).then(() => {
              const original = btn.textContent;
              btn.textContent = '복사 완료! ✔';
              setTimeout(() => { btn.textContent = original; }, 1500);
            });
          }
        },
        render: function(inputId, previewId) {
          const input = document.getElementById(inputId);
          const preview = document.getElementById(previewId);
          if (!input || !preview) return;
          const update = () => {
            preview.innerHTML = this.parse(input.value);
          };
          input.addEventListener('input', update);
          update();
        }
      };
    })();

    function render() {
      const input = document.getElementById('jocp-input');
      const preview = document.getElementById('preview');
      if (input && preview) {
        preview.innerHTML = JOCP.parse(input.value);
      }
    }

    function downloadJOP() {
      const input = document.getElementById('jocp-input');
      if (!input) return;
      const blob = new Blob([input.value], { type: 'text/plain;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'document.jop';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    }

    function downloadJPC() {
      const input = document.getElementById('jocp-input');
      if (!input) return;
      const source = input.value;
      const rendered = JOCP.parse(source);
      const meta = JOCP.metaData;
      const title = meta['제목'] || meta['title'] || 'JOCP Document';
      const metaTags = Object.entries(meta).map(([k, v]) => `<meta name="${escapeHtml(k)}" content="${escapeHtml(v)}">`).join('\n      ');
      const html = `<!DOCTYPE html><html lang="ko"><head><meta charset="UTF-8"><title>${escapeHtml(title)}</title>${metaTags}<style>body{font-family:sans-serif;max-width:800px;margin:0 auto;padding:20px;}.jocp-meta-box{background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;padding:20px;border-radius:12px;margin-bottom:25px;}.jocp-meta-title{font-size:2em;font-weight:bold;margin-bottom:10px;}.jocp-quiz,.jocp-gallery,.jocp-media,.jocp-gui,.jocp-game{background:#f8f9fa;border:1px solid #dee2e6;border-radius:8px;padding:20px;margin:15px 0;}.jocp-quiz-option{display:block;padding:10px;margin:8px 0;border:1px solid #dee2e6;border-radius:6px;cursor:pointer;background:white;}.jocp-quiz-option.correct{background:#d4edda;border-color:#c3e6cb;}.jocp-quiz-option.wrong{background:#f8d7da;border-color:#f5c6cb;}.jocp-gallery-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:15px;}.jocp-gallery-grid img{width:100%;height:150px;object-fit:cover;border-radius:6px;cursor:pointer;}.jocp-media video,.jocp-media audio,.jocp-media iframe{width:100%;border-radius:6px;}.jocp-gui-btn{display:inline-block;padding:10px 20px;margin:5px;background:#4a9eff;color:white;border:none;border-radius:6px;cursor:pointer;}.jocp-game-container{border:2px solid #333;border-radius:6px;overflow:hidden;background:#000;}.jocp-copy-block{position:relative;background:#212529;color:#f8f9fa;padding:15px;border-radius:8px;margin:15px 0;}.jocp-copy-block pre{margin:0;white-space:pre-wrap;}.copy-btn{position:absolute;top:10px;right:10px;background:#4a9eff;color:white;border:none;padding:6px 12px;border-radius:4px;cursor:pointer;}.jocp-checkbox{display:block;margin:8px 0;}.jocp-checkbox.completed{color:#999;text-decoration:line-through;}hr{border:none;border-top:2px solid #eee;margin:24px 0;}table{border-collapse:collapse;width:100%;margin:15px 0;}th,td{border:1px solid #dee2e6;padding:10px 15px;text-align:left;}th{background:#f8f9fa;}a{color:#4a9eff;}blockquote{border-left:4px solid #4a9eff;padding:10px 20px;background:#f8f9fa;margin:15px 0;}</style></head><body><div id="app">${rendered}</div></body></html>`;
      const blob = new Blob([html], { type: 'text/html;charset=utf-8' });
      const url = URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = 'document.jpc';
      document.body.appendChild(a);
      a.click();
      document.body.removeChild(a);
      URL.revokeObjectURL(url);
    }

    function loadJOP(event) {
      const file = event.target.files && event.target.files[0];
      if (!file) return;
      const reader = new FileReader();
      reader.onload = (e) => {
        const input = document.getElementById('jocp-input');
        if (input) {
          input.value = e.target.result;
          render();
        }
      };
      reader.readAsText(file, 'UTF-8');
      event.target.value = '';
    }

    document.addEventListener('DOMContentLoaded', () => {
      render();
    });
  </script>
</body>
</html>

</textarea>
<div id="preview"></div>
</div>
<script>
let scriptStore=[];
function parseInline(t){
if(!t)return'';
const tokens=[];
const store=function(h){var tok='§'+tokens.length+'§';tokens.push(h);return tok;};
var r=t.replace(/\?([^?]+)\?<(\d+,\d+,\d+)>/g,function(m,c,rgb){return store('<span style="color:rgb('+rgb+')">'+c+'</span>')});
r=r.replace(/`([^`]+)`/g,function(m,c){return store('<ins><strong>'+c+'</strong></ins>')});
r=r.replace(/\{([^}]+)\}/g,function(m,c){return store('<strong>'+c+'</strong>')});
r=r.replace(/~([^~]+)~/g,function(m,c){return store('<em>'+c+'</em>')});
r=r.replace(/_([^_]+)_/g,function(m,c){return store('<del>'+c+'</del>')});
return r.replace(/§(\d+)§/g,function(m,i){return tokens[parseInt(i)]||''});
}
function parseGame(lines,i){
i++;var title='게임',hc='',cc='',jc='',cs='';
while(i<lines.length&&lines[i].trim()!=='~'){
var l=lines[i];
if(l.indexOf('제목:')===0){title=l.substring(3).trim();cs='';}
else if(l.trim()==='html:')cs='html';
else if(l.trim()==='css:')cs='css';
else if(l.trim()==='js:')cs='js';
else if(cs==='html')hc+=l+'\n';
else if(cs==='css')cc+=l+'\n';
else if(cs==='js')jc+=l+'\n';
i++;
}
var gid='game_'+Math.random().toString(36).substr(2,9);
var html='<div class="jocp-game" id="'+gid+'"><div class="jocp-game-title"> '+parseInline(title)+'</div><style>'+cc+'</style><div class="jocp-game-container">'+parseInline(hc)+'</div></div>';
setTimeout(function(){
var el=document.getElementById(gid);
if(el){var co=el.querySelector('.jocp-game-container');if(co&&jc.trim())try{new Function(jc).call(co)}catch(e){console.error(e)}}
},100);
return {html:html,nextIdx:i+1};
}
function parseBlock(text){
var lines=text.split('\n');
var html='',i=0;
while(i<lines.length){
var line=lines[i];
if(/^~game\s*$/.test(line)){
var r=parseGame(lines,i);
html+=r.html;
i=r.nextIdx;
continue;
}
if(/^#\s/.test(line)){
var rows=[];
while(i<lines.length&&/^#\s/.test(lines[i])){
var cells=lines[i].split('#');
var clean=[];
for(var c=0;c<cells.length;c++){var t=cells[c].trim();if(t!=='')clean.push(t);}
if(clean.length>0)rows.push(clean);
i++;
}
if(rows.length>0){
html+='<table>';
for(var r=0;r<rows.length;r++){
var tag=r===0?'th':'td';
html+='<tr>';
for(var c=0;c<rows[r].length;c++){
html+='<'+tag+'>'+parseInline(rows[r][c])+'</'+tag+'>';
}
html+='</tr>';
}
html+='</table>';
}
continue;
}
if(/^(!{1,6})\s+(.+)$/.test(line)){
var m=line.match(/^(!{1,6})\s+(.+)$/);
var lv=7-m[1].length;
html+='<h'+lv+'>'+parseInline(m[2])+'</h'+lv+'>';
i++;
continue;
}
if(line.trim()===''){i++;continue;}
html+='<p>'+parseInline(line)+'</p>';
i++;
}
return html;
}
function render(){
scriptStore=[];
document.getElementById('preview').innerHTML=parseBlock(document.getElementById('input').value);
}
function downloadJOP(){
var c=document.getElementById('input').value;
var b=new Blob([c],{type:'text/plain'});
var u=URL.createObjectURL(b);
var a=document.createElement('a');a.href=u;a.download='document.jop';a.click();
URL.revokeObjectURL(u);
}
function downloadJPC(){
var s=document.getElementById('input').value;
var r=parseBlock(s);
var h='<!DOCTYPE html><html><head><meta charset="UTF-8"><title>JOCP</title><style>body{font-family:sans-serif;max-width:800px;margin:0 auto;padding:20px}table{border-collapse:collapse;width:100%}th,td{border:1px solid #ddd;padding:10px}th{background:#f8f9fa}.jocp-game{background:#fff;border:1px solid #ddd;border-radius:8px;padding:20px;margin:15px 0}.jocp-game-title{font-weight:bold;margin-bottom:15px}.jocp-game-container{border:2px solid #333;border-radius:6px;overflow:hidden;background:#000}</style></head><body>'+r+'</body></html>';
var b=new Blob([h],{type:'text/html'});
var u=URL.createObjectURL(b);
var a=document.createElement('a');a.href=u;a.download='document.jpc';a.click();
URL.revokeObjectURL(u);
}
render();
</script>
</body>
</html>

    th { background: #f0f0f0; font-weight: bold; }
    hr { border: none; border-top: 2px dashed #e0e0e0; margin: 15px 0; }
    a { color: #4a9eff; text-decoration: none; font-weight: 500; }
    a:hover { text-decoration: underline; }
    .jocp-anchor { background: #eef7ff; padding: 2px 6px; border-radius: 4px; border: 1px solid #4a9eff; font-size: 0.9em; }
    h1, h2, h3, h4, h5, h6 { margin-top: 15px; margin-bottom: 5px; color: #111; line-height: 1.3; }
    p { margin: 8px 0; }

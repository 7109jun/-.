    .save-btn:hover { background: #2f87ee; }
    .save-btn.secondary { background: #34c759; }
    .save-btn.secondary:hover { background: #28a745; }
    .container {
      display: flex;
      gap: 12px;
      flex: 1;
      height: calc(100% - 50px);

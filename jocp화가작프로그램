    .jocp-copy-block { position: relative; background: #1e1e1e; color: #d4d4d4; padding: 12px; border-radius: 6px; margin: 10px 0; }
    .jocp-copy-block pre { margin: 0; white-space: pre-wrap; font-size: 12px; }
    .copy-btn { position: absolute; top: 8px; right: 8px; background: #555; color: #fff; border: none; padding: 4px 8px; border-radius: 4px; cursor: pointer; font-size: 11px; }

      flex: 1;
      height: 100%;
      font-family: Consolas, Monaco, monospace;
      font-size: 13px;
      padding: 12px;
      border: 1px solid #e0e0e0;
      border-radius: 8px;
      resize: none;
      box-sizing: border-box;
      outline: none;
      background: #fdfdfd;
    }
    textarea:focus { border-color: #4a9eff; }
    #jocp-preview {
      flex: 1;
      height: 100%;
      overflow-y: auto;
      padding: 15px;

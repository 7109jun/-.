        function updateLineCount() {
            const code = document.getElementById('codeEditor').value;
            const lines = code.split('\n').length;
            document.getElementById('lineCount').textContent = `${lines}줄`;
            document.getElementById('statLines').textContent = lines;
        }

        function updateVariablesTable(interpreter) {
            const tbody = document.getElementById('variablesTable');
            tbody.innerHTML = '';
            
            for (const [name, value] of Object.entries(interpreter.variables)) {
                const tr = document.createElement('tr');
                let type = '일반';
                if (interpreter.memory.allocations.has(name)) type = '메모리';
                else if (interpreter.pointers.has(name)) type = '포인터';
                else if (interpreter.checksums.has(name)) type = '체크섬';
                else if (interpreter.permissions.has(name)) type = '권한';
                else if (typeof value === 'number') type = '숫자';
                else type = '문자열';
                
                tr.innerHTML = `
                    <td class="var-name">${name}</td>
                    <td class="var-value">${value}</td>
                    <td class="var-type">${type}</td>
                `;
                tbody.appendChild(tr);
            }
            
            document.getElementById('statVars').textContent = Object.keys(interpreter.variables).length;
        }

        function updateDebugLog(logs) {
            const logDiv = document.getElementById('debugLog');
            logDiv.innerHTML = '';
            
            for (const log of logs) {
                const entry = document.createElement('div');
                entry.className = `log-entry ${log.level}`;
                entry.innerHTML = `<span class="log-time">[${log.time}]</span> ${log.message}`;
                logDiv.appendChild(entry);
            }
            
            logDiv.scrollTop = logDiv.scrollHeight;
        }

        function clearLog() {
            document.getElementById('debugLog').innerHTML = '';
        }

        function runCode() {
            const code = document.getElementById('codeEditor').value;
            const outputDiv = document.getElementById('output');
            const outputStatus = document.getElementById('outputStatus');
            
            const startTime = performance.now();
            
            try {
                outputDiv.innerHTML = '<span class="info">🔧 컴파일 중...</span>\n';
                outputStatus.textContent = '실행중';
                outputStatus.style.color = '#ffd93d';
                
                const lexer = new Lexer(code);
                const tokens = lexer.tokenize();
                
                const parser = new Parser(tokens);
                const program = parser.parse();
                
                const interpreter = new Interpreter();
                const result = interpreter.interpret(program);
                
                const endTime = performance.now();
                const executionTime = Math.round(endTime - startTime);
                
                outputDiv.innerHTML = `<span class="success">✓ 실행 완료</span>\n\n<span class="success">출력:</span>\n${result}`;
                outputStatus.textContent = '완료';
                outputStatus.style.color = '#00ff41';
                
                document.getElementById('statTime').textContent = `${executionTime}ms`;
                document.getElementById('statPhase').textContent = `${Math.round(interpreter.currentPhase * 12)}/12`;
                
                updateVariablesTable(interpreter);
                updateDebugLog(interpreter.debugLog);
                
            } catch (error) {
                outputDiv.innerHTML = `<span class="error">${error.message}</span>`;
                outputStatus.textContent = '오류';
                outputStatus.style.color = '#ff0000';
            }
        }

        function clearCode() {
            document.getElementById('codeEditor').value = '';
            document.getElementById('output').innerHTML = '';
            document.getElementById('debugLog').innerHTML = '';
            document.getElementById('variablesTable').innerHTML = '';
            document.getElementById('outputStatus').textContent = '대기중';
            document.getElementById('outputStatus').style.color = '#666';
            document.getElementById('statPhase').textContent = '0/12';
            updateLineCount();
        }


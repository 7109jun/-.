<script type="module">
/* ============================================================
 *  HPCDown v4.1 — DOMParser 기반 하이픈 안전 처리
 *  핵심: HTML은 DOM으로, CSS/JS는 토큰 기반으로 처리
 * ========================================================== */

/* ---------------- Parser ---------------- */
const HtmlParser = {
  // DOMParser를 사용하여 정확한 class/id 추출 (하이픈 안전)
  extractIdentifiers(src){
    const classes = new Set(), ids = new Set();
    try {
      const parser = new DOMParser();
      const doc = parser.parseFromString(src, 'text/html');
      
      // 모든 요소 순회
      doc.querySelectorAll('*').forEach(el => {
        // class 속성에서 개별 클래스 추출
        if(el.classList && el.classList.length > 0){
          el.classList.forEach(c => classes.add(c));
        }
        // id 속성 추출
        if(el.id) ids.add(el.id);
      });
    } catch(e) {
      // 파싱 실패 시 정규식 폴백
      const reClass = /\bclass\s*=\s*["']([^"']+)["']/g;
      const reId    = /\bid\s*=\s*["']([^"']+)["']/g;
      let m;
      while((m = reClass.exec(src))) m[1].split(/\s+/).forEach(c=>c&&classes.add(c));
      while((m = reId.exec(src)))    ids.add(m[1]);
    }
    return { classes:[...classes], ids:[...ids] };
  }
};

const CssParser = {
  // 하이픈 포함 선택자 추출 ([\w-]+ 패턴)
  extractSelectors(src){
    const classes = new Set(), ids = new Set();
    // 하이픈(-)을 포함한 식별자도 매칭
    const re = /([.#])([\w-]+)/g;
    let m;
    while((m = re.exec(src))){
      (m[1]==='.'?classes:ids).add(m[2]);
    }
    return { classes:[...classes], ids:[...ids] };
  }
};

const JsParser = {
  extractStringRefs(src){
    const refs = new Set();
    // 하이픈 포함 문자열도 매칭
    const re = /["'`](?:\.|#)?([\w-]+)["'`]/g;
    let m;
    while((m = re.exec(src))){ refs.add(m[1]); }
    return [...refs];
  }
};

/* ---------------- Analyzer ---------------- */
const DependencyAnalyzer = {
  build(htmlSrc, cssSrc, jsSrc){
    const h = HtmlParser.extractIdentifiers(htmlSrc);
    const c = CssParser.extractSelectors(cssSrc);
    const jRaw = JsParser.extractStringRefs(jsSrc);
    const jClasses = jRaw.filter(x=>h.classes.includes(x));
    const jIds = jRaw.filter(x=>h.ids.includes(x));
    const classMap = new Map(), idMap = new Map();
    h.classes.forEach(n=>classMap.set(n,{html:true,css:c.classes.includes(n),js:jClasses.includes(n)}));
    h.ids.forEach(n=>idMap.set(n,{html:true,css:c.ids.includes(n),js:jIds.includes(n)}));
    return { classMap, idMap, html:h, css:c };
  }
};

/* ---------------- Renamer (v4.1 - DOMParser 기반) ---------------- */
const IdentifierRenamer = {
  buildMap(names){
    const map = new Map();
    let i = 0;
    for(const n of names){ map.set(n, this._encode(i++)); }
    return map;
  },
  _encode(n){
    let s=''; const a='a'.charCodeAt(0);
    do { s = String.fromCharCode(a + (n%26)) + s; n = Math.floor(n/26)-1; } while(n>=0);
    return s;
  },
  
  // HTML을 DOM으로 파싱하여 안전하게 class/id 변경 (하이픈 안전!)
  applyToHtml(html, map){
    try {
      const parser = new DOMParser();
      const doc = parser.parseFromString(html, 'text/html');
      
      doc.querySelectorAll('*').forEach(el => {
        // classList 변경 (하이픈 포함 클래스도 안전하게 처리)
        if(el.classList && el.classList.length > 0){
          const newClasses = [];
          el.classList.forEach(c => {
            newClasses.push(map.has(c) ? map.get(c) : c);
          });
          el.className = newClasses.join(' ');
        }
        // id 변경
        if(el.id && map.has(el.id)){
          el.id = map.get(el.id);
        }
      });
      
      // doctype 보존
      let result = '';
      if(doc.doctype){
        result += '<!DOCTYPE ' + doc.doctype.name + '>\n';
      }
      result += doc.documentElement.outerHTML;
      return result;
    } catch(e) {
      // 파싱 실패 시 토큰 기반 폴백
      return this._applyToHtmlFallback(html, map);
    }
  },
  
  // 폴백: 토큰 기반 HTML 처리
  _applyToHtmlFallback(html, map){
    let result = html;
    // class="..." 내부에서 토큰 단위로 치환
    result = result.replace(/\bclass\s*=\s*["']([^"']+)["']/g, (m, val) => {
      const tokens = val.split(/\s+/).map(t => map.has(t) ? map.get(t) : t);
      return `class="${tokens.join(' ')}"`;
    });
    // id="..." 치환 (전체 매칭)
    result = result.replace(/\bid\s*=\s*["']([^"']+)["']/g, (m, val) => {
      return `id="${map.has(val) ? map.get(val) : val}"`;
    });
    return result;
  },
  
  // CSS 변경 (하이픈 포함 선택자 안전 처리)
  applyToCss(css, map){
    let result = css;
    // 긴 이름부터 치환하여 부분치환 방지
    const entries = [...map.entries()].sort((a,b)=>b[0].length-a[0].length);
    for(const [from, to] of entries){
      const esc = from.replace(/[-/\\^$*+?.()|[\]{}]/g,'\\$&');
      // .btn-primary 또는 #main-header 패턴 (하이픈 포함 전체 매칭)
      // 음수 lookbehind로 더 긴 식별자의 일부가 아닌 경우만 매칭
      const classRe = new RegExp(`(?<![\\w-])\\.${esc}(?![\\w-])`, 'g');
      const idRe = new RegExp(`(?<![\\w-])\\#${esc}(?![\\w-])`, 'g');
      result = result.replace(classRe, `.${to}`);
      result = result.replace(idRe, `#${to}`);
    }
    return result;
  },
  
  // JS 변경 (문자열 리터럴 내에서만 정확한 매칭)
  applyToJs(js, map){
    const literals = [];
    // 문자열 리터럴 추출
    const escaped = js.replace(/"(?:\\.|[^"\\])*"|'(?:\\.|[^'\\])*'|`(?:\\.|[^`\\])*`/g,
      m => { literals.push(m); return `\u0001${literals.length-1}\u0001`; });
    
    // 문자열 리터럴 내부에서만 치환
    const modified = literals.map(lit => {
      let result = lit;
      const entries = [...map.entries()].sort((a,b)=>b[0].length-a[0].length);
      for(const [from, to] of entries){
        const esc = from.replace(/[-/\\^$*+?.()|[\]{}]/g,'\\$&');
        // 문자열 내에서 정확한 단어 경계 매칭 (하이픈 포함)
        const re = new RegExp(`(?<![\\w-])${esc}(?![\\w-])`, 'g');
        result = result.replace(re, to);
      }
      return result;
    });
    
    // 리터럴 복원
    return escaped.replace(/\u0001(\d+)\u0001/g, (_, i) => modified[+i]);
  },
  
  // 통합 apply
  apply(html, css, js, map){
    return {
      html: this.applyToHtml(html, map),
      css: this.applyToCss(css, map),
      js: this.applyToJs(js, map)
    };
  },
  
  // 역변환 (동일한 로직으로 reverse map 적용)
  reverse(html, css, js, reverseMap){
    return this.apply(html, css, js, reverseMap);
  }
};

/* ---------------- Compressor ---------------- */
const HtmlCompressor = {
  run(src){
    let s = src;
    s = s.replace(/<!--[\s\S]*?-->/g,'');
    s = s.replace(/>\s+</g,'><');
    s = s.replace(/\s{2,}/g,' ');
    s = s.replace(/(\w+)=["']([A-Za-z0-9_-]+)["']/g,(m,k,v)=>`${k}=${v}`);
    return s.trim();
  }
};

const CssCompressor = {
  run(src){
    let s = src;
    s = s.replace(/\/\*[\s\S]*?\*\//g,'');
    s = s.replace(/\s+/g,' ');
    s = s.replace(/\s*([{}:;,>~+])\s*/g,'$1');
    s = s.replace(/;}/g,'}');
    s = s.replace(/#([0-9a-fA-F])\1([0-9a-fA-F])\2([0-9a-fA-F])\3\b/g,'#$1$2$3');
    s = s.replace(/(:|\s)0(?:px|em|rem|pt|ex|ch|vw|vh|vmin|vmax|%)/g,'$1'+'0');
    return s.trim();
  }
};

const JsCompressor = {
  run(src){
    let s = src;
    s = s.replace(/\/\*[\s\S]*?\*\//g,'');
    s = s.replace(/^\s*\/\/.*$/gm,'');
    return this._collapseWhitespace(s);
  },
  _collapseWhitespace(src){
    const literals = [];
    const escaped = src.replace(/"(?:\\.|[^"\\])*"|'(?:\\.|[^'\\])*'|`(?:\\.|[^`\\])*`/g,
      m => { literals.push(m); return `\u0000${literals.length-1}\u0000`; });
    let s = escaped.replace(/\s+/g,' ')
                   .replace(/\s*([{}();,=+\-*/<>!&|?:])\s*/g,'$1')
                   .replace(/;}/g,'}');
    return s.replace(/\u0000(\d+)\u0000/g,(_,i)=>literals[+i]);
  }
};

/* ---------------- HCDN Format ---------------- */
const HCDN_FORMAT = {
  version: "4.1",
  
  compress(files, mode, metadata){
    const compressed = {};
    const stats = { html:{before:0,after:0}, css:{before:0,after:0}, js:{before:0,after:0} };
    
    for (const [name, { type, content }] of files) {
      const originalSize = content.length;
      const compressedData = LZString.compressToBase64(content);
      compressed[name] = {
        type,
        compressed: compressedData,
        originalSize,
        compressedSize: compressedData.length
      };
      if(stats[type]){
        stats[type].before += originalSize;
        stats[type].after += compressedData.length;
      }
    }
    
    return {
      version: this.version,
      mode,
      timestamp: new Date().toISOString(),
      files: compressed,
      metadata,
      stats: {
        ...stats,
        total: {
          before: stats.html.before + stats.css.before + stats.js.before,
          after: stats.html.after + stats.css.after + stats.js.after
        }
      }
    };
  },
  
  restore(hcdnData){
    const files = new Map();
    
    for (const [name, fileData] of Object.entries(hcdnData.files)) {
      let content = LZString.decompressFromBase64(fileData.compressed);
      
      if(hcdnData.mode === 'reversible' && hcdnData.metadata?.renameMap){
        const reverseMap = new Map();
        for(const [orig, short] of Object.entries(hcdnData.metadata.renameMap)){
          reverseMap.set(short, orig);
        }
        const r = IdentifierRenamer.reverse(
          fileData.type === 'html' ? content : '',
          fileData.type === 'css' ? content : '',
          fileData.type === 'js' ? content : '',
          reverseMap
        );
        if(fileData.type === 'html') content = r.html;
        if(fileData.type === 'css') content = r.css;
        if(fileData.type === 'js') content = r.js;
      }
      
      if(hcdnData.mode === 'max' && hcdnData.metadata?.originalCss?.[name]){
        content = hcdnData.metadata.originalCss[name];
      }
      
      files.set(name, { type: fileData.type, content });
    }
    
    return files;
  },
  
  serialize(hcdnData){ return JSON.stringify(hcdnData, null, 2); },
  deserialize(str){ return JSON.parse(str); }
};

/* ---------------- UI ---------------- */
const UI = {
  files: new Map(),
  result: null,
  hcdnData: null,
  mode: 'lossless',
  restoreMode: false,

  els: {
    drop: document.getElementById('drop'),
    input: document.getElementById('fileInput'),
    list: document.getElementById('fileList'),
    run: document.getElementById('btnRun'),
    restore: document.getElementById('btnRestore'),
    clear: document.getElementById('btnClear'),
    download: document.getElementById('btnDownload'),
    preview: document.getElementById('preview'),
    tabs: document.getElementById('tabs'),
    log: document.getElementById('log'),
    pipeline: document.getElementById('pipeline'),
    modeSelector: document.getElementById('modeSelector'),
    restoreInfo: document.getElementById('restoreInfo'),
  },

  detectType(name){
    if(/\.html?$/i.test(name)) return 'html';
    if(/\.css$/i.test(name)) return 'css';
    if(/\.js$/i.test(name)) return 'js';
    if(/\.hcdn$/i.test(name)) return 'hcdn';
    return null;
  },

  async addFiles(fileList){
    for(const f of fileList){
      const type = this.detectType(f.name);
      if(!type) continue;
      this.files.set(f.name, { type, content: await f.text() });
    }
    this.renderList();
    this.checkHcdn();
  },

  checkHcdn(){
    const hcdnFile = [...this.files.entries()].find(([_,f]) => f.type === 'hcdn');
    if(hcdnFile){
      this.restoreMode = true;
      this.els.run.style.display = 'none';
      this.els.restore.style.display = 'inline-block';
      this.els.restore.disabled = false;
      this.els.modeSelector.style.display = 'none';
      
      try {
        const hcdnData = HCDN_FORMAT.deserialize(hcdnFile[1].content);
        this.els.restoreInfo.style.display = 'block';
        this.els.restoreInfo.innerHTML = 
          `📦 <b>.hcdn 파일 감지됨</b><br>` +
          `• 버전: ${hcdnData.version}<br>` +
          `• 모드: ${hcdnData.mode}<br>` +
          `• 파일 수: ${Object.keys(hcdnData.files).length}개<br>` +
          `• 복원 가능: ${hcdnData.mode !== 'max' ? '✅ 예' : '❌ 아니오 (최대 압축 모드)'}`;
        this.log('.hcdn 파일 로드 완료. "↩ 원본 복원" 버튼을 클릭하세요.');
      } catch(e){
        this.log('❌ .hcdn 파일 파싱 실패: ' + e.message);
      }
    } else {
      this.restoreMode = false;
      this.els.run.style.display = 'inline-block';
      this.els.restore.style.display = 'none';
      this.els.modeSelector.style.display = 'flex';
      this.els.restoreInfo.style.display = 'none';
    }
    this.els.run.disabled = [...this.files.values()].filter(f=>f.type!=='hcdn').length === 0;
  },

  renderList(){
    const el = this.els.list; el.innerHTML='';
    for(const [name,{type}] of this.files){
      const chip = document.createElement('span');
      chip.className = `chip ${type}`;
      chip.innerHTML = `<span class="t">${type.toUpperCase()}</span>${name}<button data-n="${name}">×</button>`;
      el.appendChild(chip);
    }
    el.querySelectorAll('button').forEach(b=>{
      b.onclick = ()=>{ this.files.delete(b.dataset.n); this.renderList(); this.checkHcdn(); };
    });
  },

  setMode(mode){
    this.mode = mode;
    this.els.modeSelector.querySelectorAll('.mode-card').forEach(c=>{
      c.classList.toggle('active', c.dataset.mode === mode);
    });
  },

  log(msg){
    this.els.log.innerHTML = `[${new Date().toLocaleTimeString()}] ${msg}<br>` + this.els.log.innerHTML;
  },

  markStep(step, skip=false){
    const el = this.els.pipeline.querySelector(`[data-step="${step}"]`);
    if(el){
      el.classList.remove('done','skip');
      el.classList.add(skip ? 'skip' : 'done');
    }
  },
  resetPipeline(){
    this.els.pipeline.querySelectorAll('.step').forEach(s=>s.classList.remove('done','skip'));
  },

  setStats(stats){
    const fmt = b => b<1024?`${b}B`:`${(b/1024).toFixed(2)}KB`;
    const pct = (a,b)=> b?((1-a/b)*100).toFixed(1)+'%':'0%';

    document.getElementById('sHtml').textContent = fmt(stats.html.after);
    document.getElementById('dHtml').textContent = pct(stats.html.after, stats.html.before)+' ↓';
    document.getElementById('sCss').textContent = fmt(stats.css.after);
    document.getElementById('dCss').textContent = pct(stats.css.after, stats.css.before)+' ↓';
    document.getElementById('sJs').textContent = fmt(stats.js.after);
    document.getElementById('dJs').textContent = pct(stats.js.after, stats.js.before)+' ↓';
    document.getElementById('sTotal').textContent = fmt(stats.total.after);
    document.getElementById('dTotal').textContent = `압축률 ${pct(stats.total.after, stats.total.before)} · ${fmt(stats.total.before-stats.total.after)} 절약`;
    document.getElementById('barTotal').style.width = `${(stats.total.after/stats.total.before)*100}%`;
  },

  firstOf(type){
    for(const v of this.files.values()) if(v.type===type) return v.content;
    return null;
  }
};

/* ---------------- Main ---------------- */
const Main = {
  init(){
    const { drop, input } = UI.els;
    drop.onclick = ()=> input.click();
    input.onchange = e => UI.addFiles(e.target.files);
    ['dragenter','dragover'].forEach(ev=>drop.addEventListener(ev,e=>{e.preventDefault();drop.classList.add('over');}));
    ['dragleave','drop'].forEach(ev=>drop.addEventListener(ev,e=>{e.preventDefault();drop.classList.remove('over');}));
    drop.addEventListener('drop', e => UI.addFiles(e.dataTransfer.files));

    UI.els.run.onclick = ()=> this.compress();
    UI.els.restore.onclick = ()=> this.restore();
    UI.els.clear.onclick = ()=>{ UI.files.clear(); UI.renderList(); UI.checkHcdn(); };
    UI.els.download.onclick = ()=> this.download();

    UI.els.tabs.querySelectorAll('.tab').forEach(t=>{
      t.onclick = ()=>{
        UI.els.tabs.querySelectorAll('.tab').forEach(x=>x.classList.remove('active'));
        t.classList.add('active');
        this.showPreview(t.dataset.t);
      };
    });

    UI.els.modeSelector.querySelectorAll('.mode-card').forEach(c=>{
      c.onclick = ()=> UI.setMode(c.dataset.mode);
    });
  },

  compress(){
    UI.resetPipeline();
    const mode = UI.mode;
    
    let html = UI.firstOf('html')||'', css = UI.firstOf('css')||'', js = UI.firstOf('js')||'';
    const before = { html:html.length, css:css.length, js:js.length };
    
    const metadata = {};
    const originalCss = {};

    UI.markStep('lz');

    if(mode === 'reversible' || mode === 'max'){
      const dep = DependencyAnalyzer.build(html, css, js);
      
      UI.markStep('rename');
      const names = [...dep.classMap.keys(), ...dep.idMap.keys()].filter(n=>n.length>1);
      const map = IdentifierRenamer.buildMap(names);
      const r = IdentifierRenamer.apply(html, css, js, map);
      html = r.html; css = r.css; js = r.js;
      
      metadata.renameMap = {};
      for(const [orig, short] of map.entries()){
        metadata.renameMap[orig] = short;
      }
      UI.log(`이름 변경: ${names.length}개 → 짧은 심볼 (DOMParser 적용, 하이픈 안전)`);
      
      UI.markStep('minify');
      html = HtmlCompressor.run(html);
      css = CssCompressor.run(css);
      js = JsCompressor.run(js);
      UI.log('Minify 완료');
      
      if(mode === 'max'){
        UI.markStep('unused');
        const usedClasses = new Set(dep.html.classes);
        const usedIds = new Set(dep.html.ids);
        const unusedClasses = [...dep.css.classes].filter(c=>!usedClasses.has(c));
        const unusedIds = [...dep.css.ids].filter(i=>!usedIds.has(i));
        
        for(const [name, f] of UI.files){
          if(f.type === 'css') originalCss[name] = f.content;
        }
        metadata.originalCss = originalCss;
        
        for(const uc of unusedClasses){
          const esc = uc.replace(/[-/\\^$*+?.()|[\]{}]/g,'\\$&');
          css = css.replace(new RegExp(`(?<![\\w-])\\.${esc}(?![\\w-])\\s*\\{[^}]*\\}`, 'g'), '');
        }
        for(const ui of unusedIds){
          const esc = ui.replace(/[-/\\^$*+?.()|[\]{}]/g,'\\$&');
          css = css.replace(new RegExp(`(?<![\\w-])\\#${esc}(?![\\w-])\\s*\\{[^}]*\\}`, 'g'), '');
        }
        UI.log(`미사용 CSS 제거: ${unusedClasses.length + unusedIds.length}개 규칙`);
      } else {
        UI.markStep('unused', true);
      }
    } else {
      UI.markStep('rename', true);
      UI.markStep('minify', true);
      UI.markStep('unused', true);
      UI.log('완전 가역 모드: LZ 압축만 적용');
    }

    const files = new Map();
    for(const [name,{type}] of UI.files){
      if(type==='html') files.set(name,{type,content:html});
      if(type==='css')  files.set(name,{type,content:css});
      if(type==='js')   files.set(name,{type,content:js});
    }
    
    const hcdnData = HCDN_FORMAT.compress(files, mode, metadata);
    UI.hcdnData = hcdnData;
    UI.result = { html, css, js, metadata };
    
    UI.setStats(hcdnData.stats);
    UI.els.download.disabled = false;
    this.showPreview('html');
    
    const pct = ((1 - hcdnData.stats.total.after / hcdnData.stats.total.before) * 100).toFixed(1);
    const restoreNote = mode === 'max' ? ' (⚠ 복원 불가)' : ' (✓ 복원 가능)';
    UI.log(`🎉 압축 완료! ${pct}% 절감${restoreNote}`);
  },

  restore(){
    const hcdnFile = [...UI.files.entries()].find(([_,f]) => f.type === 'hcdn');
    if(!hcdnFile){ UI.log('❌ .hcdn 파일이 없습니다'); return; }
    
    try {
      const hcdnData = HCDN_FORMAT.deserialize(hcdnFile[1].content);
      
      if(hcdnData.mode === 'max'){
        UI.log('⚠ 최대 압축 모드는 완전 복원이 불가능합니다. CSS는 원본 복원.');
      }
      
      const restored = HCDN_FORMAT.restore(hcdnData);
      UI.result = {};
      for(const [name, {type, content}] of restored){
        UI.result[type] = content;
      }
      UI.result.metadata = hcdnData.metadata;
      
      UI.setStats(hcdnData.stats);
      UI.els.download.disabled = false;
      this.showPreview('html');
      UI.log(`✅ 복원 완료! ${restored.size}개 파일`);
    } catch(e){
      UI.log('❌ 복원 실패: ' + e.message);
    }
  },

  showPreview(type){
    if(!UI.result){ UI.els.preview.textContent='(결과가 여기에 표시됩니다)'; return; }
    if(type === 'meta'){
      UI.els.preview.textContent = UI.result.metadata ? JSON.stringify(UI.result.metadata, null, 2) : '(메타데이터 없음)';
    } else {
      UI.els.preview.textContent = UI.result[type] || '(해당 파일 없음)';
    }
  },

  async download(){
    if(!UI.hcdnData){ UI.log('❌ 압축된 데이터가 없습니다'); return; }
    
    const blob = new Blob([HCDN_FORMAT.serialize(UI.hcdnData)], { type: 'application/json' });
    const a = document.createElement('a');
    a.href = URL.createObjectURL(blob);
    a.download = 'project.hcdn';
    a.click();
    URL.revokeObjectURL(a.href);
    UI.log('.hcdn 파일 다운로드 완료');
  }
};

Main.init();
</script>
</body>
</html>

<!DOCTYPE html>
<html lang="ko">
<head>
<meta charset="UTF-8" />
<title>HPCDown v4.1 — 하이픈 안전 + DOMParser</title>
<script src="https://cdn.jsdelivr.net/npm/jszip@3.10.1/dist/jszip.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/lz-string@1.5.0/libs/lz-string.min.js"></script>
<style>
  :root {
    --bg:#0f1115; --panel:#171a21; --border:#262b36;
    --text:#e6e8ee; --muted:#8a93a6; --accent:#6ee7b7; --accent2:#60a5fa;
    --danger:#f87171; --ok:#34d399; --warn:#fbbf24;
  }
  *{box-sizing:border-box}
  body{margin:0;font-family:ui-sans-serif,system-ui,"Apple SD Gothic Neo",sans-serif;
       background:var(--bg);color:var(--text)}
  header{padding:18px 24px;border-bottom:1px solid var(--border);
         display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px}
  header h1{margin:0;font-size:18px;letter-spacing:.5px}
  header h1 span{color:var(--accent)}
  main{display:grid;grid-template-columns:1fr 1fr;gap:16px;padding:16px}
  .panel{background:var(--panel);border:1px solid var(--border);border-radius:12px;
         padding:14px;min-height:300px}
  .panel h2{margin:0 0 10px;font-size:14px;color:var(--muted);
            text-transform:uppercase;letter-spacing:1px}
  .drop{border:2px dashed var(--border);border-radius:10px;padding:22px;
        text-align:center;color:var(--muted);transition:.15s;cursor:pointer}
  .drop.over{border-color:var(--accent);color:var(--accent);background:#0c1410}
  .file-list{margin-top:10px;display:flex;flex-wrap:wrap;gap:6px}
  .chip{background:#1f2430;border:1px solid var(--border);border-radius:999px;
        padding:4px 10px;font-size:12px;display:inline-flex;gap:6px;align-items:center}
  .chip .t{font-weight:600}
  .chip.html .t{color:#f59e0b} .chip.css .t{color:#60a5fa} .chip.js .t{color:#fbbf24}
  .chip.hcdn .t{color:#a78bfa}
  .chip button{background:transparent;border:0;color:var(--muted);cursor:pointer;font-size:14px}
  .row{display:flex;gap:8px;flex-wrap:wrap;margin-top:12px}
  button.primary{background:var(--accent);color:#06201a;border:0;padding:10px 16px;
        border-radius:8px;font-weight:700;cursor:pointer}
  button.secondary{background:var(--accent2);color:#06201a;border:0;padding:10px 16px;
        border-radius:8px;font-weight:700;cursor:pointer}
  button.ghost{background:transparent;color:var(--text);border:1px solid var(--border);
        padding:8px 12px;border-radius:8px;cursor:pointer}
  button:disabled{opacity:.5;cursor:not-allowed}
  
  .mode-selector{display:flex;gap:8px;margin:12px 0;flex-wrap:wrap}
  .mode-card{flex:1;min-width:140px;padding:12px;border:2px solid var(--border);
             border-radius:8px;cursor:pointer;transition:.2s;background:#12151c}
  .mode-card:hover{border-color:var(--muted)}
  .mode-card.active{border-color:var(--accent);background:#0c1410}
  .mode-card .title{font-weight:700;margin-bottom:4px;color:var(--text)}
  .mode-card .desc{font-size:11px;color:var(--muted);line-height:1.4}
  .mode-card .badge{display:inline-block;padding:2px 6px;border-radius:4px;
                    font-size:10px;margin-top:6px;font-weight:600}
  .mode-card .badge.ok{background:var(--ok);color:#06201a}
  .mode-card .badge.no{background:var(--danger);color:#fff}
  
  .stats{display:grid;grid-template-columns:repeat(4,1fr);gap:8px;margin-top:10px}
  .stat{background:#12151c;border:1px solid var(--border);border-radius:8px;padding:10px}
  .stat .k{font-size:11px;color:var(--muted);text-transform:uppercase}
  .stat .v{font-size:16px;font-weight:700;margin-top:4px}
  .stat .d{font-size:11px;color:var(--ok);margin-top:2px}
  
  .bar{height:8px;background:#12151c;border-radius:4px;overflow:hidden;margin-top:6px}
  .bar > div{height:100%;background:linear-gradient(90deg,var(--accent),var(--accent2))}
  
  .log{font-size:12px;color:var(--muted);max-height:140px;overflow:auto;
       background:#0b0d12;border:1px solid var(--border);border-radius:8px;padding:8px;margin-top:8px}
  
  .pipeline{background:#0b0d12;border:1px solid var(--border);border-radius:8px;padding:10px;
            margin-top:10px;font-size:11px;color:var(--muted);display:flex;flex-wrap:wrap;gap:4px;align-items:center}
  .pipeline .step{padding:4px 8px;border-radius:4px;background:#1f2430;transition:.2s}
  .pipeline .step.done{background:var(--accent);color:#06201a;font-weight:600}

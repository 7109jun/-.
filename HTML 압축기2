  .tabs{display:flex;gap:6px;margin-bottom:8px}
  .tab{padding:6px 10px;border:1px solid var(--border);border-radius:6px;
       font-size:12px;cursor:pointer;color:var(--muted)}
  .tab.active{color:var(--text);border-color:var(--accent)}
  pre{background:#0b0d12;border:1px solid var(--border);border-radius:8px;
      padding:10px;overflow:auto;max-height:360px;font-size:12px;line-height:1.5;
      white-space:pre-wrap;word-break:break-all}
  
  .restore-info{background:#1a2a1a;border:1px solid var(--ok);border-radius:8px;
                padding:10px;margin-top:10px;font-size:12px;color:var(--ok)}
  
  .fix-note{background:#1a2030;border:1px solid var(--accent2);border-radius:8px;
            padding:10px;margin-bottom:12px;font-size:12px;color:var(--accent2)}
</style>

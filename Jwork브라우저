            Panel controlContainer = new Panel { Dock = DockStyle.Top, Height = 95, BackColor = Color.FromArgb(22, 27, 34) };

            // лӮҙл№„кІҢмқҙм…ҳ мҳҒм—ӯ
            Panel navPanel = new Panel { Dock = DockStyle.Top, Height = 50, BackColor = Color.FromArgb(22, 27, 34) };
            
            // [к°ңм„  мҷ„лЈҢ] Y мўҢн‘ңмҷҖ лҶ’мқҙ(Height)к№Ңм§Җ нҳём¶ңл¶Җм—җм„ң лӘ…нҷ•н•ҳкІҢ м ңм–ҙн•ҳлҸ„лЎқ нҢ©нҶ лҰ¬ л©”м„ңл“ң мҲҳм •
            Button CreateGitButton(string text, int x, int y, int width, int height) => new Button {
                Location = new Point(x, y),
                Size = new Size(width, height),
                Text = text,
                Font = new Font("Segoe UI", 9, FontStyle.Bold),
                FlatStyle = FlatStyle.Flat,
                BackColor = Color.FromArgb(33, 38, 45),
                ForeColor = Color.FromArgb(201, 209, 217),
                Cursor = Cursors.Hand
            };

            // лӘЁл“  лІ„нҠјмқҳ Y мўҢн‘ңлҘј 10, лҶ’мқҙлҘј 30мңјлЎң м§ҒкҙҖм Ғ нҶөмқј
            btnBack = CreateGitButton("в—Җ", 15, 10, 35, 30);
            btnBack.Click += (s, e) => { if (webView?.CoreWebView2 != null && webView.CoreWebView2.CanGoBack) webView.CoreWebView2.GoBack(); };

            btnForward = CreateGitButton("в–¶", 55, 10, 35, 30);
            btnForward.Click += (s, e) => { if (webView?.CoreWebView2 != null && webView.CoreWebView2.CanGoForward) webView.CoreWebView2.GoForward(); };

            btnRefresh = CreateGitButton("вҹі", 95, 10, 35, 30);
            btnRefresh.Click += (s, e) => webView?.CoreWebView2?.Reload();

            btnHome = CreateGitButton("рҹҸ  JWork Home", 135, 10, 110, 30);
            btnHome.Click += (s, e) => NavigateToUrl(jworkHomeUrl);

            // мЈјмҶҢм°Ҫ мң„м№ҳ (Y: 11)
            urlTextBox = new TextBox { 
                Location = new Point(255, 11), 
                Width = 1180, 
                Font = new Font("Segoe UI", 11),
                BackColor = Color.FromArgb(13, 17, 23),
                ForeColor = Color.FromArgb(240, 246, 252),
                BorderStyle = BorderStyle.FixedSingle
            };
            urlTextBox.Text = jworkHomeUrl; 
            urlTextBox.KeyDown += (s, e) => { if (e.KeyCode == Keys.Enter) NavigateToUrl(urlTextBox.Text); };

            // [лІ„к·ё мҲҳм • мҷ„лЈҢ] лӢӨлҘё лӮҙл№„кІҢмқҙм…ҳ лІ„нҠјкіј YмўҢн‘ң(10) л°Ҹ лҶ’мқҙ(30)лҘј м№јк°ҷмқҙ л§һм¶”кі  нҢҢлқјлҜён„° л¶Ҳмқјм№ҳ н•ҙкІ°
            Button btnGo = CreateGitButton("Go", 1445, 10, 55, 30);
            btnGo.BackColor = Color.FromArgb(35, 134, 54); 
            btnGo.ForeColor = Color.White;
            btnGo.Click += (s, e) => NavigateToUrl(urlTextBox.Text);

            navPanel.Controls.AddRange(new Control[] { btnBack, btnForward, btnRefresh, btnHome, urlTextBox, btnGo });

            // л¶Ғл§ҲнҒ¬ нҢЁл„җ
            bookmarkPanel = new FlowLayoutPanel { 
                Dock = DockStyle.Bottom, 
                Height = 45, 
                BackColor = Color.FromArgb(33, 38, 45),
                Padding = new Padding(15, 7, 10, 5)
            };

            void AddBookmark(string name, string url) {
                Button btn = new Button {
                    Text = name,
                    AutoSize = true,
                    Height = 26,
                    Font = new Font("Segoe UI", 9, FontStyle.Regular),
                    FlatStyle = FlatStyle.Flat,
                    BackColor = Color.FromArgb(22, 27, 34),
                    ForeColor = Color.FromArgb(139, 148, 158),
                    Cursor = Cursors.Hand
                };
                btn.FlatAppearance.BorderSize = 0;
                btn.Click += (s, e) => NavigateToUrl(url);
                bookmarkPanel.Controls.Add(btn);
            }

            AddBookmark("JWork Home", jworkHomeUrl);
            AddBookmark("GitHub", "https://github.com");
            AddBookmark("YouTube", "https://youtube.com");
            AddBookmark("Google", "https://google.com");
            AddBookmark("Naver", "https://naver.com");

            controlContainer.Controls.Add(navPanel);
            controlContainer.Controls.Add(bookmarkPanel);
            this.Controls.Add(controlContainer);

            webView = new WebView2 { Dock = DockStyle.Fill };
            this.Controls.Add(webView);
        }

        private async void InitializeWebView()
        {
            try
            {
                string extremeHqArguments = 
                    "--enable-gpu " +
                    "--ignore-gpu-blocklist " +
                    "--use-angle=d3d11on12 " + 
                    "--enable-gpu-rasterization " +
                    "--enable-oop-rasterization " +
                    "--enable-zero-copy " +
                    "--enable-features=UseSkiaRenderer,Vulkan,D3D11VideoDecoder,VaapiVideoDecoder " + 
                    "--video-decoding-color-space=rgba " +
                    "--high-dpi-support=1 " +
                    "--force-device-scale-factor=1.0 " + 
                    "--enable-hardware-overlays=single-fullscreen,underlay " +
                    "--enable-hdr " +
                    "--force-color-profile=srgb " +
                    "--max-gum-fps=144";

                var options = new CoreWebView2EnvironmentOptions(additionalBrowserArguments: extremeHqArguments);

                var env = await CoreWebView2Environment.CreateAsync(null, null, options);
                await webView.EnsureCoreWebView2Async(env);

                webView.SourceChanged += WebView_SourceChanged;
                NavigateToUrl(jworkHomeUrl);
            }
            catch (Exception ex)
            {
                MessageBox.Show("JWork Engine Error: " + ex.Message, "Error", MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void WebView_SourceChanged(object sender, CoreWebView2SourceChangedEventArgs e)
        {
            if (webView != null && webView.Source != null)
            {
                if (webView.Source.ToString().StartsWith("data:text/html"))
                {
                    urlTextBox.Text = jworkHomeUrl;
                }
                else
                {
                    urlTextBox.Text = webView.Source.ToString();
                }
            }
        }

        private void NavigateToUrl(string url)
        {
            if (webView?.CoreWebView2 == null) return;

            if (url.Equals(jworkHomeUrl, StringComparison.OrdinalIgnoreCase))
            {
                string customHtml = GetJWorkHomeHtml();
                webView.CoreWebView2.NavigateToString(customHtml);
                return;
            }

            if (!url.StartsWith("http://") && !url.StartsWith("https://"))
            {
                url = "https://" + url;
            }

            try
            {
                webView.CoreWebView2.Navigate(url);
            }
            catch (Exception ex)
            {
                MessageBox.Show("нҺҳмқҙм§Җ мқҙлҸҷ мҳӨлҘҳ: " + ex.Message, "Error", MessageBoxButtons.OK, MessageBoxIcon.Warning);
            }
        }


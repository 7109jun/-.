<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>메모펜 (MemoPen) - Windows 98 Plain Text Edition</title>
    <script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Nanum+Myeongjo&display=swap">
    <style>
        /* 1990년대 윈도우 클래식 OS 완전 고증 CSS 스타일 */
        body { background: #008080; margin: 0; padding: 20px; font-family: '굴림', Gulim, sans-serif; font-size: 12px; color: black; }
        
        .memopen-app { 
            max-width: 1200px; 
            margin: 0 auto; 
            background: #d4d0c8; 
            border: 2px solid;
            border-color: #fff #404040 #404040 #fff;
            padding: 2px;
        }
        
        /* 타이틀 바 */
        .title-bar { background: linear-gradient(90deg, #000080, #1084d0); color: white; padding: 3px 6px; font-weight: bold; font-size: 13px; display: flex; justify-content: space-between; align-items: center; }
        .title-bar-controls button { background: #d4d0c8; border: 1px solid; border-color: #fff #404040 #404040 #fff; min-width: 16px; height: 14px; font-size: 9px; font-weight: bold; cursor: pointer; padding: 0 2px; color: black; }
        .title-bar-controls button:active { border-color: #404040 #fff #fff #404040; }

        /* 클래식 메뉴 및 툴바 (이모지 전면 삭제) */
        .menu-bar { padding: 4px 6px; display: flex; gap: 12px; background: #d4d0c8; border-bottom: 1px solid #808080; }
        .menu-item { cursor: pointer; padding: 2px 6px; }
        .menu-item:hover { background: #000080; color: white; }
        
        .toolbar { background: #d4d0c8; padding: 6px 10px; border-bottom: 2px solid #808080; display: flex; gap: 6px; align-items: center; flex-wrap: wrap; }
        
        /* 90년대 회색 입체 버튼 스타일 */
        .toolbar button, .toolbar select { 
            background: #d4d0c8; 
            color: black; 
            border: 1px solid; 
            border-color: #fff #404040 #404040 #fff; 
            padding: 4px 10px; 
            cursor: pointer; 
            font-size: 12px; 
            font-family: '굴림', Gulim, sans-serif;
        }
        .toolbar button:active, .toolbar button.active { 
            background: #b5b0a5; 
            border-color: #404040 #fff #fff #404040; 
        }
        
        .color-picker-wrapper { display: flex; align-items: center; gap: 4px; background: #d4d0c8; padding: 2px; border: 1px solid; border-color: #404040 #fff #fff #404040; }
        .color-picker-wrapper input[type="color"] { border: none; width: 18px; height: 18px; cursor: pointer; background: none; padding: 0; }
        
        .stroke-counter { margin-left: auto; font-size: 12px; color: #000; background: #d4d0c8; padding: 4px 8px; border: 1px solid; border-color: #404040 #fff #fff #404040; }

        /* 대형 에디터 (완전 흰색 바탕에 굵은 테두리) */
        .editor-container { position: relative; width: 100%; height: 750px; background: white; border: 2px solid; border-color: #808080 #fff #fff #808080; }
        
        /* 기본 크기 26px 고정 및 폰트 변경 레이아웃 */
        textarea, canvas, .md-preview { position: absolute; top: 0; left: 0; width: 100%; height: 100%; box-sizing: border-box; padding: 20px; border: none; margin: 0; font-size: var(--zoom-size, 26px); line-height: 1.6; }
        
        textarea { resize: none; outline: none; background: transparent; color: black; z-index: 1; font-family: var(--font-style, sans-serif); }
        canvas { z-index: 2; pointer-events: none; } 
        
        .md-preview { z-index: 3; background: white; color: black; display: none; overflow-y: auto; font-family: var(--font-style, sans-serif); }
        .md-preview h1 { border-bottom: 1px solid #000; padding-bottom: 3px; font-size: 1.5em; }

        .pen-activated canvas { pointer-events: auto; cursor: crosshair; }
        .pen-activated textarea { user-select: none; } 

        /* 자동완성 드롭다운 (회색 투박한 레이아웃) */
        .autocomplete-box { position: absolute; background: white; border: 1px solid #000; box-shadow: 2px 2px 0px #808080; z-index: 999; display: none; width: 220px; list-style: none; padding: 0; margin: 0; font-size: 14px; font-family: var(--font-style, sans-serif); }
        .autocomplete-box li { padding: 6px 10px; cursor: pointer; color: black; border-bottom: 1px solid #d4d0c8; }
        .autocomplete-box li.active, .autocomplete-box li:hover { background: #000080; color: white; }
    </style>
</head>
<body>

<div class="memopen-app">
    <div class="title-bar">
        <span>바탕화면_저장용_메모펜.txt - 메모장</span>
        <div class="title-bar-controls">
            <button>_</button> <button>ㅁ</button> <button onclick="saveAndExit()">X</button>
        </div>
    </div>

    <div class="menu-bar">
        <div class="menu-item" onclick="newWindow()">파일(F)</div>
        <div class="menu-item" onclick="saveAsFile()">바탕화면에 저장(S)</div>
        <div class="menu-item" onclick="loadRecent()">열기(O)</div>
        <div class="menu-item" onclick="saveAndExit()">종료(X)</div>
    </div>

    <div class="toolbar">
        <button id="btn-text" class="active" onclick="setMode('text')">글쓰기</button>
        <button id="btn-pen" onclick="setMode('pen')">일반펜</button>
        <button id="btn-highlighter" onclick="setMode('highlighter')">형광펜</button>
        <button id="btn-fountain" onclick="setMode('fountain')">만년필</button>
        <button id="btn-md-toggle" onclick="toggleMarkdownMode()">마크다운 변환</button>
        
        <div class="color-picker-wrapper">
            <input type="color" id="hex-color" value="#000000">
            <span id="hex-text" style="font-family: monospace; font-size: 11px; font-weight: bold;">#000000</span>
        </div>
        
        <select id="font-select" onchange="changeFont()">
            <option value="sans-serif">기본글씨체</option>
            <option value="'D2Coding', monospace">D2 coding</option>
            <option value="'Nanum Myeongjo', serif">나눔명조</option>
        </select>

        <button onclick="zoom(2)">확대</button>
        <button onclick="zoom(-2)">축소</button>
        <button onclick="clearCanvas()">펜초기화</button>
        
        <span id="stroke-count" class="stroke-counter">펜 한도: 0 / 500</span>
    </div>

    <div class="editor-container" id="editor-wrapper">
        <textarea id="note-textarea" placeholder="글자 크기가 확대되었습니다. 내용을 적으세요. (자동완성: 대한민국, 메모장, 하늘, 컴퓨터)"></textarea>
        <div id="md-preview" class="md-preview"></div>
        <canvas id="note-canvas"></canvas>
        <ul id="suggestion-box" class="autocomplete-box"></ul>
    </div>
</div>

<script>
    const wrapper = document.getElementById('editor-wrapper');
    const textarea = document.getElementById('note-textarea');
    const mdPreview = document.getElementById('md-preview');
    const canvas = document.getElementById('note-canvas');
    const ctx = canvas.getContext('2d');
    const box = document.getElementById('suggestion-box');
    const strokeCountEl = document.getElementById('stroke-count');
    const hexColorInput = document.getElementById('hex-color');
    const hexText = document.getElementById('hex-text');
    const fontSelect = document.getElementById('font-select');

    let currentMode = 'text'; 
    let isDrawing = false;
    let isMarkdownView = false;
    let currentZoom = 26; 

    let strokeCount = 0;
    const maxStrokes = 500;
    let timerInterval = null;
    let lastX = 0; let lastY = 0;

    const mockCSVData = `대한민국\n메모장\n메모펜\n노트북\n하늘\n바다\n가을\n겨울\n컴퓨터\n개발자\n오픈소스\n깃허브`;
    let dictionary = mockCSVData.split('\n');

    window.addEventListener('load', () => { initCanvas(); updateColor(); changeFont(); });
    hexColorInput.addEventListener('input', updateColor);

    function initCanvas() {
        canvas.width = wrapper.clientWidth;
        canvas.height = wrapper.clientHeight;
    }

    function updateColor() { hexText.innerText = hexColorInput.value.toUpperCase(); }

    function hexToRgba(hex, alpha) {
        const r = parseInt(hex.slice(1, 3), 16);
        const g = parseInt(hex.slice(3, 5), 16);
        const b = parseInt(hex.slice(5, 7), 16);
        return `rgba(${r}, ${g}, ${b}, ${alpha})`;
    }

    function changeFont() { document.documentElement.style.setProperty('--font-style', fontSelect.value); }

    function zoom(amount) {
        currentZoom += amount;
        if(currentZoom < 14) currentZoom = 14;
        if(currentZoom > 60) currentZoom = 60;
        document.documentElement.style.setProperty('--zoom-size', currentZoom + 'px');
    }

    function setMode(mode) {
        if(isMarkdownView) toggleMarkdownMode();
        currentMode = mode;
        wrapper.classList.toggle('pen-activated', mode !== 'text');
        document.getElementById('btn-text').classList.toggle('active', mode === 'text');
        document.getElementById('btn-pen').classList.toggle('active', mode === 'pen');
        document.getElementById('btn-highlighter').classList.toggle('active', mode === 'highlighter');
        document.getElementById('btn-fountain').classList.toggle('active', mode === 'fountain');
    }

    // 0.05초 카운팅 타이머 펜 로직
    canvas.addEventListener('mousedown', (e) => {
        if (currentMode === 'text' || strokeCount >= maxStrokes) return;
        isDrawing = true;
        [lastX, lastY] = [e.offsetX, e.offsetY];
        ctx.beginPath();
        ctx.moveTo(e.offsetX, e.offsetY);

        timerInterval = setInterval(() => {
            if(isDrawing) {
                strokeCount++;
                strokeCountEl.innerText = `펜 한도: ${strokeCount} / ${maxStrokes}`;
                if (strokeCount >= maxStrokes) {
                    alert('펜 한도 도달!');
                    stopDrawing();
                    setMode('text');
                }
            }
        }, 50);
    });

    canvas.addEventListener('mousemove', (e) => {
        if (!isDrawing) return;
        ctx.lineCap = 'round'; ctx.lineJoin = 'round';
        const color = hexColorInput.value;

        if (currentMode === 'pen') {
            ctx.lineTo(e.offsetX, e.offsetY);
            ctx.strokeStyle = color; ctx.lineWidth = 3; ctx.stroke();
        } 
        else if (currentMode === 'highlighter') {
            ctx.lineTo(e.offsetX, e.offsetY);
            ctx.strokeStyle = hexToRgba(color, 0.4); ctx.lineWidth = 26; ctx.stroke();
        } 
        else if (currentMode === 'fountain') {
            ctx.beginPath(); ctx.moveTo(lastX, lastY); ctx.lineTo(e.offsetX, e.offsetY);
            ctx.strokeStyle = color;
            const distance = Math.sqrt(Math.pow(e.offsetX - lastX, 2) + Math.pow(e.offsetY - lastY, 2));
            ctx.lineWidth = Math.max(1, 8 - distance * 0.3); ctx.stroke();
        }
        [lastX, lastY] = [e.offsetX, e.offsetY];
    });

    window.addEventListener('mouseup', stopDrawing);
    function stopDrawing() { if (isDrawing) { isDrawing = false; clearInterval(timerInterval); } }

    function clearCanvas() {
        ctx.clearRect(0, 0, canvas.width, canvas.height);
        strokeCount = 0; strokeCountEl.innerText = `펜 한도: 0 / ${maxStrokes}`;
    }

    function toggleMarkdownMode() {
        isMarkdownView = !isMarkdownView;
        document.getElementById('btn-md-toggle').classList.toggle('active', isMarkdownView);
        if(isMarkdownView) {
            mdPreview.innerHTML = marked.parse(textarea.value);
            mdPreview.style.display = 'block'; textarea.style.display = 'none';
        } else {
            mdPreview.style.display = 'none'; textarea.style.display = 'block'; textarea.focus();
        }
    }

    /* ================= ★ 바탕화면 전용 .txt 저장 메커니즘 패치 ================= */
    
    // .txt 형태로 저장하되 내부 파일 구조 하단에 Base64 주석 분리 형태로 바인딩 처리!
    function saveAsFile() {
        const textData = textarea.value;
        const base64CanvasData = canvas.toDataURL("image/png");

        // 바탕화면에 저장하라는 암시를 주기 위해 파일명 기본값 세팅
        const filename = prompt("바탕화면에 저장할 파일명을 입력하십시오:", "바탕화면_메모펜_문서") + ".txt";
        if(!filename || filename.startsWith("null")) return;

        // .txt 텍스트 파일 내부에 유저 글과 Base64 데이터를 완벽히 공존시킴
        const fileContent = `${textData}\n\n====================================\n[MEMOPEN-IMAGE-DATA]\n${base64CanvasData}\n====================================\n[INFO]\nStroke:${strokeCount}\nFont:${fontSelect.value}`;

        const blob = new Blob([fileContent], { type: "text/plain;charset=utf-8" });
        const link = document.createElement("a");
        link.href = URL.createObjectURL(blob);
        link.download = filename;
        link.click();
        
        // 열기(O) 기능을 위한 로컬 백업 유지
        localStorage.setItem("last_txt_archive", JSON.stringify({text: textData, img: base64CanvasData, stroke: strokeCount, font: fontSelect.value}));
    }

    // 불러오기 기능
    function loadRecent() {
        const savedData = localStorage.getItem("last_txt_archive");
        if(savedData) {
            const data = JSON.parse(savedData);
            textarea.value = data.text;
            strokeCount = data.stroke || 0;
            strokeCountEl.innerText = `펜 한도: ${strokeCount} / ${maxStrokes}`;
            fontSelect.value = data.font || "sans-serif"; changeFont();

            const img = new Image();
            img.onload = function() { ctx.clearRect(0, 0, canvas.width, canvas.height); ctx.drawImage(img, 0, 0); };
            img.src = data.img;

            if(isMarkdownView) mdPreview.innerHTML = marked.parse(data.text);
            alert("텍스트와 펜의 데이터를 완전 복원했습니다.");
        } else {
            alert("가져올 문서 내역이 존재하지 않습니다.");
        }
    }

    function newWindow() { window.open(window.location.href, '_blank'); }
    function saveAndExit() { saveAsFile(); window.close(); }

    /* 자동완성 기본 시스템 */
    let matches = []; let activeIndex = 0; let currentWordStart = 0;
    textarea.addEventListener('input', () => {
        const text = textarea.value; const caretPos = textarea.selectionStart;
        const textBeforeCaret = text.substring(0, caretPos);
        const words = textBeforeCaret.split(/[\s\n]+/); const lastWord = words[words.length - 1];
        currentWordStart = caretPos - lastWord.length;
        if (lastWord.length > 0) {
            matches = dictionary.filter(word => word.trim().startsWith(lastWord));
            if (matches.length > 0) {
                box.innerHTML = ''; activeIndex = 0;
                matches.slice(0, 5).forEach((word, index) => {
                    const li = document.createElement('li'); li.innerText = word;
                    if (index === 0) li.classList.add('active');
                    li.onclick = () => selectWord(word); box.appendChild(li);
                });
                box.style.left = '25px'; box.style.bottom = '25px'; box.style.display = 'block'; return;
            }
        } box.style.display = 'none';
    });
    textarea.addEventListener('keydown', (e) => {
        if (box.style.display !== 'block') return; const items = box.querySelectorAll('li');
        if (e.key === 'ArrowDown') { e.preventDefault(); items[activeIndex].classList.remove('active'); activeIndex = (activeIndex + 1) % items.length; items[activeIndex].classList.add('active'); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); items[activeIndex].classList.remove('active'); activeIndex = (activeIndex - 1 + items.length) % items.length; items[activeIndex].classList.add('active'); }
        else if (e.key === 'Enter' || e.key === 'Tab') { e.preventDefault(); if (matches[activeIndex]) selectWord(matches[activeIndex]); }
        else if (e.key === 'Escape') { box.style.display = 'none'; }
    });
    function selectWord(word) {
        const text = textarea.value; const before = text.substring(0, currentWordStart); const after = text.substring(textarea.selectionStart);
        textarea.value = before + word.trim() + " " + after; const newPos = currentWordStart + word.trim().length + 1;
        textarea.setSelectionRange(newPos, newPos); box.style.display = 'none'; textarea.focus();
    }
</script>
</body>
</html>

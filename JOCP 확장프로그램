const JOCP = (function() {
  'use strict';

  // 정규식 최적화 및 기호 뒤 한 칸 띄어쓰기(\s) 필수 규칙 반영 완료
  const REGEX = {
    heading: /^(!+)\s+(.*)$/,          // ! 뒤 스페이스 필수
    table: /^#\s/,                     // # 뒤 스페이스 필수
    listUnordered: /^(\*+)\s+(.*)$/,   // * 뒤 스페이스 필수
    listOrdered: /^(\d+)\s+(.*)$/,     // 숫자 뒤 스페이스 필수
    checkboxTodo: /^\+\s+(.*)$/,       // + 뒤 스페이스 필수
    checkboxDone: /^@\s+(.*)$/,       // @ 뒤 스페이스 필수
    hr: /^-\s*$/,
    copyBlock: /^~\s*$/,
    
    // 간섭 방지용 비탐욕(Lazy) 멀티라인 정규식
    inlineComment: /%%[\s\S]*?%%/g,
    inlineImage: /!\{([\s\S]+?)\}/g,
    inlineHyperlink: /=([\s\S]+?)=\[([\s\S]+?)\]/g,
    inlineAnchor: /\[([\s\S]+?)\]\[([\s\S]+?)\]/g,
    inlineLink: /\[\[([\s\S]+?)\]\]/g,
    inlineQuote: /&([\s\S]+?)&/g,
    inlineBoldUnder: /`([\s\S]+?)`/g,
    inlineColor: /\?([\s\S]+?)\?<(\d+,\d+,\d+)>/g,
    inlineOpacity: /\^([\s\S]+?)\^(\d+)%/g,
    inlineBold: /\{([\s\S]+?)\}/g,
    inlineItalic: /~([\s\S]+?)~/g,
    inlineDel: /_([\s\S]+?)_/g
  };

  function escapeHtml(text) {
    const map = { '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#039;' };
    return text.replace(/[&<>"']/g, m => map[m]);
  }

  function slugify(text) {
    return text.replace(/\s+/g, '-').replace(/[^\w-가-힣]/g, '');
  }

  function parseInline(text) {
    const tokens = [];
    const store = (html) => {
      const token = `\x1A_JOCP_${tokens.length}_\x1A`;
      tokens.push(html);
      return token;
    };

    // 1단계: 주석 및 인용구 선추출
    text = text.replace(REGEX.inlineComment, '');
    text = text.replace(REGEX.inlineQuote, (m, content) => store(`<blockquote>${content}</blockquote>`));

    // 2단계: HTML 태그 이스케이프 (보안 처리)
    text = escapeHtml(text);

    // 3단계: 구조 및 하이퍼링크 매핑
    text = text.replace(REGEX.inlineImage, (m, src) => store(`<img src="${src}" alt="image" style="max-width:100%;" />`));
    text = text.replace(REGEX.inlineHyperlink, (m, label, url) => store(`<a href="${url}" target="_blank">${label}</a>`));
    text = text.replace(REGEX.inlineAnchor, (m, target, label) => store(`<a href="#${slugify(target)}" class="jocp-anchor">${label}</a>`));
    text = text.replace(REGEX.inlineLink, (m, url) => store(`<a href="${url}" target="_blank">${url}</a>`));

    // 4단계: 스타일링 적용
    text = text.replace(REGEX.inlineBoldUnder, (m, content) => store(`<ins><strong>${content}</strong></ins>`));
    text = text.replace(REGEX.inlineColor, (m, content, rgb) => store(`<span style="color:rgb(${rgb})">${content}</span>`));
    text = text.replace(REGEX.inlineOpacity, (m, content, percent) => store(`<span style="opacity:${percent/100}">${content}</span>`));
    text = text.replace(REGEX.inlineBold, (m, content) => store("<strong>" + content + "</strong>"));
    text = text.replace(REGEX.inlineItalic, (m, content) => store(`<em>${content}</em>`));
    text = text.replace(REGEX.inlineDel, (m, content) => store(`<del>${content}</del>`));

    // 5단계: 토큰 복원
    return text.replace(/\x1A_JOCP_(\d+)_\x1A/g, (m, idx) => tokens[parseInt(idx)]);
  }

  function parseBlock(lines) {
    let html = '';
    let i = 0;

    while (i < lines.length) {
      const line = lines[i];

      // 1. 복사 블록
      if (REGEX.copyBlock.test(line)) {
        let content = '';
        i++;
        while (i < lines.length && !REGEX.copyBlock.test(lines[i])) {
          content += lines[i] + '\n';
          i++;
        }
        i++;
        html += `<div class="jocp-copy-block">
                   <button class="copy-btn">복사</button>
                   <pre><code>${escapeHtml(content.trim())}</code></pre>
                 </div>`;
        continue;
      }

      // 2. 테이블
      if (REGEX.table.test(line)) {
        let rows = [];
        while (i < lines.length && REGEX.table.test(lines[i])) {
          rows.push(lines[i].split('#').map(c => c.trim()).filter(c => c !== ''));
          i++;
        }
        html += '<table>';
        rows.forEach((row, idx) => {
          const tag = idx === 0 ? 'th' : 'td';
          html += '<tr>' + row.map(cell => `<${tag}>${parseInline(cell)}</${tag}>`).join('') + '</tr>';
        });
        html += '</table>';
        continue;
      }

      // 3. 순서 없는 리스트 (* 뒤 공백 필수 적용)
      if (REGEX.listUnordered.test(line)) {
        let listHtml = '<ul>';
        let prevLevel = 0;
        while (i < lines.length && REGEX.listUnordered.test(lines[i])) {
          const match = lines[i].match(REGEX.listUnordered);
          const level = match[1].length;
          const content = match[2];
          
          if (level > prevLevel) {
            for (let j = 0; j < level - prevLevel; j++) listHtml += '<ul>';
          } else if (level < prevLevel) {
            for (let j = 0; j < prevLevel - level; j++) listHtml += '</ul>';
          }
          
          listHtml += `<li>${parseInline(content)}</li>`;
          prevLevel = level;
          i++;
        }
        for (let j = 0; j < prevLevel; j++) listHtml += '</ul>';
        html += listHtml;
        continue;
      }

      // 4. 제목 체계
      if (REGEX.heading.test(line)) {
        const match = line.match(REGEX.heading);
        const level = Math.max(1, 7 - match[1].length);
        const title = match[2];
        html += `<h${level} id="${slugify(title)}">${parseInline(title)}</h${level}>`;
        i++;
        continue;
      }

      if (line.trim() === '') { i++; continue; }

      // 스페이스 규칙에 맞지 않는 텍스트는 일반 본문으로 안전하게 처리
      html += `<p>${parseInline(line)}</p>`;
      i++;
    }
    return html;
  }

  return {
    parse: function(text) { return parseBlock(text.split('\n')); },
    render: function(inputId, previewId) {
      const input = document.getElementById(inputId);
      const preview = document.getElementById(previewId);
      if (!input || !preview) return;

      const update = () => { preview.innerHTML = this.parse(input.value); };
      input.addEventListener('input', update);
      update();

      preview.addEventListener('click', (e) => {
        if (e.target.classList.contains('copy-btn')) {
          const code = e.target.parentElement.querySelector('code').innerText;
          navigator.clipboard.writeText(code).then(() => {
            const originalText = e.target.textContent;
            e.target.textContent = '완료! ✔';
            setTimeout(() => { e.target.textContent = originalText; }, 1500);
          });
        }
      });
    }
  };
})();

function downloadFile(content, fileName, contentType) {
  const a = document.createElement("a");
  const file = new Blob([content], { type: contentType });
  a.href = URL.createObjectURL(file);
  a.download = fileName;
  a.click();
  URL.revokeObjectURL(a.href);
}

document.addEventListener('DOMContentLoaded', () => {
  const input = document.getElementById('jocp-input');
  const preview = document.getElementById('jocp-preview');
  
  JOCP.render('jocp-input', 'jocp-preview');

  document.getElementById('btn-export-txt').addEventListener('click', () => {
    downloadFile(input.value, 'document.jocp', 'text/plain');
  });

  document.getElementById('btn-export-html').addEventListener('click', () => {
    const fullHtml = `<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <title>JOCP Rendered Document</title>
  <style>
    body { font-family: sans-serif; max-width: 800px; margin: 40px auto; padding: 0 20px; line-height: 1.6; }
    .jocp-copy-block { position: relative; background: #1e1e1e; color: #d4d4d4; padding: 12px; border-radius: 6px; margin: 10px 0; }
    .jocp-copy-block pre { margin: 0; }
    .copy-btn { display: none; }
    blockquote { border-left: 4px solid #4a9eff; padding: 8px 12px; background: #eef7ff; margin: 10px 0; font-style: italic; }
    table { border-collapse: collapse; width: 100%; margin: 10px 0; }
    th, td { border: 1px solid #e0e0e0; padding: 8px; text-align: left; }
    th { background: #f0f0f0; }
  </style>
</head>
<body>
  ${preview.innerHTML}
</body>
</html>`;
    downloadFile(fullHtml, 'document.html', 'text/html');
  });
});

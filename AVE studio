<script>
// ==========================================
// 1. 사운드 및 애니메이션 엔진
// ==========================================
let soundEnabled = true;
const audioCtx = new (window.AudioContext || window.webkitAudioContext)();

function toggleSound() {
  soundEnabled = !soundEnabled;
  const btn = document.getElementById('soundToggle');
  btn.textContent = soundEnabled ? '🔊 사운드 ON' : '🔇 사운드 OFF';
  btn.classList.toggle('active', soundEnabled);
}

function playTone(freq, type, duration, delay = 0) {
  if (!soundEnabled) return;
  if (audioCtx.state === 'suspended') audioCtx.resume();
  const osc = audioCtx.createOscillator();
  const gain = audioCtx.createGain();
  osc.type = type;
  osc.frequency.setValueAtTime(freq, audioCtx.currentTime + delay);
  gain.gain.setValueAtTime(0.08, audioCtx.currentTime + delay);
  gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + delay + duration);
  osc.connect(gain); gain.connect(audioCtx.destination);
  osc.start(audioCtx.currentTime + delay);
  osc.stop(audioCtx.currentTime + delay + duration);
}

function playSound(type) {
  if (type === 'start') { playTone(440, 'sine', 0.1); playTone(880, 'sine', 0.2, 0.1); }
  else if (type === 'success') { playTone(523.25, 'triangle', 0.1); playTone(659.25, 'triangle', 0.1, 0.1); playTone(783.99, 'triangle', 0.3, 0.2); }
  else if (type === 'error') { playTone(150, 'sawtooth', 0.3); playTone(100, 'sawtooth', 0.4, 0.2); }
  else if (type === 'type') { playTone(800 + Math.random()*400, 'sine', 0.03); }
}

async function highlightASTNode(nodeId) {
  const el = document.getElementById(nodeId);
  if (el) {
    el.classList.add('highlight');
    playSound('type');
    await new Promise(r => setTimeout(r, 150));
    el.classList.remove('highlight');
  }
}

// ==========================================
// 2. 상태 관리
// ==========================================
const defaultCode = `// AVE Final Edition 예제
let x = 10
let y = 20
let result = x + y * 2

출력 "결과: " + result

// 함수 정의
함수 팩토리얼(n) {
  만약 n <= 1 {
    반환 1
  }
  반환 n * 팩토리얼(n - 1)
}

출력 "5! = " + 팩토리얼(5)

// for 루프
let sum = 0
for (let i = 1; i <= 5; i = i + 1) {
  sum = sum + i
}
출력 "1~5 합: " + sum

// Escape 문자
출력 "줄바꿈:\\n탭:\\t끝"`;

function getConfig() {
  return {
    name: document.getElementById('infoName').value || 'AVE',
    version: document.getElementById('infoVersion').value || '1.0.0',
    ext: document.getElementById('infoExt').value || '.astvse',
    author: document.getElementById('infoAuthor').value || 'Developer',
    keywords: document.getElementById('cfgKeywords').value.split(',').map(s => s.trim()).filter(Boolean),
    operators: document.getElementById('cfgOperators').value.split(',').map(s => s.trim()).filter(Boolean).sort((a,b) => b.length - a.length),
    types: document.getElementById('cfgTypes').value.split(',').map(s => s.trim()).filter(Boolean),
    comment: document.getElementById('cfgComment').value,
    quote: document.getElementById('cfgQuote').value,
  };
}

function toggleAccordion(header) { header.parentElement.classList.toggle('open'); }

function checkCollisions(cfg) {
  const allTokens = [...cfg.keywords, ...cfg.operators, ...cfg.types];
  const duplicates = [...new Set(allTokens.filter((item, index) => allTokens.indexOf(item) !== index))];
  const banner = document.getElementById('collisionWarning');
  if (duplicates.length > 0) {
    banner.classList.add('show');
    document.getElementById('collisionText').textContent = `"${duplicates.join(', ')}"가 중복 정의되었습니다.`;
  } else { banner.classList.remove('show'); }
}

// ==========================================
// 3. Lexer (Escape 지원, 정확한 Line/Column)
// ==========================================
class LexerError extends Error {
  constructor(msg, line, col) { super(msg); this.line = line; this.col = col; }
}

function tokenize(code, cfg) {
  const tokens = [];
  let i = 0, line = 1, col = 1;
  
  while (i < code.length) {
    const startPos = { line, col };
    
    if (code[i] === ' ' || code[i] === '\t') {
      tokens.push({ type: 't-ws', value: code[i], ...startPos }); col++; i++; continue;
    }
    if (code[i] === '\n') {
      tokens.push({ type: 't-ws', value: '\n', ...startPos }); line++; col = 1; i++; continue;
    }
    if (code[i] === '\r') { i++; continue; }
    
    // 주석
    if (code.startsWith(cfg.comment, i)) {
      let end = code.indexOf('\n', i); if (end === -1) end = code.length;
      tokens.push({ type: 't-cmt', value: code.slice(i, end), ...startPos });
      col += (end - i); i = end; continue;
    }

    // 문자열 (Escape 지원)
    if (code[i] === cfg.quote) {
      let j = i + 1;
      let value = cfg.quote;
      while (j < code.length && code[j] !== cfg.quote) {
        if (code[j] === '\\' && j + 1 < code.length) {
          value += code[j] + code[j+1];
          j += 2;
        } else {
          value += code[j];
          j++;
        }
      }
      if (j >= code.length) throw new LexerError(`닫히지 않은 문자열입니다.`, startPos.line, startPos.col);
      value += cfg.quote;
      tokens.push({ type: 't-str', value, ...startPos });
      col += (j - i + 1); i = j + 1; continue;
    }

    // 숫자 (엄격 검사)
    if (/[0-9]/.test(code[i])) {
      let j = i;
      if (code[i] === '0' && /[xb]/.test(code[i+1])) {
        j += 2;
        while (j < code.length && /[0-9a-fA-F]/.test(code[j])) j++;
      } else {
        while (j < code.length && /[0-9.]/.test(code[j])) j++;
        if ((code.slice(i, j).match(/\./g) || []).length > 1) {
          throw new LexerError(`잘못된 숫자 형식: '${code.slice(i, j)}'`, startPos.line, startPos.col);
        }
      }
      tokens.push({ type: 't-num', value: code.slice(i, j), ...startPos });
      col += (j - i); i = j; continue;
    }

    // 연산자
    let opMatch = false;
    for (let op of cfg.operators) {
      if (code.startsWith(op, i)) {
        tokens.push({ type: 't-op', value: op, ...startPos });
        col += op.length; i += op.length; opMatch = true; break;
      }
    }
    if (opMatch) continue;

    // 괄호 및 구분자
    if (['{','}','(',')','[',']',',',';'].includes(code[i])) {
      tokens.push({ type: 't-brk', value: code[i], ...startPos }); col++; i++; continue;
    }

    // 식별자/키워드
    if (/[a-zA-Z_가-힣]/.test(code[i])) {
      let j = i;
      while (j < code.length && /[a-zA-Z0-9_가-힣]/.test(code[j])) j++;
      const word = code.slice(i, j);
      let type = 't-id';
      if (cfg.keywords.includes(word)) type = 't-kw';
      else if (cfg.types.includes(word)) type = 't-type';
      tokens.push({ type, value: word, ...startPos });
      col += (j - i); i = j; continue;
    }

    tokens.push({ type: 't-unknown', value: code[i], ...startPos }); col++; i++;
  }
  return tokens;
}

function handleInput() {
  const code = document.getElementById('codeEditor').value;
  const cfg = getConfig();
  try {
    const tokens = tokenize(code, cfg);
    let html = '';
    tokens.forEach(t => {
      let val = t.value.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;');
      html += t.type === 't-ws' ? val : `<span class="${t.type}">${val}</span>`;
    });
    document.getElementById('highlightLayer').innerHTML = html;
  } catch (e) { /* 실시간 입력 중 오류는 무시 */ }
}

function syncScroll() {
  const editor = document.getElementById('codeEditor');
  const hl = document.getElementById('highlightLayer');
  hl.scrollTop = editor.scrollTop; hl.scrollLeft = editor.scrollLeft;
}

// ==========================================
// 4. Parser (Recursive Descent + Pratt)
// ==========================================
class ParseError extends Error {
  constructor(msg, line, col) { super(msg); this.line = line; this.col = col; }
}

class Parser {
  constructor(tokens, cfg) {
    this.tokens = tokens.filter(t => t.type !== 't-ws');
    this.cfg = cfg;
    this.pos = 0;
    // 키워드 인덱스 매핑
    this.kw = {
      print: cfg.keywords[0], if: cfg.keywords[1], else: cfg.keywords[2],
      while: cfg.keywords[3], func: cfg.keywords[4], return: cfg.keywords[5],
      let: cfg.keywords[6], for: cfg.keywords[7], break: cfg.keywords[8], continue: cfg.keywords[9]
    };
  }

  peek(offset = 0) { return this.tokens[this.pos + offset]; }
  consume() { return this.tokens[this.pos++]; }
  expect(type, value) {
    const t = this.peek();
    if (!t || t.type !== type || (value && t.value !== value)) {
      throw new ParseError(`예상: ${type} ${value || ''}, 실제: ${t ? t.value : 'EOF'}`, t ? t.line : '?', t ? t.col : '?');
    }
    return this.consume();
  }

  parseProgram() {
    let body = [];
    while (this.pos < this.tokens.length) {
      body.push(this.parseStatement());
    }
    return { type: 'Program', body };
  }

  parseStatement() {
    const t = this.peek();
    if (!t) return null;

    // let 변수 선언: let ID = Expr
    if (t.type === 't-kw' && t.value === this.kw.let) {
      this.consume();
      const name = this.expect('t-id').value;
      this.expect('t-op', '=');
      return { type: 'VariableDeclaration', name, value: this.parseExpression(), line: t.line };
    }

    // 출력
    if (t.type === 't-kw' && t.value === this.kw.print) {
      this.consume();
      return { type: 'PrintStatement', expression: this.parseExpression(), line: t.line };
    }
    
    // 만약
    if (t.type === 't-kw' && t.value === this.kw.if) {
      this.consume();
      const condition = this.parseExpression();
      this.expect('t-brk', '{');
      const consequent = this.parseBlock();
      let alternate = null;
      if (this.peek()?.type === 't-kw' && this.peek().value === this.kw.else) {
        this.consume();
        this.expect('t-brk', '{');
        alternate = this.parseBlock();
      }
      return { type: 'IfStatement', condition, consequent, alternate, line: t.line };
    }

    // 반복 (while)
    if (t.type === 't-kw' && t.value === this.kw.while) {
      this.consume();
      const condition = this.parseExpression();
      this.expect('t-brk', '{');
      const body = this.parseBlock();
      return { type: 'WhileStatement', condition, body, line: t.line };
    }

    // for (init; cond; update) { body }
    if (t.type === 't-kw' && t.value === this.kw.for) {
      this.consume();
      this.expect('t-brk', '(');
      let init = null;
      if (this.peek().value !== ';') {
        if (this.peek().type === 't-kw' && this.peek().value === this.kw.let) {
          this.consume();
          const name = this.expect('t-id').value;
          this.expect('t-op', '=');
          init = { type: 'VariableDeclaration', name, value: this.parseExpression() };
        } else {
          init = this.parseExpression();
        }
      }
      this.expect('t-brk', ';');
      let condition = null;
      if (this.peek().value !== ';') condition = this.parseExpression();
      this.expect('t-brk', ';');
      let update = null;
      if (this.peek().value !== ')') update = this.parseExpression();
      this.expect('t-brk', ')');
      this.expect('t-brk', '{');
      const body = this.parseBlock();
      return { type: 'ForStatement', init, condition, update, body, line: t.line };
    }

    // 함수
    if (t.type === 't-kw' && t.value === this.kw.func) {
      this.consume();
      const name = this.expect('t-id').value;
      this.expect('t-brk', '(');
      const params = [];
      if (this.peek().value !== ')') {
        params.push(this.expect('t-id').value);
        while (this.peek()?.value === ',') { this.consume(); params.push(this.expect('t-id').value); }
      }
      this.expect('t-brk', ')');
      this.expect('t-brk', '{');
      const body = this.parseBlock();
      return { type: 'FunctionDeclaration', name, params, body, line: t.line };
    }

    // 반환
    if (t.type === 't-kw' && t.value === this.kw.return) {
      this.consume();
      let value = null;
      if (this.peek() && this.peek().value !== '}' && this.peek().value !== ';') {
        value = this.parseExpression();
      }
      return { type: 'ReturnStatement', value, line: t.line };
    }

    // break / continue
    if (t.type === 't-kw' && t.value === this.kw.break) {
      this.consume();
      return { type: 'BreakStatement', line: t.line };
    }
    if (t.type === 't-kw' && t.value === this.kw.continue) {
      this.consume();
      return { type: 'ContinueStatement', line: t.line };
    }

    // 할당 또는 표현식 문장
    return this.parseExpressionStatement();
  }

  parseBlock() {
    const stmts = [];
    while (this.peek() && this.peek().value !== '}') {
      stmts.push(this.parseStatement());
    }
    this.expect('t-brk', '}');
    return stmts;
  }

  parseExpressionStatement() {
    const expr = this.parseExpression();
    // 할당: ID = Expr
    if (expr.type === 'Identifier' && this.peek()?.type === 't-op' && this.peek().value === '=') {
      this.consume();
      return { type: 'AssignmentExpression', name: expr.name, value: this.parseExpression(), line: expr.line };
    }
    return { type: 'ExpressionStatement', expression: expr, line: expr.line };
  }

  getPrecedence(op) {
    const p = { '||': 1, '&&': 2, '==': 3, '!=': 3, '>': 4, '<': 4, '>=': 4, '<=': 4, '+': 5, '-': 5, '*': 6, '/': 6, '%': 6 };
    return p[op] || 0;
  }

  parseExpression() { return this.parseBinary(0); }

  parseBinary(minPrec) {
    let left = this.parseUnary();
    while (this.peek()?.type === 't-op' && this.getPrecedence(this.peek().value) >= minPrec) {
      const op = this.consume().value;
      const right = this.parseBinary(this.getPrecedence(op) + 1);
      left = { type: 'BinaryExpression', operator: op, left, right, line: left.line };
    }
    return left;
  }

  parseUnary() {
    const t = this.peek();
    if (t?.type === 't-op' && t.value === '!') {
      this.consume();
      return { type: 'UnaryExpression', operator: '!', argument: this.parseUnary(), line: t.line };
    }
    if (t?.type === 't-op' && t.value === '-') {
      this.consume();
      return { type: 'UnaryExpression', operator: '-', argument: this.parseUnary(), line: t.line };
    }
    return this.parsePrimary();
  }

  parsePrimary() {
    const t = this.peek();
    if (!t) throw new ParseError("예상치 못한 EOF", '?', '?');

    if (t.type === 't-num') {
      this.consume();
      return { type: 'Literal', valueType: 'Number', value: t.value, line: t.line };
    }
    if (t.type === 't-str') {
      this.consume();
      // Escape 처리
      const raw = t.value.slice(1, -1);
      const processed = raw.replace(/\\n/g, '\n').replace(/\\t/g, '\t').replace(/\\r/g, '\r').replace(/\\\\/g, '\\').replace(new RegExp(`\\\\${this.cfg.quote}`, 'g'), this.cfg.quote);
      return { type: 'Literal', valueType: 'String', value: processed, line: t.line };
    }
    if (t.type === 't-id') {
      this.consume();
      if (this.peek()?.value === '(') {
        this.consume();
        const args = [];
        if (this.peek().value !== ')') {
          args.push(this.parseExpression());
          while (this.peek()?.value === ',') { this.consume(); args.push(this.parseExpression()); }
        }
        this.expect('t-brk', ')');
        return { type: 'CallExpression', callee: t.value, arguments: args, line: t.line };
      }
      return { type: 'Identifier', name: t.value, line: t.line };
    }
    if (t.value === '(') {
      this.consume();
      const expr = this.parseExpression();
      this.expect('t-brk', ')');
      return expr;
    }
    if (t.value === '[') {
      this.consume();
      const elements = [];
      if (this.peek().value !== ']') {
        elements.push(this.parseExpression());
        while (this.peek()?.value === ',') { this.consume(); elements.push(this.parseExpression()); }
      }
      this.expect('t-brk', ']');
      return { type: 'ArrayLiteral', elements, line: t.line };
    }
    
    throw new ParseError(`예상치 못한 토큰: '${t.value}'`, t.line, t.col);
  }
}

// ==========================================
// 5. Interpreter (Signal 기반 제어 흐름)
// ==========================================
class ReturnSignal { constructor(value) { this.value = value; } }
class BreakSignal {}
class ContinueSignal {}

class Environment {
  constructor(parent = null) {
    this.vars = {};
    this.parent = parent;
    this.functions = {};
  }
  define(name, value) { this.vars[name] = value; }
  get(name) { 
    if (name in this.vars) return this.vars[name];
    if (this.parent) return this.parent.get(name);
    throw new Error(`정의되지 않은 변수: ${name}`);
  }
  assign(name, value) {
    if (name in this.vars) { this.vars[name] = value; return; }
    if (this.parent) { this.parent.assign(name, value); return; }
    throw new Error(`정의되지 않은 변수: ${name}`);
  }
  defineFunc(name, func) { this.functions[name] = func; }
  getFunc(name) {
    if (name in this.functions) return this.functions[name];
    if (this.parent) return this.parent.getFunc(name);
    throw new Error(`정의되지 않은 함수: ${name}`);
  }
}

class Interpreter {
  constructor(cfg, onNodeVisit) {
    this.cfg = cfg;
    this.globalEnv = new Environment();
    this.onNodeVisit = onNodeVisit;
    this.iterationLimit = 100000;
    this.iterationCount = 0;
  }

  async interpret(ast) {
    this.output = [];
    this.iterationCount = 0;
    for (const node of ast.body) {
      await this.evaluate(node, this.globalEnv);
    }
    return this.output;
  }

  checkIteration() {
    this.iterationCount++;
    if (this.iterationCount > this.iterationLimit) {
      throw new Error(`무한 루프 감지! (${this.iterationLimit}회 초과)`);
    }
  }

  async evaluate(node, env) {
    if (!node) return undefined;
    if (this.onNodeVisit && node._astId) await this.onNodeVisit(node._astId);

    switch (node.type) {
      case 'Program':
        for (const n of node.body) await this.evaluate(n, env);
        break;
      case 'VariableDeclaration':
        env.define(node.name, await this.evaluate(node.value, env));
        break;
      case 'AssignmentExpression':
        env.assign(node.name, await this.evaluate(node.value, env));
        break;
      case 'PrintStatement':
        this.output.push(String(await this.evaluate(node.expression, env)));
        break;
      case 'IfStatement':
        if (await this.evaluate(node.condition, env)) {
          for (const n of node.consequent) await this.evaluate(n, env);
        } else if (node.alternate) {
          for (const n of node.alternate) await this.evaluate(n, env);
        }
        break;
      case 'WhileStatement':
        while (await this.evaluate(node.condition, env)) {
          this.checkIteration();
          try {
            for (const n of node.body) await this.evaluate(n, env);
          } catch (e) {
            if (e instanceof BreakSignal) break;
            if (e instanceof ContinueSignal) continue;
            throw e;
          }
        }
        break;
      case 'ForStatement':
        const forEnv = new Environment(env);
        if (node.init) await this.evaluate(node.init, forEnv);
        while (!node.condition || await this.evaluate(node.condition, forEnv)) {
          this.checkIteration();
          try {
            for (const n of node.body) await this.evaluate(n, forEnv);
          } catch (e) {
            if (e instanceof BreakSignal) break;
            if (e instanceof ContinueSignal) { /* fall through to update */ }
            else throw e;
          }
          if (node.update) await this.evaluate(node.update, forEnv);
        }
        break;
      case 'FunctionDeclaration':
        env.defineFunc(node.name, node);
        break;
      case 'ReturnStatement':
        throw new ReturnSignal(node.value ? await this.evaluate(node.value, env) : undefined);
      case 'BreakStatement':
        throw new BreakSignal();
      case 'ContinueStatement':
        throw new ContinueSignal();
      case 'ExpressionStatement':
        await this.evaluate(node.expression, env);
        break;
      case 'BinaryExpression':
        const l = await this.evaluate(node.left, env);
        const r = await this.evaluate(node.right, env);
        const op = node.operator;
        if (op === '+') return (typeof l === 'string' || typeof r === 'string') ? String(l) + String(r) : l + r;
        if (op === '-') return l - r;
        if (op === '*') return l * r;
        if (op === '/') return l / r;
        if (op === '%') return l % r;
        if (op === '==') return l == r;
        if (op === '!=') return l != r;
        if (op === '>') return l > r;
        if (op === '<') return l < r;
        if (op === '>=') return l >= r;
        if (op === '<=') return l <= r;
        if (op === '&&') return l && r;
        if (op === '||') return l || r;
        break;
      case 'UnaryExpression':
        if (node.operator === '!') return !await this.evaluate(node.argument, env);
        if (node.operator === '-') return -await this.evaluate(node.argument, env);
        break;
      case 'Literal':
        return node.valueType === 'Number' ? parseFloat(node.value) : node.value;
      case 'Identifier':
        return env.get(node.name);
      case 'ArrayLiteral':
        const arr = [];
        for (const el of node.elements) arr.push(await this.evaluate(el, env));
        return arr;
      case 'CallExpression':
        const func = env.getFunc(node.callee);
        const newEnv = new Environment(env);
        func.params.forEach((p, i) => {
          newEnv.define(p, await this.evaluate(node.arguments[i], env));
        });
        try {
          for (const n of func.body) await this.evaluate(n, newEnv);
        } catch (e) {
          if (e instanceof ReturnSignal) return e.value;
          throw e;
        }
        return undefined;
    }
    return undefined;
  }
}

// ==========================================
// 6. AST 렌더러 (ID 부여, 하이라이트 연결)
// ==========================================
let astIdCounter = 0;
function renderAST(node, idPrefix = 'node') {
  if (!node) return '';
  const nodeId = idPrefix + '-' + (astIdCounter++);
  node._astId = nodeId; // 실행 시 하이라이트용 ID 저장
  
  let content = `<span class="ast-type">${node.type}</span>`;
  if (node.name) content += ` <span class="ast-key">name:</span> <span class="ast-val">"${node.name}"</span>`;
  if (node.valueType) content += ` <span class="ast-key">value:</span> <span class="ast-val">${JSON.stringify(node.value)}</span>`;
  if (node.operator) content += ` <span class="ast-key">op:</span> <span class="ast-val">"${node.operator}"</span>`;
  if (node.callee) content += ` <span class="ast-key">callee:</span> <span class="ast-val">"${node.callee}"</span>`;
  if (node.line) content += ` <span class="log-line">(L${node.line})</span>`;

  let html = `<div id="${nodeId}" class="ast-node">` + content;
  
  const renderChild = (child, suffix) => {
    if (child && typeof child === 'object' && child.type) return renderAST(child, nodeId + suffix);
    return '';
  };

  if (node.body && Array.isArray(node.body)) {
    node.body.forEach((child, i) => { html += renderChild(child, '-b' + i); });
  }
  html += renderChild(node.left, '-l');
  html += renderChild(node.right, '-r');
  html += renderChild(node.argument, '-a');
  html += renderChild(node.value, '-v');
  html += renderChild(node.condition, '-cnd');
  html += renderChild(node.init, '-init');
  html += renderChild(node.update, '-upd');
  
  if (node.arguments) {
    html += `<div class="ast-node"><span class="ast-key">arguments</span>`;
    node.arguments.forEach((arg, i) => { html += renderChild(arg, '-arg' + i); });
    html += `</div>`;
  }
  if (node.elements) {
    html += `<div class="ast-node"><span class="ast-key">elements</span>`;
    node.elements.forEach((el, i) => { html += renderChild(el, '-el' + i); });
    html += `</div>`;
  }
  if (node.consequent) {
    html += `<div class="ast-node"><span class="ast-key">consequent</span>`;
    node.consequent.forEach((c, i) => { html += renderChild(c, '-csq' + i); });
    html += `</div>`;
  }
  if (node.alternate) {
    html += `<div class="ast-node"><span class="ast-key">alternate</span>`;
    node.alternate.forEach((c, i) => { html += renderChild(c, '-alt' + i); });
    html += `</div>`;
  }
  
  html += `</div>`;
  return html;
}

// ==========================================
// 7. 메인 실행
// ==========================================
async function runCode() {
  const outputBox = document.getElementById('outputBox');
  const astOutput = document.getElementById('astOutput');
  outputBox.innerHTML = '';
  astOutput.innerHTML = '<span class="log-info">파싱 중...</span>';
  
  const code = document.getElementById('codeEditor').value;
  const cfg = getConfig();
  
  try {
    playSound('start');
    astIdCounter = 0;
    
    const tokens = tokenize(code, cfg);
    const parser = new Parser(tokens, cfg);
    const ast = parser.parseProgram();
    
    // AST 렌더링
    astOutput.innerHTML = `<div class="ast-root">Program</div>` + renderAST(ast);
    
    // Interpreter 실행
    const interpreter = new Interpreter(cfg, async (nodeId) => {
      await highlightASTNode(nodeId);
    });
    
    const results = await interpreter.interpret(ast);
    
    outputBox.innerHTML = `<span class="log-success">🚀 실행 완료! (${interpreter.iterationCount} iterations)</span>\n<span style="color:#666">-------------------</span>\n`;
    results.forEach(line => { outputBox.innerHTML += `<div>${line}</div>`; });
    playSound('success');
    
  } catch (e) {
    const lineInfo = e.line ? ` (Line ${e.line}, Col ${e.col})` : '';
    astOutput.innerHTML = `<span class="log-error">❌ 오류: ${e.message}${lineInfo}</span>`;
    outputBox.innerHTML = `<span class="log-error">❌ ${e.message}${lineInfo}</span>`;
    playSound('error');
  }
}

// ==========================================
// 8. 예제 코드 생성 및 주입
// ==========================================
function generateExampleCode(cfg) {
  const cmt = `${cfg.comment} 예제 코드`;
  const q = cfg.quote;
  const kw = cfg.keywords;
  return `${cmt}
${kw[6] || 'let'} x = 10
${kw[6] || 'let'} y = 20
${kw[6] || 'let'} result = x + y * 2

${kw[0] || '출력'} "결과: " + result

${kw[1] || '만약'} result > 30 {
  ${kw[0] || '출력'} ${q}크다${q}
}`;
}

function injectExample(type) {
  const cfg = getConfig();
  const q = cfg.quote; const kw = cfg.keywords;
  let code = "";
  if (type === 'hello') code = `${kw[0] || '출력'} ${q}Hello, World!${q}`;
  else if (type === 'math') code = `${kw[6] || 'let'} a = 3\n${kw[6] || 'let'} b = 4\n${kw[6] || 'let'} c = 5\n${kw[0] || '출력'} "우선순위: " + (a + b * c)\n${kw[0] || '출력'} "논리: " + (a < b && b < c)`;
  else if (type === 'func') code = `${kw[4] || '함수'} 팩토리얼(n) {\n  ${kw[1] || '만약'} n <= 1 {\n    ${kw[5] || '반환'} 1\n  }\n  ${kw[5] || '반환'} n * 팩토리얼(n - 1)\n}\n${kw[0] || '출력'} "5! = " + 팩토리얼(5)`;
  else if (type === 'for') code = `${kw[6] || 'let'} sum = 0\nfor (${kw[6] || 'let'} i = 1; i <= 5; i = i + 1) {\n  sum = sum + i\n}\n${kw[0] || '출력'} "1~5 합: " + sum`;
  else if (type === 'escape') code = `${kw[0] || '출력'} "첫째줄\\n둘째줄"\n${kw[0] || '출력'} "탭:\\t여기"\n${kw[0] || '출력'} "따옴표: \\\\"`;
  document.getElementById('codeEditor').value = code;
  handleInput();
}

function updateAll() {
  const cfg = getConfig();
  document.getElementById('displayExt').textContent = cfg.ext;
  checkCollisions(cfg);
  document.getElementById('previewCode').textContent = generateExampleCode(cfg);
  handleInput();
}

// ==========================================
// 9. 프로젝트 저장/불러오기
// ==========================================
function saveProject() {
  const state = {
    infoName: document.getElementById('infoName').value,
    infoVersion: document.getElementById('infoVersion').value,
    infoExt: document.getElementById('infoExt').value,
    infoAuthor: document.getElementById('infoAuthor').value,
    cfgKeywords: document.getElementById('cfgKeywords').value,
    cfgOperators: document.getElementById('cfgOperators').value,
    cfgTypes: document.getElementById('cfgTypes').value,
    cfgComment: document.getElementById('cfgComment').value,
    cfgQuote: document.getElementById('cfgQuote').value,
    code: document.getElementById('codeEditor').value
  };
  const blob = new Blob([JSON.stringify(state, null, 2)], { type: 'application/json' });
  const a = document.createElement('a'); a.href = URL.createObjectURL(blob); a.download = 'AVE_Project.json';
  document.body.appendChild(a); a.click(); document.body.removeChild(a);
}

function loadProject(input) {
  const file = input.files[0]; if (!file) return;
  const reader = new FileReader();
  reader.onload = (e) => {
    try {
      const state = JSON.parse(e.target.result);
      document.getElementById('infoName').value = state.infoName || 'AVE';
      document.getElementById('infoVersion').value = state.infoVersion || '1.0.0';
      document.getElementById('infoExt').value = state.infoExt || '.astvse';
      document.getElementById('infoAuthor').value = state.infoAuthor || 'Developer';
      document.getElementById('cfgKeywords').value = state.cfgKeywords || '출력,만약,아니면,반복,함수,반환,let,for,break,continue';
      document.getElementById('cfgOperators').value = state.cfgOperators || '==,!=,>=,<=,&&,||,+,-,*,/,%,!,=';
      document.getElementById('cfgTypes').value = state.cfgTypes || 'int,string,bool';
      document.getElementById('cfgComment').value = state.cfgComment || '//';
      document.getElementById('cfgQuote').value = state.cfgQuote || '"';
      document.getElementById('codeEditor').value = state.code || defaultCode;
      updateAll();
      playSound('success');
    } catch (err) { playSound('error'); alert('❌ 잘못된 프로젝트 파일입니다.'); }
  };
  reader.readAsText(file); input.value = '';
}

// ==========================================
// 10. VS Code 확장 생성
// ==========================================
function openGenerateModal() {
  const cfg = getConfig();
  const keywordRegex = cfg.keywords.join('|');
  const operatorRegex = cfg.operators.map(op => op.replace(/[.*+?^${}()|[\]\\]/g, '\\$&')).join('|');
  
  const tmLanguage = {
    "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
    "name": cfg.name, "scopeName": `source.${cfg.name.toLowerCase()}`,
    "patterns": [
      { "include": "#comments" }, { "include": "#strings" }, { "include": "#keywords" }, { "include": "#operators" }, { "include": "#numbers" }
    ],
    "repository": {
      "comments": { "patterns": [{ "name": "comment.line.ave", "match": `${cfg.comment}.*$` }] },
      "strings": { "name": "string.quoted.double.ave", "match": `${cfg.quote}(\\\\.|[^${cfg.quote}\\\\])*${cfg.quote}` },
      "keywords": { "name": "keyword.control.ave", "match": `\\b(${keywordRegex})\\b` },
      "operators": { "name": "keyword.operator.ave", "match": `(${operatorRegex})` },
      "numbers": { "name": "constant.numeric.ave", "match": "\\b(0[xX][0-9a-fA-F]+|0[bB][01]+|[0-9]+(\\.[0-9]+)?)\\b" }
    }
  };

  document.getElementById('modalBody').innerHTML = `
    <div style="color:var(--green); margin-bottom:10px;">🎉 아래 파일을 저장하고 <code>npm install && vsce package</code>를 실행하세요.</div>
    <div class="code-block">
      <button class="btn btn-small btn-primary copy-btn" onclick="copyCode(this)">복사</button>
      <h4 style="color:var(--blue); margin-bottom:8px;">1. package.json</h4>
      <pre>${JSON.stringify({"name": `${cfg.name.toLowerCase()}-syntax`, "displayName": `${cfg.name} Language`, "version": cfg.version, "publisher": cfg.author, "engines": {"vscode": "^1.75.0"}, "contributes": {"languages": [{"id": cfg.name.toLowerCase(), "aliases": [cfg.name], "extensions": [cfg.ext]}], "grammars": [{"language": cfg.name.toLowerCase(), "scopeName": `source.${cfg.name.toLowerCase()}`, "path": "./syntaxes/ave.tmLanguage.json"}]}}, null, 2)}</pre>
    </div>
    <div class="code-block">
      <button class="btn btn-small btn-primary copy-btn" onclick="copyCode(this)">복사</button>
      <h4 style="color:var(--blue); margin-bottom:8px;">2. syntaxes/ave.tmLanguage.json</h4>
      <pre>${JSON.stringify(tmLanguage, null, 2)}</pre>
    </div>
  `;
  document.getElementById('generateModal').style.display = 'flex';
}

function closeModal() { document.getElementById('generateModal').style.display = 'none'; }
function copyCode(btn) {
  const code = btn.nextElementSibling.nextElementSibling.textContent;
  navigator.clipboard.writeText(code).then(() => {
    const orig = btn.textContent; btn.textContent = '복사됨!'; btn.style.background = 'var(--green)';
    setTimeout(() => { btn.textContent = orig; btn.style.background = ''; }, 1500);
  });
}

function switchTab(tabName, btnElement) {
  document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(c => c.classList.remove('active'));
  btnElement.classList.add('active');
  document.getElementById('tab-' + tabName).classList.add('active');
}

function setLevel(level, btn) {
  document.body.setAttribute('data-level', level);
  document.querySelectorAll('.level-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

document.getElementById('themeSelect').addEventListener('change', (e) => {
  document.body.setAttribute('data-theme', e.target.value);
});

// 초기화
document.getElementById('codeEditor').value = defaultCode;
updateAll();
</script>

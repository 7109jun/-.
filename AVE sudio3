<script>
// ============ 상태 ============
const $ = id => document.getElementById(id);
let userExamples = JSON.parse(localStorage.getItem('aveUserExamples') || '[]');
let projects = JSON.parse(localStorage.getItem('aveProjects') || '[]');
let currentProjectId = null;

function getConfig() {
  const level = document.body.getAttribute('data-level');
  const config = {
    name: $('infoName').value||'AVE',
    ext: $('infoExt').value||'.ave',
    comment: level !== 'basic' ? ($('cfgComment')?.value || '//') : '//',
    quote: level !== 'basic' ? ($('cfgQuote')?.value || '"') : '"',
  };
  if (level === 'basic') {
    config.keywords = '출력,만약,아니면,반복,함수,반환,let,for,break,continue'.split(',');
    config.operators = '==,!=,>=,<=,&&,||,+,-,*,/,%,!,='.split(',');
    config.precedence = {'||':1,'&&':2,'==':3,'!=':3,'>':4,'<':4,'>=':4,'<=':4,'+':5,'-':5,'*':6,'/':6,'%':6};
  } else {
    config.keywords = $('cfgKeywords').value.split(',').map(s=>s.trim()).filter(Boolean);
    config.operators = $('cfgOperators').value.split(',').map(s=>s.trim()).filter(Boolean).sort((a,b)=>b.length-a.length);
    config.precedence = {'||':1,'&&':2,'==':3,'!=':3,'>':4,'<':4,'>=':4,'<=':4,'+':5,'-':5,'*':6,'/':6,'%':6};
  }
  config.decimal = '.'; config.hexPrefix = '0x'; config.binPrefix = '0b'; config.numSep = '_';
  return config;
}

function toggleAccordion(h) { h.parentElement.classList.toggle('open'); }

function checkCollisions(cfg) {
  const all=[...cfg.keywords,...cfg.operators];
  const dup=[...new Set(all.filter((v,i)=>all.indexOf(v)!==i))];
  const w=$('collisionWarning');
  if(dup.length){w.classList.add('show');$('collisionText').textContent=dup.join(', ');}
  else w.classList.remove('show');
}

function setLevel(level, btn) {
  document.body.setAttribute('data-level', level);
  document.querySelectorAll('.level-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const levels = {basic:0, standard:1, expert:2, creator:3};
  const cur = levels[level]||0;
  document.querySelectorAll('[data-min-level]').forEach(el => {
    const req = levels[el.getAttribute('data-min-level')]||0;
    if(cur >= req) el.classList.remove('level-hidden');
    else el.classList.add('level-hidden');
  });
  document.querySelectorAll('.accordion-item.level-hidden.open').forEach(el => el.classList.remove('open'));
  $('creatorUI').style.display = level === 'creator' ? 'block' : 'none';
  if (level === 'creator') {
    updateCreatorStats();
    renderCategoryFilter();
  }
  updateAll();
}

$('themeSelect').addEventListener('change', function() {
  document.body.setAttribute('data-theme', this.value);
});

function switchTab(name, btn) {
  document.querySelectorAll('#rightTabs .tab-btn').forEach(b => b.classList.remove('active'));
  document.querySelectorAll('.tab-content').forEach(c => { c.classList.remove('active'); c.style.display = 'none'; });
  btn.classList.add('active');
  const target = $('tab-' + name);
  if(target) { target.style.display = ''; target.classList.add('active'); }
}

// ============ 제작자 모드 ============
function updateCreatorStats() {
  const allInputs = document.querySelectorAll('input[id^="cr"], select[id^="cr"], textarea[id^="cr"]');
  const filledInputs = Array.from(allInputs).filter(el => el.value.trim() !== '');
  $('totalSettings').textContent = allInputs.length;
  $('totalCategories').textContent = document.querySelectorAll('.creator-only').length;
  $('completionRate').textContent = allInputs.length > 0 ? Math.round((filledInputs.length / allInputs.length) * 100) + '%' : '0%';
}

function renderCategoryFilter() {
  const categories = ['all', 'interpreter', 'compiler', 'runtime', 'debug', 'json'];
  const filterDiv = $('categoryFilter');
  filterDiv.innerHTML = categories.map(cat => 
    `<div class="filter-tag ${cat === 'all' ? 'active' : ''}" onclick="filterByCategory('${cat}', this)">${cat}</div>`
  ).join('');
}

function filterByCategory(category, btn) {
  document.querySelectorAll('.filter-tag').forEach(t => t.classList.remove('active'));
  btn.classList.add('active');
  document.querySelectorAll('.creator-only').forEach(item => {
    if (category === 'all' || item.getAttribute('data-category') === category) {
      item.classList.remove('level-hidden');
    } else {
      item.classList.add('level-hidden');
    }
  });
}

function filterCategories() {
  const query = $('creatorSearch').value.toLowerCase();
  document.querySelectorAll('.creator-only').forEach(item => {
    const text = item.textContent.toLowerCase();
    if (text.includes(query)) {
      item.classList.remove('level-hidden');
    } else {
      item.classList.add('level-hidden');
    }
  });
}

// ============ 프로젝트 관리 ============
function openProjectManager() {
  renderProjectList();
  $('projectModal').classList.add('show');
}

function closeProjectManager() {
  $('projectModal').classList.remove('show');
}

function renderProjectList() {
  const list = $('projectList');
  if (projects.length === 0) {
    list.innerHTML = '<div style="color:var(--comment);font-style:italic;padding:20px;text-align:center;">저장된 프로젝트가 없습니다.</div>';
    return;
  }
  list.innerHTML = projects.map((p, i) => `
    <div class="project-item">
      <div class="project-info">
        <div class="project-name">${p.name.replace(/</g,'&lt;')}</div>
        <div class="project-meta">생성: ${p.created} | 수정: ${p.modified}</div>
      </div>
      <div class="project-actions">
        <button class="btn btn-small btn-primary" onclick="loadProjectFromList(${i})">열기</button>
        <button class="btn btn-small btn-warning" onclick="duplicateProject(${i})">복제</button>
        <button class="btn btn-small btn-danger" onclick="deleteProject(${i})">삭제</button>
      </div>
    </div>
  `).join('');
}

function createNewProject() {
  const name = prompt('새 프로젝트 이름을 입력하세요:');
  if (!name) return;
  const project = {
    id: Date.now(),
    name: name,
    created: new Date().toLocaleString(),
    modified: new Date().toLocaleString(),
    data: {
      infoName: 'AVE',
      infoExt: '.ave',
      cfgKeywords: '출력,만약,아니면,반복,함수,반환,let,for,break,continue',
      cfgOperators: '==,!=,>=,<=,&&,||,+,-,*,/,%,!,=',
      cfgComment: '//',
      cfgQuote: '"',
      code: '// 새 프로젝트\n출력 "Hello, World!"'
    }
  };
  projects.push(project);
  localStorage.setItem('aveProjects', JSON.stringify(projects));
  renderProjectList();
}

function saveCurrentProject() {
  const name = prompt('프로젝트 이름을 입력하세요:', currentProjectId ? projects.find(p => p.id === currentProjectId)?.name : '새 프로젝트');
  if (!name) return;
  const data = {
    infoName: $('infoName').value,
    infoExt: $('infoExt').value,
    cfgKeywords: $('cfgKeywords').value,
    cfgOperators: $('cfgOperators').value,
    cfgComment: $('cfgComment').value,
    cfgQuote: $('cfgQuote').value,
    code: $('codeEditor').value
  };
  document.querySelectorAll('input[id^="cr"], textarea[id^="cr"], select[id^="cr"]').forEach(el => {
    data[el.id] = el.value;
  });
  if (currentProjectId) {
    const idx = projects.findIndex(p => p.id === currentProjectId);
    if (idx !== -1) {
      projects[idx].name = name;
      projects[idx].modified = new Date().toLocaleString();
      projects[idx].data = data;
    }
  } else {
    const project = {
      id: Date.now(),
      name: name,
      created: new Date().toLocaleString(),
      modified: new Date().toLocaleString(),
      data: data
    };
    projects.push(project);
    currentProjectId = project.id;
  }
  localStorage.setItem('aveProjects', JSON.stringify(projects));
  renderProjectList();
  alert('프로젝트가 저장되었습니다.');
}

function loadProjectFromList(idx) {
  const p = projects[idx];
  if (!p) return;
  $('infoName').value = p.data.infoName || 'AVE';
  $('infoExt').value = p.data.infoExt || '.ave';
  if (p.data.cfgKeywords) $('cfgKeywords').value = p.data.cfgKeywords;
  if (p.data.cfgOperators) $('cfgOperators').value = p.data.cfgOperators;
  if (p.data.cfgComment) $('cfgComment').value = p.data.cfgComment;
  if (p.data.cfgQuote) $('cfgQuote').value = p.data.cfgQuote;
  if (p.data.code) $('codeEditor').value = p.data.code;
  Object.keys(p.data).forEach(key => {
    if (key.startsWith('cr')) {
      const el = $(key);
      if (el) el.value = p.data[key];
    }
  });
  currentProjectId = p.id;
  updateAll();
  closeProjectManager();
}

function duplicateProject(idx) {
  const p = projects[idx];
  if (!p) return;
  const newProject = {
    id: Date.now(),
    name: p.name + ' (복사본)',
    created: new Date().toLocaleString(),
    modified: new Date().toLocaleString(),
    data: JSON.parse(JSON.stringify(p.data))
  };
  projects.push(newProject);
  localStorage.setItem('aveProjects', JSON.stringify(projects));
  renderProjectList();
}

function deleteProject(idx) {
  if (!confirm('이 프로젝트를 삭제하시겠습니까?')) return;
  projects.splice(idx, 1);
  localStorage.setItem('aveProjects', JSON.stringify(projects));
  renderProjectList();
}

// ============ Lexer ============
class LexerError extends Error { constructor(m,l,c){super(m);this.line=l;this.col=c;} }

function tokenize(code, cfg) {
  const tokens=[]; let i=0, line=1, col=1;
  while(i<code.length) {
    const sl=line, sc=col;
    const prevI = i;
    if(code[i]===' '||code[i]==='\t'){tokens.push({type:'t-ws',value:code[i],line:sl,col:sc,length:1});col++;i++;}
    else if(code[i]==='\n'){tokens.push({type:'t-ws',value:'\n',line:sl,col:sc,length:1});line++;col=1;i++;}
    else if(code[i]==='\r'){i++;}
    else if(cfg.comment && code.startsWith(cfg.comment,i)){
      let end=code.indexOf('\n',i); if(end===-1)end=code.length;
      const val = code.slice(i,end);
      tokens.push({type:'t-cmt',value:val,line:sl,col:sc,length:val.length});
      col+=val.length; i=end;
    }
    else if(code[i]===cfg.quote){
      let j=i+1, val=cfg.quote;
      while(j<code.length && code[j]!==cfg.quote){
        if(code[j]==='\\'&&j+1<code.length){val+=code[j]+code[j+1];j+=2;}
        else{val+=code[j];j++;}
      }
      if(j>=code.length) throw new LexerError('닫히지 않은 문자열입니다.', sl, sc);
      val+=cfg.quote;
      tokens.push({type:'t-str',value:val,line:sl,col:sc,length:val.length});
      col+=val.length; i=j+1;
    }
    else if(/[0-9]/.test(code[i])){
      let j=i;
      while(j<code.length&&(/[0-9.]/.test(code[j])||code[j]==='_'))j++;
      const val = code.slice(i,j);
      tokens.push({type:'t-num',value:val,line:sl,col:sc,length:val.length});
      col+=val.length;i=j;
    }
    else {
      let om=false;
      for(let op of cfg.operators){
        if(code.startsWith(op,i)){
          tokens.push({type:'t-op',value:op,line:sl,col:sc,length:op.length});
          col+=op.length;i+=op.length;om=true;break;
        }
      }
      if(!om){
        if('{ } ( ) [ ] , ;'.split(' ').includes(code[i])){
          tokens.push({type:'t-brk',value:code[i],line:sl,col:sc,length:1});col++;i++;
        } else {
          const idMatch = code.slice(i).match(/^[\p{L}\p{N}_]+/u);
          if(idMatch){
            const w = idMatch[0];
            const len = w.length;
            let tp='t-id';
            if(cfg.keywords.includes(w))tp='t-kw';
            tokens.push({type:tp,value:w,line:sl,col:sc,length:len});
            col+=len;i+=len;
          } else {
            tokens.push({type:'t-unknown',value:code[i],line:sl,col:sc,length:1});col++;i++;
          }
        }
      }
    }
    if (i === prevI) throw new LexerError(`처리할 수 없는 문자: '${code[i]}'`, sl, sc);
  }
  return tokens;
}

// ============ 하이라이팅 ============
function updateHighlight() {
  const code=$('codeEditor').value, cfg=getConfig();
  try {
    const tokens=tokenize(code,cfg);
    let html='';
    tokens.forEach(t=>{
      let v=t.value.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      html+= t.type==='t-ws' ? v : `<span class="${t.type}">${v}</span>`;
    });
    $('highlightLayer').innerHTML=html;
    $('statusDot').className='status-dot ok';
    $('statusError').style.display='none';
  } catch(e) {
    $('statusDot').className='status-dot err';
    $('statusError').style.display='';

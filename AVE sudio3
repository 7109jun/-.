// ============ Parser ============
class ParseError extends Error { constructor(m,l,c){super(m);this.line=l;this.col=c;} }
class Parser {
  constructor(tokens,cfg){
    this.t=tokens.filter(t=>t.type!=='t-ws');
    this.cfg=cfg; this.pos=0;
    this.kw = {
      print: cfg.keywords[0] || '출력', if: cfg.keywords[1] || '만약', else: cfg.keywords[2] || '아니면',
      while: cfg.keywords[3] || '반복', func: cfg.keywords[4] || '함수', return: cfg.keywords[5] || '반환',
      let: cfg.keywords[6] || 'let', for: cfg.keywords[7] || 'for', break: cfg.keywords[8] || 'break', continue: cfg.keywords[9] || 'continue'
    };
  }
  peek(o=0){return this.t[this.pos+o];}
  eat(){return this.t[this.pos++];}
  expect(tp,v){
    const t=this.peek();
    if(!t||t.type!==tp||(v&&t.value!==v))
      throw new ParseError(`예상: ${tp} ${v||''}, 실제: ${t?t.value:'EOF'}`,t?t.line:'?',t?t.col:'?');
    return this.eat();
  }
  parseProgram(){let b=[];while(this.pos<this.t.length)b.push(this.parseStmt());return{type:'Program',body:b};}
  parseStmt(){
    const t=this.peek(); if(!t)return null;
    if(t.type==='t-kw'&&t.value===this.kw.let){
      this.eat();const n=this.expect('t-id').value;this.expect('t-op','=');
      return{type:'VarDecl',name:n,value:this.parseExpr(),line:t.line,col:t.col,length:t.length};
    }
    if(t.type==='t-kw'&&t.value===this.kw.print){
      this.eat();
      return{type:'PrintStatement',expr:this.parseExpr(),line:t.line,col:t.col,length:t.length};
    }
    if(t.type==='t-kw'&&t.value===this.kw.if){
      this.eat();const cond=this.parseExpr();this.expect('t-brk','{');const con=this.parseBlock();
      let alt=null;
      if(this.peek()?.type==='t-kw'&&this.peek().value===this.kw.else){
        this.eat();
        if(this.peek()?.type==='t-kw'&&this.peek().value===this.kw.if) alt=[this.parseStmt()];
        else{this.expect('t-brk','{');alt=this.parseBlock();}
      }
      return{type:'IfStatement',cond,consequent:con,alternate:alt,line:t.line,col:t.col,length:t.length};
    }
    if(t.type==='t-kw'&&t.value===this.kw.while){
      this.eat();const c=this.parseExpr();this.expect('t-brk','{');
      return{type:'WhileStatement',cond:c,body:this.parseBlock(),line:t.line,col:t.col,length:t.length};
    }
    if(t.type==='t-kw'&&t.value===this.kw.for){
      this.eat();this.expect('t-brk','(');
      let init=null;
      if(this.peek().value!==';'){
        if(this.peek().type==='t-kw'&&this.peek().value===this.kw.let){this.eat();const n=this.expect('t-id').value;this.expect('t-op','=');init={type:'VarDecl',name:n,value:this.parseExpr()};}
        else init=this.parseExpr();
      }
      this.expect('t-brk',';');
      let cond=this.peek().value!==';'?this.parseExpr():null;
      this.expect('t-brk',';');
      let upd=this.peek().value!==')'?this.parseExpr():null;
      this.expect('t-brk',')');this.expect('t-brk','{');
      return{type:'ForStatement',init,cond,update:upd,body:this.parseBlock(),line:t.line,col:t.col,length:t.length};
    }
    if(t.type==='t-kw'&&t.value===this.kw.func){
      this.eat();const n=this.expect('t-id').value;this.expect('t-brk','(');
      const p=[];if(this.peek().value!==')'){p.push(this.expect('t-id').value);while(this.peek()?.value===','){this.eat();p.push(this.expect('t-id').value);}}
      this.expect('t-brk',')');this.expect('t-brk','{');
      return{type:'FuncDecl',name:n,params:p,body:this.parseBlock(),line:t.line,col:t.col,length:t.length};
    }
    if(t.type==='t-kw'&&t.value===this.kw.return){
      this.eat();let v=null;if(this.peek()&&this.peek().value!=='}'&&this.peek().value!==';')v=this.parseExpr();
      return{type:'ReturnStatement',value:v,line:t.line,col:t.col,length:t.length};
    }
    if(t.type==='t-kw'&&t.value===this.kw.break){this.eat();return{type:'BreakStatement',line:t.line,col:t.col,length:t.length};}
    if(t.type==='t-kw'&&t.value===this.kw.continue){this.eat();return{type:'ContinueStatement',line:t.line,col:t.col,length:t.length};}
    return this.parseExprStmt();
  }
  parseBlock(){const s=[];while(this.peek()&&this.peek().value!=='}')s.push(this.parseStmt());this.expect('t-brk','}');return s;}
  parseExprStmt(){
    const e=this.parseExpr();
    if(e.type==='Identifier'&&this.peek()?.type==='t-op'&&this.peek().value==='='){this.eat();return{type:'Assignment',name:e.name,value:this.parseExpr(),line:e.line,col:e.col,length:e.length};}
    return{type:'ExprStmt',expr:e,line:e.line,col:e.col,length:e.length};
  }
  prec(op){return this.cfg.precedence[op] || 0;}
  parseExpr(){return this.parseBin(0);}
  parseBin(min){
    let l=this.parseUnary();
    while(this.peek()?.type==='t-op'&&this.prec(this.peek().value)>=min){
      const op=this.eat().value; l={type:'BinOp',op,left:l,right:this.parseBin(this.prec(op)+1),line:l.line,col:l.col,length:l.length};
    }
    return l;
  }
  parseUnary(){
    const t=this.peek();
    if(t?.type==='t-op'&&(t.value==='!'||t.value==='-')){this.eat();return{type:'Unary',op:t.value,arg:this.parseUnary(),line:t.line,col:t.col,length:t.length};}
    return this.parsePrimary();
  }
  parsePrimary(){
    const t=this.peek();
    if(!t)throw new ParseError('예상치 못한 EOF','?','?');
    if(t.type==='t-num'){this.eat();return{type:'Literal',vt:'Num',value:t.value,line:t.line,col:t.col,length:t.length};}
    if(t.type==='t-str'){
      this.eat();
      const raw=t.value.slice(1,-1);
      const q=this.cfg.quote;
      const p=raw.replace(/\\n/g,'\n').replace(/\\t/g,'\t').replace(/\\r/g,'\r').replace(/\\\\/g,'\\').replace(new RegExp('\\\\'+q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&'),'g'),q);
      return{type:'Literal',vt:'Str',value:p,line:t.line,col:t.col,length:t.length};
    }
    if(t.type==='t-id'){
      this.eat();
      if(this.peek()?.value==='('){this.eat();const a=[];if(this.peek().value!==')'){a.push(this.parseExpr());while(this.peek()?.value===','){this.eat();a.push(this.parseExpr());}}this.expect('t-brk',')');return{type:'Call',callee:t.value,args:a,line:t.line,col:t.col,length:t.length};}
      return{type:'Identifier',name:t.value,line:t.line,col:t.col,length:t.length};
    }
    if(t.value==='('){this.eat();const e=this.parseExpr();this.expect('t-brk',')');return e;}
    throw new ParseError(`예상치 못한 토큰: '${t.value}'`,t.line,t.col);
  }
}

// ============ Interpreter ============
class RetSig{constructor(v){this.value=v;}}
class BrkSig{}
class CntSig{}
class Env{
  constructor(p=null){this.v={};this.p=p;this.fn={};}
  def(n,val){this.v[n]=val;}
  get(n){if(n in this.v)return this.v[n];if(this.p)return this.p.get(n);throw new Error(`미정의 변수: ${n}`);}
  set(n,val){if(n in this.v){this.v[n]=val;return;}if(this.p){this.p.set(n,val);return;}throw new Error(`미정의 변수: ${n}`);}
  defFn(n,f){this.fn[n]=f;}
  getFn(n){if(n in this.fn)return this.fn[n];if(this.p)return this.p.getFn(n);throw new Error(`미정의 함수: ${n}`);}
}

class Interp {
  constructor(cfg){this.cfg=cfg;this.env=new Env();this.iter=0;this.MAX=50000;}
  async run(ast){this.out=[];this.iter=0;for(const n of ast.body)await this.eval(n,this.env);return this.out;}
  async chk(){
    if(++this.iter>this.MAX) throw new Error(`무한 루프 감지! (${this.MAX}회 초과).`);
    if(this.iter % 1000 === 0) await new Promise(r => setTimeout(r, 0));
  }
  async eval(n,e){
    if(!n)return;
    switch(n.type){
      case'VarDecl':e.def(n.name,await this.eval(n.value,e));break;
      case'Assignment':e.set(n.name,await this.eval(n.value,e));break;
      case'PrintStatement':this.out.push(String(await this.eval(n.expr,e)));break;
      case'IfStatement':if(await this.eval(n.cond,e)){for(const c of n.consequent)await this.eval(c,e);}else if(n.alternate){for(const c of n.alternate)await this.eval(c,e);}break;
      case'WhileStatement':while(await this.eval(n.cond,e)){await this.chk();try{for(const c of n.body)await this.eval(c,e);}catch(x){if(x instanceof BrkSig)break;if(x instanceof CntSig)continue;throw x;}}break;
      case'ForStatement':{const fe=new Env(e);if(n.init)await this.eval(n.init,fe);while(!n.cond||await this.eval(n.cond,fe)){await this.chk();try{for(const c of n.body)await this.eval(c,fe);}catch(x){if(x instanceof BrkSig)break;if(x instanceof CntSig){if(n.update)await this.eval(n.update,fe);continue;}throw x;}if(n.update)await this.eval(n.update,fe);}break;}
      case'FuncDecl':e.defFn(n.name,n);break;
      case'ReturnStatement':throw new RetSig(n.value?await this.eval(n.value,e):undefined);
      case'BreakStatement':throw new BrkSig();
      case'ContinueStatement':throw new CntSig();
      case'ExprStmt':await this.eval(n.expr,e);break;
      case'BinOp':{const l=await this.eval(n.left,e),r=await this.eval(n.right,e),o=n.op;
        if(o==='+')return(typeof l==='string'||typeof r==='string')?String(l)+String(r):l+r;
        if(o==='-')return l-r;if(o==='*')return l*r;if(o==='/')return l/r;if(o==='%')return l%r;
        if(o==='==')return l==r;if(o==='!=')return l!=r;if(o==='>')return l>r;if(o==='<')return l<r;
        if(o==='>=')return l>=r;if(o==='<=')return l<=r;if(o==='&&')return l&&r;if(o==='||')return l||r;break;}
      case'Unary':{const a=await this.eval(n.arg,e);if(n.op==='!')return!a;if(n.op==='-')return-a;break;}
      case'Literal':{
        if(n.vt==='Num'){
          const val = n.value.replace(this.cfg.numSep || '_', '');
          return parseFloat(val);
        }
        return n.value;
      }
      case'Identifier':return e.get(n.name);
      case'Call':{const fn=e.getFn(n.callee),ne=new Env(e);
        for(let i=0;i<fn.params.length;i++) ne.def(fn.params[i],i<n.args.length?await this.eval(n.args[i],e):undefined);
        try{for(const c of fn.body)await this.eval(c,ne);}catch(x){if(x instanceof RetSig)return x.value;throw x;}return undefined;}
    }
  }
}

// ============ AST 렌더러 ============
let astC=0;
function renderAST(n,pfx='n'){
  if(!n||typeof n!=='object'||!n.type)return '';
  const id=pfx+'-'+(astC++);
  let mappingText = '';
  const cfg = getConfig();
  if(n.type === 'PrintStatement') mappingText = `<span class="ast-mapping">'${cfg.keywords[0]}'</span>`;
  else if(n.type === 'IfStatement') mappingText = `<span class="ast-mapping">'${cfg.keywords[1]}'</span>`;
  else if(n.type === 'WhileStatement') mappingText = `<span class="ast-mapping">'${cfg.keywords[3]}'</span>`;
  else if(n.type === 'ForStatement') mappingText = `<span class="ast-mapping">'${cfg.keywords[7]}'</span>`;
  else if(n.type === 'FuncDecl') mappingText = `<span class="ast-mapping">'${cfg.keywords[4]}'</span>`;

  let c=`<span class="ast-type">${n.type}</span>${mappingText ? ' ' + mappingText : ''}`;
  if(n.name!==undefined)c+=` <span class="ast-key">이름:</span> <span class="ast-val">"${n.name}"</span>`;
  if(n.vt)c+=` <span class="ast-key">값:</span> <span class="ast-val">${JSON.stringify(n.value)}</span>`;
  if(n.op)c+=` <span class="ast-key">연산:</span> <span class="ast-val">"${n.op}"</span>`;
  if(n.callee)c+=` <span class="ast-key">함수:</span> <span class="ast-val">"${n.callee}"</span>`;
  
  let h=`<div id="${id}" class="ast-node">${c}`;
  const rc=(child,s)=>(child&&typeof child==='object'&&child.type)?renderAST(child,id+s):'';
  if(Array.isArray(n.body))n.body.forEach((c,i)=>h+=rc(c,'-b'+i));
  if(Array.isArray(n.consequent)){h+=`<div class="ast-node"><span class="ast-key">참일 때</span>`;n.consequent.forEach((c,i)=>h+=rc(c,'-cq'+i));h+=`</div>`;}
  if(Array.isArray(n.alternate)){h+=`<div class="ast-node"><span class="ast-key">거짓일 때</span>`;n.alternate.forEach((c,i)=>h+=rc(c,'-al'+i));h+=`</div>`;}
  h+=rc(n.left,'-l')+rc(n.right,'-r')+rc(n.arg,'-a')+rc(n.expr,'-e')+rc(n.cond,'-cd')+rc(n.init,'-in')+rc(n.update,'-up')+rc(n.value,'-v');
  if(n.args){h+=`<div class="ast-node"><span class="ast-key">인수</span>`;n.args.forEach((a,i)=>h+=rc(a,'-ag'+i));h+=`</div>`;}
  h+=`</div>`;return h;
}

function updateGrammarMap(cfg) {
  const kw = cfg.keywords;
  $('mapContent').innerHTML = `
    <div class="map-item"><span class="map-user">${kw[0]||'출력'}</span> <span class="map-arrow">➔</span> <span class="map-ast">PrintStatement</span></div>
    <div class="map-item"><span class="map-user">${kw[1]||'만약'}</span> <span class="map-arrow">➔</span> <span class="map-ast">IfStatement</span></div>
    <div class="map-item"><span class="map-user">${kw[3]||'반복'}</span> <span class="map-arrow">➔</span> <span class="map-ast">WhileStatement</span></div>
    <div class="map-item"><span class="map-user">${kw[4]||'함수'}</span> <span class="map-arrow">➔</span> <span class="map-ast">FuncDecl</span></div>
    <div class="map-item"><span class="map-user">${kw[6]||'let'}</span> <span class="map-arrow">➔</span> <span class="map-ast">VarDecl</span></div>
  `;
}

// ============ 실행 ============
async function runCode(){
  const out=$('outputBox'), ast=$('astOutput');
  out.innerHTML=''; ast.innerHTML='<span class="log-info">구조를 분석하는 중입니다...</span>';
  switchTab('ast',document.querySelector('[data-tab="ast"]'));
  const code=$('codeEditor').value, cfg=getConfig();
  try{
    astC=0;
    const tokens=tokenize(code,cfg);
    const parser=new Parser(tokens,cfg);
    const astObj=parser.parseProgram();
    updateGrammarMap(cfg);
    ast.innerHTML=`<div class="ast-root">Program</div>`+renderAST(astObj);
    const interp=new Interp(cfg);
    const results=await interp.run(astObj);
    switchTab('output',document.querySelector('[data-tab="output"]'));
    out.innerHTML=`<span class="log-success">실행 완료! (${interp.iter}번 반복)</span>\n<span style="color:var(--border);display:block;margin:8px 0;">--------------------------------------------------</span>`;
    results.forEach(line=>{out.innerHTML+=`<div>${line}</div>`;});
  } catch(e) {
    const li=e.line?` (${e.line}줄 ${e.col}열)`:'';
    ast.innerHTML=`<span class="log-error">오류: ${e.message}${li}</span>`;
    switchTab('output',document.querySelector('[data-tab="output"]'));
    out.innerHTML=`<span class="log-error">오류: ${e.message}${li}</span>`;
  }
}


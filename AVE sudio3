function loadProjectFile(input) {
  const file = input.files[0]; if(!file) return;
  const reader = new FileReader();
  reader.onload = (e) => {
    try {
      const s = JSON.parse(e.target.result);
      $('infoName').value = s.infoName||'AVE';
      $('infoExt').value = s.infoExt||'.ave';
      if(s.cfgKeywords) $('cfgKeywords').value = s.cfgKeywords;
      if(s.cfgOperators) $('cfgOperators').value = s.cfgOperators;
      if(s.cfgComment) $('cfgComment').value = s.cfgComment;
      if(s.cfgQuote) $('cfgQuote').value = s.cfgQuote;
      Object.keys(s).forEach(key => {
        if (key.startsWith('cr')) {
          const el = $(key);
          if (el) el.value = s[key];
        }
      });
      $('codeEditor').value = s.code||defaultCode;
      updateAll();
    } catch(err) { alert('잘못된 프로젝트 파일입니다.'); }
  };
  reader.readAsText(file); input.value = '';
}

function updateAll() {
  const cfg = getConfig();
  $('displayExt').textContent = cfg.ext;
  $('statusExt').textContent = cfg.ext;
  checkCollisions(cfg);
  updateGrammarMap(cfg);
  updateHighlight();
}

// ============ 초기화 ============
$('codeEditor').value = defaultCode;
renderUserExamples();
updateAll();
</script>
</body>
</html>
